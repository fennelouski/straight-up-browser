        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una sesión aislada y persistente, con sus propias cookies e inicios de sesión: mantente conectado con cuentas distintas, una al lado de la otra."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
