    "100% leaves pages alone. Lower caps how bright white can get." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عند 100% تبقى الصفحات كما هي. وكلما قلّت القيمة تقيّد مدى سطوع الأبيض."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al 100 % les pàgines queden intactes. Més avall limita com de brillant pot ser el blanc."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % nechá stránky být. Níž omezíš, jak jasná může být bílá."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % lader sider være. Lavere sætter loft over, hvor lyst hvidt må blive."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % lässt Seiten unverändert. Niedriger begrenzt, wie hell Weiß werden darf."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Στο 100% οι σελίδες μένουν ανέγγιχτες. Πιο χαμηλά περιορίζεις πόσο φωτεινό μπορεί να γίνει το λευκό."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al 100 % las páginas quedan intactas. Más bajo limita cuánto puede brillar el blanco."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al 100 % las páginas quedan intactas. Más bajo limita cuánto puede brillar el blanco."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % jättää sivut rauhaan. Pienempi arvo rajaa, kuinka kirkkaaksi valkoinen voi käydä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % laisse les pages intactes. Plus bas, cela limite l'intensité du blanc."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % laisse les pages intactes. Plus bas, cela limite l'intensité du blanc."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ב‑100% הדפים נשארים כמו שהם. נמוך יותר מגביל עד כמה הלבן יכול להיות בהיר."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100% पर पृष्ठ जैसे हैं वैसे ही रहते हैं। कम करने पर सफ़ेद कितना चमकीला हो सकता है, यह सीमित हो जाता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % ostavlja stranice na miru. Niže ograničava koliko svijetla bijela može biti."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100%-on az oldalak érintetlenek maradnak. Lejjebb korlátozza, mennyire lehet világos a fehér."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pada 100% halaman dibiarkan apa adanya. Lebih rendah membatasi seberapa terang putih bisa jadi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al 100% le pagine restano intatte. Più in basso limiti quanto può diventare luminoso il bianco."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100% ならページはそのままです。下げるほど白の明るさに上限がかかります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100%면 페이지를 그대로 둡니다. 낮출수록 흰색이 얼마나 밝아질 수 있는지를 제한합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pada 100% halaman dibiarkan seadanya. Lebih rendah mengehadkan sejauh mana putih boleh menjadi cerah."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % lar sider være i fred. Lavere setter tak på hvor lyst hvitt kan bli."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100% laat pagina's ongemoeid. Lager begrenst hoe fel wit mag worden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100% zostawia strony w spokoju. Niżej ogranicza, jak jasna może być biel."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100% deixa as páginas como estão. Mais baixo limita o quanto o branco pode brilhar."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100% deixa as páginas como estão. Mais baixo limita o quanto o branco pode brilhar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100% lasă paginile neatinse. Mai jos limitează cât de luminos poate fi albul."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % оставляет страницы как есть. Меньше — ограничивает, насколько ярким может быть белый."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % nechá stránky tak, ako sú. Nižšie obmedzíš, aká jasná môže byť biela."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % lämnar sidor orörda. Lägre värden begränsar hur ljust vitt får bli."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ที่ 100% หน้าเว็บจะไม่ถูกแตะต้อง ค่าที่ต่ำลงจะจำกัดว่าสีขาวจะสว่างได้แค่ไหน"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%100'de sayfalara dokunulmaz. Daha düşük değerler beyazın ne kadar parlayabileceğini sınırlar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100 % лишає сторінки як є. Менше — обмежує, наскільки яскравим може бути білий."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ở mức 100% các trang giữ nguyên. Thấp hơn sẽ giới hạn màu trắng có thể sáng đến đâu."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100% 时页面保持原样。调低则限制白色能有多亮。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100% 時頁面維持原樣。調低則限制白色能有多亮。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "100% 時頁面維持原樣。調低則限制白色能有多亮。"
