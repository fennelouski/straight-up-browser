    "Before you open your window to the Internet, please accept the End User License Agreement.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قبل أن تفتح نافذتك على الإنترنت، يُرجى قبول اتفاقية ترخيص المستخدم النهائي."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Abans d'obrir la teva finestra a internet, accepta l'acord de llicència d'usuari final."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Než otevřeš své okno do internetu, přijmi prosím licenční smlouvu s koncovým uživatelem."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Før du åbner dit vindue mod internettet, skal du acceptere slutbrugerlicensaftalen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bevor du dein Fenster zum Internet öffnest, akzeptiere bitte die Endbenutzer-Lizenzvereinbarung."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πριν ανοίξεις το παράθυρό σου στο διαδίκτυο, αποδέξου την Άδεια Χρήσης Τελικού Χρήστη."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Antes de abrir tu ventana a Internet, acepta el Contrato de licencia de usuario final."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Antes de abrir tu ventana a Internet, acepta el Contrato de licencia de usuario final."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ennen kuin avaat ikkunasi internetiin, hyväksy loppukäyttäjän käyttöoikeussopimus."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Avant d'ouvrir votre fenêtre sur Internet, veuillez accepter le contrat de licence utilisateur final."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Avant d'ouvrir votre fenêtre sur Internet, veuillez accepter le contrat de licence utilisateur final."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לפני שתפתח את החלון שלך אל האינטרנט, אנא אשר את הסכם רישיון משתמש הקצה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इंटरनेट पर अपनी विंडो खोलने से पहले, कृपया अंतिम-उपयोगकर्ता लाइसेंस अनुबंध स्वीकार करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prije nego otvoriš svoj prozor prema internetu, prihvati ugovor o licenci za krajnjeg korisnika."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Mielőtt megnyitnád az ablakod az internetre, fogadd el a végfelhasználói licencszerződést."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sebelum membuka jendelamu ke Internet, harap terima Perjanjian Lisensi Pengguna Akhir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Prima di aprire la tua finestra su Internet, accetta il Contratto di licenza con l'utente finale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インターネットへの窓を開く前に、エンドユーザーライセンス契約に同意してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인터넷으로 향한 창을 열기 전에 최종 사용자 사용권 계약에 동의해 주세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sebelum membuka tetingkap anda ke Internet, sila terima Perjanjian Lesen Pengguna Akhir."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Før du åpner vinduet ditt mot internett, må du godta sluttbrukerlisensavtalen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voordat je je venster op internet opent, accepteer de licentieovereenkomst voor eindgebruikers."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zanim otworzysz swoje okno na internet, zaakceptuj umowę licencyjną użytkownika końcowego."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Antes de abrir sua janela para a Internet, aceite o Contrato de Licença de Usuário Final."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Antes de abrir sua janela para a Internet, aceite o Contrato de Licença de Usuário Final."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Înainte de a-ți deschide fereastra către internet, te rugăm să accepți acordul de licență pentru utilizatorul final."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прежде чем открыть своё окно в интернет, примите Лицензионное соглашение с конечным пользователем."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Skôr než otvoríš svoje okno do internetu, prijmi prosím licenčnú zmluvu s koncovým používateľom."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Innan du öppnar ditt fönster mot internet, godkänn licensavtalet för slutanvändare."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ก่อนเปิดหน้าต่างของคุณสู่อินเทอร์เน็ต โปรดยอมรับข้อตกลงสิทธิ์การใช้งานสำหรับผู้ใช้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İnternete açılan pencereni açmadan önce lütfen Son Kullanıcı Lisans Sözleşmesi'ni kabul et."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перш ніж відкрити своє вікно в інтернет, прийміть Ліцензійну угоду з кінцевим користувачем."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Trước khi mở cửa sổ ra Internet, vui lòng chấp nhận Thỏa thuận Cấp phép Người dùng Cuối."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "在打開你通往網際網路的視窗之前，請接受終端使用者授權合約。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在打开你通往互联网的窗口之前，请接受最终用户许可协议。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在打開你通往網際網路的視窗之前，請接受終端使用者授權合約。"
          }
        }
      }
    },
