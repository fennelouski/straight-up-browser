    "Nothing is released, so nothing needs reloading": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا شيء يُحرَّر، لذا لا شيء يحتاج إلى إعادة تحميل"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "No s'allibera res, així que no cal recarregar res"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nic se neuvolňuje, takže není třeba nic znovu načítat"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Intet frigives, så intet skal genindlæses"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Es wird nichts freigegeben, also muss nichts neu geladen werden"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τίποτα δεν απελευθερώνεται, οπότε τίποτα δεν χρειάζεται επαναφόρτωση"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se libera nada, así que no hay nada que recargar"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "No se libera nada, así que no hay nada que recargar"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mitään ei vapauteta, joten mitään ei tarvitse ladata uudelleen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rien n'est libéré, donc rien n'a besoin d'être rechargé"
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Rien n'est libéré, donc rien n'a besoin d'être rechargé"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שום דבר לא משוחרר, אז שום דבר לא צריך טעינה מחדש"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कुछ भी जारी नहीं होता, इसलिए कुछ भी फिर से लोड करने की आवश्यकता नहीं"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ništa se ne oslobađa, pa ništa ne treba ponovno učitavati"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Semmi sem szabadul fel, így semmit sem kell újratölteni"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tidak ada yang dilepaskan, jadi tidak ada yang perlu dimuat ulang"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non viene rilasciato nulla, quindi non c'è nulla da ricaricare"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "何も解放されないため、再読み込みは不要です"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "해제되는 것이 없으므로 다시 로드할 필요도 없습니다"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada apa yang dilepaskan, jadi tiada apa yang perlu dimuat semula"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingenting frigis, så ingenting trenger ny innlasting"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er wordt niets vrijgegeven, dus er hoeft niets opnieuw te worden geladen"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nic nie jest zwalniane, więc nic nie wymaga przeładowania"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nada é liberado, então nada precisa ser recarregado"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Nada é liberado, então nada precisa ser recarregado"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nimic nu se eliberează, așa că nimic nu trebuie reîncărcat"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ничего не выгружается, поэтому ничего не нужно перезагружать"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nič sa neuvoľňuje, takže nie je potrebné nič znova načítať"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inget frigörs, så inget behöver läsas om"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่มีอะไรถูกปล่อย ดังนั้นไม่มีอะไรต้องโหลดใหม่"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiçbir şey serbest bırakılmadığı için hiçbir şeyin yeniden yüklenmesi gerekmez"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Нічого не вивантажується, тож нічого не потрібно перезавантажувати"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không có gì được nhả, nên không cần tải lại gì cả"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
