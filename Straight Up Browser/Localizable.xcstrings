    "It also matches your open tabs, history, and bookmarks as you type, so it doubles as a quick switcher.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كما أنه يطابق علامات التبويب المفتوحة والسجل والإشارات المرجعية أثناء الكتابة، فيعمل كمبدّل سريع أيضًا."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "També coincideix amb les teves pestanyes obertes, l'historial i les adreces d'interès mentre escrius, així que també fa de commutador ràpid."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Během psaní také porovnává tvé otevřené karty, historii a záložky, takže slouží i jako rychlý přepínač."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Den matcher også dine åbne faneblade, din historik og dine bogmærker, mens du skriver, så den fungerer også som en hurtig skifter."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie gleicht beim Tippen auch deine offenen Tabs, deinen Verlauf und deine Lesezeichen ab und dient so zugleich als schneller Umschalter."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επίσης αντιστοιχίζει τις ανοιχτές καρτέλες, το ιστορικό και τους σελιδοδείκτες σου καθώς πληκτρολογείς, οπότε λειτουργεί και ως γρήγορος εναλλάκτης."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "También coincide con tus pestañas abiertas, tu historial y tus marcadores mientras escribes, por lo que sirve además como selector rápido."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "También coincide con tus pestañas abiertas, tu historial y tus marcadores mientras escribes, por lo que sirve además como selector rápido."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Se vastaa myös avoimia välilehtiäsi, historiaasi ja kirjanmerkkejäsi sitä mukaa kun kirjoitat, joten se toimii myös nopeana vaihtajana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il fait aussi correspondre vos onglets ouverts, votre historique et vos favoris au fur et à mesure que vous tapez, servant ainsi de sélecteur rapide."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Il fait aussi correspondre vos onglets ouverts, votre historique et vos favoris au fur et à mesure que vous tapez, servant ainsi de sélecteur rapide."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הוא גם מתאים את הכרטיסיות הפתוחות, ההיסטוריה והסימניות שלך תוך כדי הקלדה, כך שהוא משמש גם כמחליף מהיר."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यह टाइप करते समय आपके खुले टैब, इतिहास और बुकमार्क से भी मिलान करता है, इसलिए यह एक त्वरित स्विचर के रूप में भी काम करता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Također podudara tvoje otvorene kartice, povijest i knjižne oznake dok tipkaš, pa služi i kao brzi preklopnik."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Gépelés közben egyezteti a nyitott lapjaidat, előzményeidet és könyvjelzőidet is, így gyors váltóként is szolgál."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ia juga mencocokkan tab terbuka, riwayat, dan markahmu saat kamu mengetik, sehingga berfungsi ganda sebagai pengalih cepat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mentre digiti, trova anche corrispondenze tra le tue schede aperte, la cronologia e i segnalibri, quindi funge anche da selettore rapido."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "入力するにつれて開いているタブ、履歴、ブックマークも照合するため、クイックスイッチャーとしても機能します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "입력하는 동안 열린 탭, 기록, 북마크도 일치시키므로 빠른 전환기 역할도 합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Ia juga sepadan dengan tab terbuka, sejarah dan penanda buku anda semasa anda menaip, jadi ia berfungsi sebagai penukar pantas."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Den matcher også de åpne fanene dine, loggen og bokmerkene dine mens du skriver, så den fungerer også som en rask veksler."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Terwijl je typt, matcht hij ook je open tabbladen, geschiedenis en bladwijzers, zodat hij tevens als snelle wisselaar dient."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Podczas pisania dopasowuje też Twoje otwarte karty, historię i zakładki, więc pełni również funkcję szybkiego przełącznika."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ela também combina com suas abas abertas, seu histórico e seus favoritos enquanto você digita, funcionando também como um alternador rápido."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ela também combina com suas abas abertas, seu histórico e seus favoritos enquanto você digita, funcionando também como um alternador rápido."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "De asemenea, potrivește filele deschise, istoricul și marcajele pe măsură ce tastezi, așa că servește și ca un comutator rapid."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Он также сопоставляет ваши открытые вкладки, историю и закладки по мере ввода, поэтому служит и быстрым переключателем."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Počas písania tiež porovnáva tvoje otvorené karty, históriu a záložky, takže slúži aj ako rýchly prepínač."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Den matchar även dina öppna flikar, din historik och dina bokmärken medan du skriver, så den fungerar också som en snabbväxlare."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "นอกจากนี้ยังจับคู่แท็บที่เปิดอยู่ ประวัติ และบุ๊กมาร์กของคุณขณะที่คุณพิมพ์ ดังนั้นจึงทำหน้าที่เป็นตัวสลับด่วนด้วย"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yazarken açık sekmelerini, geçmişini ve yer işaretlerini de eşleştirir, bu yüzden hızlı bir geçiş aracı olarak da işlev görür."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Він також зіставляє ваші відкриті вкладки, історію та закладки під час введення, тож слугує і швидким перемикачем."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nó cũng khớp với các thẻ đang mở, lịch sử và dấu trang của bạn khi bạn gõ, nên đóng vai trò như một công cụ chuyển nhanh."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "在你輸入時，它還會比對你打開的分頁、紀錄與書籤，因此兼具快速切換器的功能。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在你输入时，它还会匹配你打开的标签页、历史记录和书签，因此兼具快速切换器的功能。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在你輸入時，它還會比對你打開的分頁、紀錄與書籤，因此兼具快速切換器的功能。"
          }
        }
      }
    },
