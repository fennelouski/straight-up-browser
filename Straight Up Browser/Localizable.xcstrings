    "How hard the found match announces itself." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مدى قوة إعلان التطابق عن نفسه."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amb quanta força s'anuncia la coincidència trobada."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jak výrazně se nalezená shoda přihlásí."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvor tydeligt det fundne resultat melder sig."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wie deutlich sich der gefundene Treffer meldet."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
