    "Any process running as you can then click inside the browser window.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أي عملية تعمل باسمك يمكنها حينئذٍ النقر داخل نافذة المتصفح."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualsevol procés que s'executi com tu podrà llavors fer clic dins de la finestra del navegador."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jakýkoli proces běžící pod tvým účtem pak může klikat uvnitř okna prohlížeče."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Enhver proces, der kører som dig, kan så klikke inde i browservinduet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeder Prozess, der unter deinem Konto läuft, kann dann in das Browserfenster klicken."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οποιαδήποτε διεργασία εκτελείται ως εσύ μπορεί τότε να κάνει κλικ μέσα στο παράθυρο του προγράμματος περιήγησης."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cualquier proceso que se ejecute como tú podrá entonces hacer clic dentro de la ventana del navegador."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Cualquier proceso que se ejecute como tú podrá entonces hacer clic dentro de la ventana del navegador."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mikä tahansa sinuna toimiva prosessi voi tällöin napsauttaa selainikkunan sisällä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout processus s'exécutant en votre nom peut alors cliquer dans la fenêtre du navigateur."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout processus s'exécutant en votre nom peut alors cliquer dans la fenêtre du navigateur."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "כל תהליך שרץ בשמך יוכל אז ללחוץ בתוך חלון הדפדפן."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके रूप में चल रही कोई भी प्रक्रिया तब ब्राउज़र विंडो के अंदर क्लिक कर सकती है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bilo koji proces koji se izvodi kao ti tada može kliktati unutar prozora preglednika."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Bármely, a te nevedben futó folyamat ekkor kattinthat a böngészőablakon belül."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Proses apa pun yang berjalan sebagai kamu kemudian dapat mengeklik di dalam jendela browser."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualsiasi processo eseguito a tuo nome potrà quindi fare clic all'interno della finestra del browser."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたとして実行されているどんなプロセスも、そのときブラウザウィンドウ内をクリックできるようになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "그러면 사용자로 실행되는 모든 프로세스가 브라우저 창 내부를 클릭할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sebarang proses yang berjalan sebagai anda kemudiannya boleh mengklik di dalam tetingkap pelayar."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Enhver prosess som kjører som deg, kan da klikke inne i nettleservinduet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Elk proces dat als jou draait, kan dan in het browservenster klikken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Każdy proces działający jako ty będzie mógł wtedy klikać wewnątrz okna przeglądarki."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualquer processo executado como você poderá então clicar dentro da janela do navegador."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Qualquer processo executado como você poderá então clicar dentro da janela do navegador."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Orice proces care rulează ca tine poate atunci să facă clic în interiorul ferestrei browserului."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Любой процесс, запущенный от вашего имени, сможет тогда щёлкать внутри окна браузера."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Akýkoľvek proces bežiaci pod tvojím účtom potom môže klikať vnútri okna prehliadača."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vilken process som helst som körs som du kan då klicka inuti webbläsarfönstret."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กระบวนการใดก็ตามที่ทำงานในนามคุณจะสามารถคลิกภายในหน้าต่างเบราว์เซอร์ได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Senin adına çalışan herhangi bir işlem, o zaman tarayıcı penceresinin içine tıklayabilir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Будь-який процес, запущений від вашого імені, зможе тоді клікати всередині вікна браузера."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bất kỳ tiến trình nào chạy dưới danh nghĩa bạn khi đó đều có thể nhấp bên trong cửa sổ trình duyệt."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "屆時，任何以你身分執行的程序都可以在瀏覽器視窗內點按。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "届时，任何以你身份运行的进程都可以在浏览器窗口内点击。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "屆時，任何以你身分執行的程序都可以在瀏覽器視窗內點按。"
          }
        }
      }
    },
