    "Removes cookies, cache, and storage for normal browsing. Container sessions keep their own data. This can’t be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يزيل ملفات تعريف الارتباط والذاكرة المؤقتة والتخزين للتصفح العادي. تحتفظ جلسات الحاويات ببياناتها. لا يمكن التراجع عن ذلك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina galetes, memòria cau i emmagatzematge de la navegació normal. Les sessions de contenidor conserven les seves dades. Això no es pot desfer."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Odstraní cookies, mezipaměť a úložiště pro běžné prohlížení. Relace kontejnerů si nechají vlastní data. Nelze vzít zpět."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fjerner cookies, cache og lager for almindelig browsing. Beholdersessioner beholder deres egne data. Det kan ikke fortrydes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entfernt Cookies, Cache und Speicher für das normale Surfen. Container-Sitzungen behalten ihre eigenen Daten. Das lässt sich nicht rückgängig machen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αφαιρεί cookies, προσωρινή μνήμη και αποθήκευση για την κανονική περιήγηση. Οι συνεδρίες κοντέινερ κρατούν τα δικά τους δεδομένα. Δεν αναιρείται."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina cookies, caché y almacenamiento de la navegación normal. Las sesiones de contenedor conservan sus propios datos. Esto no se puede deshacer."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina cookies, caché y almacenamiento de la navegación normal. Las sesiones de contenedor conservan sus propios datos. Esto no se puede deshacer."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poistaa evästeet, välimuistin ja tallennustilan tavalliselta selaukselta. Säiliöistunnot säilyttävät omat tietonsa. Tätä ei voi kumota."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprime les cookies, le cache et le stockage de la navigation normale. Les sessions de conteneur conservent leurs propres données. Cette action est irréversible."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Supprime les cookies, le cache et le stockage de la navigation normale. Les sessions de conteneur conservent leurs propres données. Cette action est irréversible."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "מסיר עוגיות, מטמון ואחסון לגלישה הרגילה. הפעלות של מכולות שומרות על הנתונים שלהן. אי אפשר לבטל את הפעולה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सामान्य ब्राउज़िंग की कुकीज़, कैश और संग्रहण हटाता है। कंटेनर सत्र अपना डेटा रखते हैं। इसे पहले जैसा नहीं किया जा सकता।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uklanja kolačiće, predmemoriju i pohranu za uobičajeno pregledavanje. Sesije spremnika zadržavaju vlastite podatke. Ovo se ne može poništiti."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eltávolítja a sütiket, a gyorsítótárat és a tárolót a szokásos böngészéshez. A konténer-munkamenetek megtartják a saját adataikat. Ez nem vonható vissza."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menghapus cookie, cache, dan penyimpanan untuk penjelajahan biasa. Sesi kontainer menyimpan datanya sendiri. Ini tidak bisa dibatalkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rimuove cookie, cache e archiviazione della navigazione normale. Le sessioni dei contenitori mantengono i propri dati. L'operazione non può essere annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "通常の閲覧の Cookie、キャッシュ、ストレージを削除します。コンテナのセッションは自身のデータを保持します。この操作は取り消せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "일반 브라우징의 쿠키, 캐시, 저장소를 삭제합니다. 컨테이너 세션은 자체 데이터를 유지합니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Membuang kuki, cache dan storan bagi pelayaran biasa. Sesi bekas mengekalkan data masing-masing. Ini tidak boleh dibuat asal."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fjerner informasjonskapsler, buffer og lagring for vanlig surfing. Beholderøkter beholder sine egne data. Dette kan ikke angres."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwijdert cookies, cache en opslag voor gewoon browsen. Containersessies houden hun eigen gegevens. Dit kan niet ongedaan worden gemaakt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usuwa ciasteczka, pamięć podręczną i magazyn dla zwykłego przeglądania. Sesje kontenerów zachowują własne dane. Tego nie można cofnąć."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remove cookies, cache e armazenamento da navegação normal. Sessões de contêiner mantêm os próprios dados. Isso não pode ser desfeito."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remove cookies, cache e armazenamento da navegação normal. Sessões de contêiner mantêm os próprios dados. Isso não pode ser desfeito."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimină cookie-urile, cache-ul și stocarea pentru navigarea obișnuită. Sesiunile de container își păstrează propriile date. Această acțiune nu poate fi anulată."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
