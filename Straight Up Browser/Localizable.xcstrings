    "Every pixel exactly as captured. Bigger files, perfectly crisp text." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل بكسل تمامًا كما صُوِّر. ملفات أكبر ونص حاد تمامًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada píxel exactament tal com s'ha capturat. Fitxers més grans, text perfectament nítid."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Každý pixel přesně tak, jak byl zachycen. Větší soubory, dokonale ostrý text."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hver eneste pixel præcis som taget. Større filer, knivskarp tekst."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jedes Pixel genau wie aufgenommen. Größere Dateien, perfekt scharfer Text."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Κάθε εικονοστοιχείο ακριβώς όπως καταγράφηκε. Μεγαλύτερα αρχεία, τέλεια καθαρό κείμενο."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada píxel exactamente como se capturó. Archivos más grandes, texto perfectamente nítido."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada píxel exactamente como se capturó. Archivos más grandes, texto perfectamente nítido."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jokainen pikseli täsmälleen kaapattuna. Isommat tiedostot, täysin terävä teksti."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque pixel exactement tel que capturé. Fichiers plus lourds, texte parfaitement net."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chaque pixel exactement tel que capturé. Fichiers plus lourds, texte parfaitement net."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "כל פיקסל בדיוק כפי שצולם. קבצים גדולים יותר, טקסט חד לחלוטין."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "हर पिक्सेल ठीक वैसा जैसा कैप्चर हुआ। फ़ाइलें बड़ी, पर पाठ बिलकुल साफ़।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svaki piksel točno onakav kakav je snimljen. Veće datoteke, savršeno oštar tekst."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minden képpont pontosan úgy, ahogy rögzült. Nagyobb fájlok, tökéletesen éles szöveg."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setiap piksel persis seperti saat ditangkap. Berkas lebih besar, teks sangat tajam."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ogni pixel esattamente come acquisito. File più grandi, testo perfettamente nitido."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キャプチャしたままの全ピクセル。ファイルは大きくなりますが、文字は完全に鮮明です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "캡처된 그대로의 모든 픽셀. 파일은 커지지만 글자는 완벽하게 또렷합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setiap piksel tepat seperti ditangkap. Fail lebih besar, teks amat tajam."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hver piksel nøyaktig slik den ble tatt. Større filer, knivskarp tekst."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elke pixel precies zoals vastgelegd. Grotere bestanden, messcherpe tekst."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Każdy piksel dokładnie taki, jak zarejestrowany. Większe pliki, idealnie ostry tekst."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada pixel exatamente como foi capturado. Arquivos maiores, texto perfeitamente nítido."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada pixel exatamente como foi capturado. Arquivos maiores, texto perfeitamente nítido."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fiecare pixel exact cum a fost capturat. Fișiere mai mari, text perfect clar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Каждый пиксель ровно таким, каким он снят. Файлы больше, текст идеально чёткий."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Každý pixel presne tak, ako bol zachytený. Väčšie súbory, dokonale ostrý text."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varje bildpunkt exakt som den fångades. Större filer, knivskarp text."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ทุกพิกเซลตรงตามที่ถ่ายมา ไฟล์ใหญ่ขึ้น แต่ข้อความคมกริบ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her piksel tam yakalandığı gibi. Daha büyük dosyalar, kusursuz keskin metin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Кожен піксель точно таким, яким його знято. Файли більші, текст ідеально чіткий."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Từng điểm ảnh đúng như lúc chụp. Tệp lớn hơn, chữ sắc nét tuyệt đối."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每个像素都与拍下时一致。文件更大，文字绝对锐利。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每個像素都與拍下時一致。檔案更大，文字絕對銳利。"
          }
        },
        "zh-HK" : {
