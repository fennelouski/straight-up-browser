    "⌘P prints instead of exporting a PDF if you turn off “⌘P exports PDF” in Settings → General." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P يطبع بدلًا من تصدير PDF إذا أوقفت «⌘P يصدّر PDF» في الإعدادات ← عام."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P imprimeix en lloc d'exportar un PDF si desactives «⌘P exporta PDF» a Configuració → General."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P tiskne místo exportu PDF, pokud vypneš «⌘P exportuje PDF» v Nastavení → Obecné."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P udskriver i stedet for at eksportere en PDF, hvis du slår «⌘P eksporterer PDF» fra i Indstillinger → Generelt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P druckt, statt ein PDF zu exportieren, wenn du „⌘P exportiert PDF“ in Einstellungen → Allgemein ausschaltest."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P εκτυπώνει αντί να εξάγει PDF αν απενεργοποιήσεις το «⌘P εξάγει PDF» στις Ρυθμίσεις → Γενικά."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P imprime en lugar de exportar un PDF si desactivas «⌘P exporta PDF» en Ajustes → General."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P imprime en lugar de exportar un PDF si desactivas «⌘P exporta PDF» en Ajustes → General."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P tulostaa PDF-viennin sijaan, jos poistat käytöstä «⌘P vie PDF» kohdassa Asetukset → Yleiset."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P imprime au lieu d'exporter un PDF si vous désactivez « ⌘P exporte un PDF » dans Réglages → Général."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P imprime au lieu d'exporter un PDF si vous désactivez « ⌘P exporte un PDF » dans Réglages → Général."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P מדפיס במקום לייצא PDF אם תכבה «⌘P מייצא PDF» בהגדרות ← כללי."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि आप सेटिंग्स → सामान्य में «⌘P PDF निर्यात करता है» बंद करते हैं तो ⌘P PDF निर्यात करने के बजाय प्रिंट करता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P ispisuje umjesto izvoza PDF-a ako isključiš «⌘P izvozi PDF» u Postavke → Općenito."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P nyomtat PDF-exportálás helyett, ha kikapcsolod a «⌘P PDF-et exportál» beállítást a Beállítások → Általános menüben."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P mencetak alih-alih mengekspor PDF jika kamu mematikan «⌘P mengekspor PDF» di Pengaturan → Umum."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘P stampa invece di esportare un PDF se disattivi «⌘P esporta PDF» in Impostazioni → Generale."
          }
        },
        "ja" : {
