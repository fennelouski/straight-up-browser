    "Make the everyday shortcut save a PDF instead of printing.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اجعل الاختصار اليومي يحفظ ملف PDF بدلًا من الطباعة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Fes que la drecera de cada dia desi un PDF en lloc d'imprimir."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nech každodenní zkratku uložit PDF místo tisku."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Få den daglige genvej til at gemme en PDF i stedet for at udskrive."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Den alltäglichen Kurzbefehl statt zu drucken ein PDF speichern lassen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κάνε την καθημερινή συντόμευση να αποθηκεύει PDF αντί να εκτυπώνει."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hacer que el atajo de cada día guarde un PDF en lugar de imprimir."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Hacer que el atajo de cada día guarde un PDF en lugar de imprimir."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Saa jokapäiväinen pikanäppäin tallentamaan PDF-tiedosto tulostamisen sijaan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faire en sorte que le raccourci du quotidien enregistre un PDF au lieu d'imprimer."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Faire en sorte que le raccourci du quotidien enregistre un PDF au lieu d'imprimer."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
