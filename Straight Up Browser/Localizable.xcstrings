        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Φωτεινό, Σκοτεινό ή ακολούθησε το Mac σου."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Claro, Oscuro o seguir tu Mac."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Claro, Oscuro o seguir tu Mac."
          }
