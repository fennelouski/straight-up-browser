    "Everything the page holds, including what's still below the fold." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل ما تحتويه الصفحة، بما في ذلك ما يقع أسفل حدود الشاشة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tot el que conté la pàgina, també allò que queda per sota."
          }
        },
