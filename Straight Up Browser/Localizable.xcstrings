        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sistem, Mac'inin görünümünü izler — ve onunla birlikte değişir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
