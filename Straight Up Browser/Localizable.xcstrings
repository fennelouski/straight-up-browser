    "Sets the browser's own chrome — toolbar, tabs, menus. System follows your Mac's appearance and switches with it at sunset if you have that on. (Pages render in whatever appearance the site itself chooses.)" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحدد واجهة المتصفح الخاصة — شريط الأدوات وعلامات التبويب والقوائم. يتبع النظام مظهر الـ Mac لديك ويتبدّل معه عند الغروب إذا فعّلت ذلك. (تُعرض الصفحات بالمظهر الذي يختاره الموقع نفسه.)"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estableix la interfície pròpia del navegador — barra d'eines, pestanyes, menús. Sistema segueix l'aspecte del teu Mac i canvia amb ell a la posta de sol si ho tens activat. (Les pàgines es mostren amb l'aspecte que tria el mateix lloc.)"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nastavuje vlastní rozhraní prohlížeče — panel nástrojů, karty, nabídky. Systém se řídí vzhledem tvého Macu a přepíná se s ním při západu slunce, pokud to máš zapnuté. (Stránky se zobrazují ve vzhledu, který si vybere sám web.)"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Angiver browserens egen brugerflade — værktøjslinje, faneblade, menuer. System følger din Macs udseende og skifter med det ved solnedgang, hvis du har det slået til. (Sider vises i det udseende, som webstedet selv vælger.)"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legt die eigene Oberfläche des Browsers fest – Symbolleiste, Tabs, Menüs. System folgt dem Erscheinungsbild deines Mac und wechselt bei Sonnenuntergang mit, falls du das aktiviert hast. (Seiten werden in dem Erscheinungsbild dargestellt, das die Website selbst wählt.)"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ορίζει το δικό του περιβάλλον του προγράμματος περιήγησης — γραμμή εργαλείων, καρτέλες, μενού. Το Σύστημα ακολουθεί την εμφάνιση του Mac σου και εναλλάσσεται μαζί της στο ηλιοβασίλεμα αν το έχεις ενεργό. (Οι σελίδες αποδίδονται με την εμφάνιση που επιλέγει ο ίδιος ο ιστότοπος.)"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Define la interfaz propia del navegador: barra de herramientas, pestañas, menús. Sistema sigue la apariencia de tu Mac y cambia con ella al atardecer si tienes esa opción activada. (Las páginas se muestran con la apariencia que elija el propio sitio.)"
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Define la interfaz propia del navegador: barra de herramientas, pestañas, menús. Sistema sigue la apariencia de tu Mac y cambia con ella al atardecer si tienes esa opción activada. (Las páginas se muestran con la apariencia que elija el propio sitio.)"
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Määrittää selaimen oman käyttöliittymän — työkalupalkin, välilehdet, valikot. Järjestelmä seuraa Macisi ulkoasua ja vaihtuu sen mukana auringonlaskun aikaan, jos se on käytössä. (Sivut näkyvät siinä ulkoasussa, jonka sivusto itse valitsee.)"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Définit l'interface propre du navigateur — barre d'outils, onglets, menus. Système suit l'apparence de votre Mac et change avec elle au coucher du soleil si vous avez activé cette option. (Les pages s'affichent dans l'apparence que le site lui-même choisit.)"
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Définit l'interface propre du navigateur — barre d'outils, onglets, menus. Système suit l'apparence de votre Mac et change avec elle au coucher du soleil si vous avez activé cette option. (Les pages s'affichent dans l'apparence que le site lui-même choisit.)"
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "מגדיר את ממשק הדפדפן עצמו — סרגל הכלים, הכרטיסיות, התפריטים. המערכת עוקבת אחר המראה של ה-Mac שלך ומתחלפת איתו בשקיעה אם הפעלת זאת. (דפים מוצגים במראה שהאתר עצמו בוחר.)"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ब्राउज़र के अपने इंटरफ़ेस को सेट करता है — टूलबार, टैब, मेन्यू। सिस्टम आपके Mac के स्वरूप का अनुसरण करता है और यदि आपने वह चालू किया है तो सूर्यास्त पर उसके साथ बदलता है। (पृष्ठ उसी स्वरूप में प्रस्तुत होते हैं जिसे साइट स्वयं चुनती है।)"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Postavlja vlastito sučelje preglednika — alatnu traku, kartice, izbornike. Sustav prati izgled tvog Maca i mijenja se s njim pri zalasku sunca ako to imaš uključeno. (Stranice se prikazuju u izgledu koji sam web bira.)"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beállítja a böngésző saját felületét — eszköztár, lapok, menük. A Rendszer követi a Mac megjelenését, és napnyugtakor vele együtt vált, ha ez be van kapcsolva. (Az oldalak abban a megjelenésben jelennek meg, amelyet maga a webhely választ.)"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menyetel antarmuka browser itu sendiri — bilah alat, tab, menu. Sistem mengikuti tampilan Mac-mu dan beralih dengannya saat matahari terbenam jika kamu mengaktifkannya. (Halaman ditampilkan dalam tampilan yang dipilih situs itu sendiri.)"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imposta l'interfaccia propria del browser: barra degli strumenti, schede, menu. Sistema segue l'aspetto del tuo Mac e cambia con esso al tramonto, se hai attivato quell'opzione. (Le pagine vengono visualizzate con l'aspetto scelto dal sito stesso.)"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ブラウザ自身のUI（ツールバー、タブ、メニュー）を設定します。「システム」はMacの外観に従い、有効にしていれば日没時に一緒に切り替わります。（ページはサイト自身が選ぶ外観で表示されます。）"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "브라우저 자체 UI(도구 막대, 탭, 메뉴)를 설정합니다. 시스템은 Mac의 모양을 따르며, 해당 옵션을 켜두면 일몰 시 함께 전환됩니다. (페이지는 사이트 자체가 선택한 모양으로 표시됩니다.)"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menetapkan antara muka pelayar sendiri — bar alat, tab, menu. Sistem mengikut rupa Mac anda dan bertukar dengannya pada waktu matahari terbenam jika anda menghidupkannya. (Halaman dipaparkan dalam rupa yang dipilih oleh tapak itu sendiri.)"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Angir nettleserens eget grensesnitt — verktøylinje, faner, menyer. System følger utseendet til Macen din og bytter med det ved solnedgang hvis du har det på. (Sider vises i det utseendet nettstedet selv velger.)"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stelt de eigen interface van de browser in — werkbalk, tabbladen, menu's. Systeem volgt de weergave van je Mac en schakelt bij zonsondergang mee als je dat aanhebt. (Pagina's worden weergegeven in de weergave die de site zelf kiest.)"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ustawia własny interfejs przeglądarki — pasek narzędzi, karty, menu. System podąża za wyglądem Twojego Maca i przełącza się wraz z nim o zachodzie słońca, jeśli masz to włączone. (Strony są wyświetlane w wyglądzie, który wybiera sama witryna.)"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Define a interface do próprio navegador — barra de ferramentas, abas, menus. Sistema segue a aparência do seu Mac e muda com ela ao pôr do sol, se você tiver isso ativado. (As páginas são exibidas na aparência que o próprio site escolher.)"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Define a interface do próprio navegador — barra de ferramentas, abas, menus. Sistema segue a aparência do seu Mac e muda com ela ao pôr do sol, se você tiver isso ativado. (As páginas são exibidas na aparência que o próprio site escolher.)"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setează interfața proprie a browserului — bara de instrumente, filele, meniurile. Sistem urmează aspectul Mac-ului tău și comută cu el la apus dacă ai activat asta. (Paginile sunt redate în aspectul pe care îl alege site-ul însuși.)"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Задаёт собственный интерфейс браузера — панель инструментов, вкладки, меню. «Система» следует за оформлением вашего Mac и переключается вместе с ним на закате, если это включено. (Страницы отображаются в том оформлении, которое выбирает сам сайт.)"
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nastavuje vlastné rozhranie prehliadača — panel nástrojov, karty, ponuky. Systém sa riadi vzhľadom tvojho Macu a prepína sa s ním pri západe slnka, ak to máš zapnuté. (Stránky sa zobrazujú vo vzhľade, ktorý si vyberie sám web.)"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ställer in webbläsarens eget gränssnitt — verktygsfält, flikar, menyer. System följer din Macs utseende och växlar med det vid solnedgången om du har det på. (Sidor visas i det utseende som webbplatsen själv väljer.)"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ตั้งค่าอินเทอร์เฟซของเบราว์เซอร์เอง — แถบเครื่องมือ แท็บ เมนู ระบบจะตามรูปลักษณ์ของ Mac ของคุณและสลับตามในเวลาพระอาทิตย์ตกหากคุณเปิดใช้ (หน้าจะแสดงผลในรูปลักษณ์ที่ไซต์เลือกเอง)"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tarayıcının kendi arayüzünü ayarlar — araç çubuğu, sekmeler, menüler. Sistem, Mac'inin görünümünü izler ve bunu açtıysan gün batımında onunla birlikte değişir. (Sayfalar, sitenin kendi seçtiği görünümde işlenir.)"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Задає власний інтерфейс браузера — панель інструментів, вкладки, меню. «Система» слідує за оформленням вашого Mac і перемикається разом із ним на заході сонця, якщо це ввімкнено. (Сторінки відображаються в тому оформленні, яке обирає сам сайт.)"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Đặt giao diện riêng của trình duyệt — thanh công cụ, thẻ, menu. Hệ thống theo giao diện của Mac và chuyển theo nó lúc hoàng hôn nếu bạn bật tính năng đó. (Các trang được hiển thị theo giao diện mà chính trang web chọn.)"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "设置浏览器自身的界面——工具栏、标签页、菜单。“系统”会跟随你 Mac 的外观，若你已开启，则会在日落时随之切换。（页面会以网站自身选择的外观呈现。）"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定瀏覽器自身的介面——工具列、分頁、選單。「系統」會跟隨你 Mac 的外觀，若你已開啟，則會在日落時隨之切換。（頁面會以網站自身選擇的外觀呈現。）"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "設定瀏覽器自身的介面——工具列、分頁、選單。「系統」會跟隨你 Mac 的外觀，若你已開啟，則會在日落時隨之切換。（頁面會以網站自身選擇的外觀呈現。）"
          }
        }
      }
    },
