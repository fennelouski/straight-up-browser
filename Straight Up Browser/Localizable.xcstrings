    "System follows your Mac's appearance — and switches with it.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتبع النظام مظهر الـ Mac لديك — ويتبدّل معه."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistema segueix l'aspecte del teu Mac — i canvia amb ell."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Systém se řídí vzhledem tvého Macu — a přepíná se s ním."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "System følger din Macs udseende — og skifter med det."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "System folgt dem Erscheinungsbild deines Mac – und wechselt mit ihm."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Σύστημα ακολουθεί την εμφάνιση του Mac σου — και εναλλάσσεται μαζί της."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistema sigue la apariencia de tu Mac y cambia con ella."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistema sigue la apariencia de tu Mac y cambia con ella."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Järjestelmä seuraa Macisi ulkoasua — ja vaihtuu sen mukana."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Système suit l'apparence de votre Mac — et change avec elle."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Système suit l'apparence de votre Mac — et change avec elle."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "המערכת עוקבת אחר המראה של ה-Mac שלך — ומתחלפת איתו."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सिस्टम आपके Mac के स्वरूप का अनुसरण करता है — और उसके साथ बदलता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sustav prati izgled tvog Maca — i mijenja se s njim."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Rendszer követi a Mac megjelenését — és vele együtt vált."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem mengikuti tampilan Mac-mu — dan beralih dengannya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistema segue l'aspetto del tuo Mac e cambia con esso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「システム」はMacの外観に従い、一緒に切り替わります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "시스템은 Mac의 모양을 따르며 함께 전환됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem mengikut rupa Mac anda — dan bertukar dengannya."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "System følger utseendet til Macen din — og bytter med det."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Systeem volgt de weergave van je Mac — en schakelt mee."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "System podąża za wyglądem Twojego Maca — i przełącza się wraz z nim."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistema segue a aparência do seu Mac — e muda com ela."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistema segue a aparência do seu Mac — e muda com ela."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem urmează aspectul Mac-ului tău — și comută cu el."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«Система» следует за оформлением вашего Mac — и переключается вместе с ним."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Systém sa riadi vzhľadom tvojho Macu — a prepína sa s ním."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "System följer din Macs utseende — och växlar med det."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ระบบตามรูปลักษณ์ของ Mac ของคุณ — และสลับตามมัน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sistem, Mac'inin görünümünü izler — ve onunla birlikte değişir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "«Система» слідує за оформленням вашого Mac — і перемикається разом із ним."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hệ thống theo giao diện của Mac — và chuyển theo nó."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "「系統」會跟隨你 Mac 的外觀——並隨之切換。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“系统”会跟随你 Mac 的外观——并随之切换。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「系統」會跟隨你 Mac 的外觀——並隨之切換。"
          }
        }
      }
    },
