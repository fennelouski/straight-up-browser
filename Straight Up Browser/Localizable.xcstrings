    "The certificate for %@ could not be verified.\n\nTrust Result: %@\n\nThis may indicate a security risk. Do you want to proceed anyway?": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذّر التحقق من شهادة %@.\n\nنتيجة الثقة: %@\n\nقد يشير هذا إلى خطر أمني. هل تريد المتابعة على أي حال؟"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "No s'ha pogut verificar el certificat de %@.\n\nResultat de confiança: %@\n\nAixò pot indicar un risc de seguretat. Vols continuar igualment?"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Certifikát pro %@ nebylo možné ověřit.\n\nVýsledek důvěryhodnosti: %@\n\nToto může znamenat bezpečnostní riziko. Chceš přesto pokračovat?"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Certifikatet for %@ kunne ikke verificeres.\n\nTillidsresultat: %@\n\nDette kan indikere en sikkerhedsrisiko. Vil du fortsætte alligevel?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Zertifikat für %@ konnte nicht überprüft werden.\n\nVertrauensergebnis: %@\n\nDies kann auf ein Sicherheitsrisiko hinweisen. Möchtest du trotzdem fortfahren?"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν ήταν δυνατή η επαλήθευση του πιστοποιητικού για %@.\n\nΑποτέλεσμα εμπιστοσύνης: %@\n\nΑυτό μπορεί να υποδηλώνει κίνδυνο ασφαλείας. Θέλεις να συνεχίσεις ούτως ή άλλως;"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "The certificate for %1$@ could not be verified.\n\nTrust Result: %2$@\n\nThis may indicate a security risk. Do you want to proceed anyway?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo verificar el certificado de %@.\n\nResultado de confianza: %@\n\nEsto puede indicar un riesgo de seguridad. ¿Quieres continuar de todos modos?"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo verificar el certificado de %@.\n\nResultado de confianza: %@\n\nEsto puede indicar un riesgo de seguridad. ¿Quieres continuar de todos modos?"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kohteen %@ varmennetta ei voitu vahvistaa.\n\nLuottamustulos: %@\n\nTämä voi olla merkki tietoturvariskistä. Haluatko jatkaa silti?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le certificat pour %@ n'a pas pu être vérifié.\n\nRésultat de confiance : %@\n\nCeci peut indiquer un risque de sécurité. Voulez-vous continuer malgré tout ?"
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Le certificat pour %@ n'a pas pu être vérifié.\n\nRésultat de confiance : %@\n\nCeci peut indiquer un risque de sécurité. Voulez-vous continuer malgré tout ?"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לא ניתן היה לאמת את התעודה עבור %@.\n\nתוצאת אמון: %@\n\nזה עשוי להצביע על סיכון אבטחה. האם ברצונך להמשיך בכל זאת?"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ के लिए प्रमाणपत्र सत्यापित नहीं किया जा सका।\n\nविश्वास परिणाम: %@\n\nयह एक सुरक्षा जोखिम का संकेत हो सकता है। क्या आप फिर भी आगे बढ़ना चाहते हैं?"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Certifikat za %@ nije bilo moguće provjeriti.\n\nRezultat povjerenja: %@\n\nOvo može ukazivati na sigurnosni rizik. Želiš li ipak nastaviti?"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A(z) %@ tanúsítványát nem sikerült ellenőrizni.\n\nMegbízhatósági eredmény: %@\n\nEz biztonsági kockázatra utalhat. Mégis folytatod?"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Sertifikat untuk %@ tidak dapat diverifikasi.\n\nHasil Kepercayaan: %@\n\nIni dapat menunjukkan risiko keamanan. Apakah kamu ingin tetap melanjutkan?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile verificare il certificato per %@.\n\nEsito attendibilità: %@\n\nQuesto potrebbe indicare un rischio per la sicurezza. Vuoi procedere comunque?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@の証明書を検証できませんでした。\n\n信頼結果：%@\n\nこれはセキュリティ上のリスクを示している可能性があります。それでも続けますか？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@의 인증서를 확인할 수 없습니다.\n\n신뢰 결과: %@\n\n이는 보안 위험을 나타낼 수 있습니다. 그래도 계속하시겠습니까?"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Sijil untuk %@ tidak dapat disahkan.\n\nKeputusan Kepercayaan: %@\n\nIni mungkin menunjukkan risiko keselamatan. Adakah anda mahu teruskan juga?"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sertifikatet for %@ kunne ikke verifiseres.\n\nTillitsresultat: %@\n\nDette kan tyde på en sikkerhetsrisiko. Vil du fortsette likevel?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het certificaat voor %@ kon niet worden geverifieerd.\n\nVertrouwensresultaat: %@\n\nDit kan wijzen op een beveiligingsrisico. Wil je toch doorgaan?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się zweryfikować certyfikatu dla %@.\n\nWynik zaufania: %@\n\nMoże to wskazywać na zagrożenie bezpieczeństwa. Czy chcesz kontynuować mimo to?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível verificar o certificado de %@.\n\nResultado de confiança: %@\n\nIsso pode indicar um risco de segurança. Deseja prosseguir mesmo assim?"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível verificar o certificado de %@.\n\nResultado de confiança: %@\n\nIsso pode indicar um risco de segurança. Deseja prosseguir mesmo assim?"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Certificatul pentru %@ nu a putut fi verificat.\n\nRezultatul încrederii: %@\n\nAcest lucru poate indica un risc de securitate. Vrei să continui oricum?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось проверить сертификат для %@.\n\nРезультат доверия: %@\n\nЭто может указывать на угрозу безопасности. Хотите всё равно продолжить?"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Certifikát pre %@ sa nepodarilo overiť.\n\nVýsledok dôveryhodnosti: %@\n\nToto môže znamenať bezpečnostné riziko. Chceš napriek tomu pokračovať?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Certifikatet för %@ kunde inte verifieras.\n\nTillitsresultat: %@\n\nDetta kan tyda på en säkerhetsrisk. Vill du fortsätta ändå?"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่สามารถยืนยันใบรับรองสำหรับ %@\n\nผลความน่าเชื่อถือ: %@\n\nสิ่งนี้อาจบ่งชี้ถึงความเสี่ยงด้านความปลอดภัย คุณต้องการดำเนินการต่ออยู่ดีหรือไม่?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ için sertifika doğrulanamadı.\n\nGüven Sonucu: %@\n\nBu bir güvenlik riskine işaret edebilir. Yine de devam etmek istiyor musun?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Не вдалося перевірити сертифікат для %@.\n\nРезультат довіри: %@\n\nЦе може вказувати на загрозу безпеці. Хочете все одно продовжити?"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không thể xác minh chứng chỉ cho %@.\n\nKết quả tin cậy: %@\n\nĐiều này có thể cho thấy một rủi ro bảo mật. Bạn có muốn vẫn tiếp tục không?"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "無法驗證 %@ 的憑證。\n\n信任結果：%@\n\n這可能表示存在安全風險。你想仍要繼續嗎？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法验证 %@ 的证书。\n\n信任结果：%@\n\n这可能表示存在安全风险。你想仍然继续吗？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法驗證 %@ 的憑證。\n\n信任結果：%@\n\n這可能表示存在安全風險。你想仍要繼續嗎？"
          }
        }
      }
    },
