          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Világos, Sötét vagy a Mac szerint."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terang, Gelap, atau ikuti Mac-mu."
          }
        },
