    "Which corner or edge the ⌘F bar docks to." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الزاوية أو الحافة التي يرسو عندها شريط ⌘F."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A quin cantó o vora s'acobla la barra de ⌘F."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ke kterému rohu nebo okraji se lišta ⌘F přichytí."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvilket hjørne eller hvilken kant ⌘F-linjen sætter sig i."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An welcher Ecke oder Kante die ⌘F-Leiste andockt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Σε ποια γωνία ή άκρη προσδένεται η γραμμή ⌘F."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En qué esquina o borde se acopla la barra de ⌘F."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En qué esquina o borde se acopla la barra de ⌘F."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mihin kulmaan tai reunaan ⌘F-palkki kiinnittyy."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le coin ou le bord où la barre ⌘F vient se placer."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le coin ou le bord où la barre ⌘F vient se placer."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לאיזו פינה או קצה נצמד סרגל ⌘F."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘F बार किस कोने या किनारे पर टिकेगा।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uz koji se kut ili rub traka ⌘F pripija."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melyik sarokhoz vagy szélhez dokkol a ⌘F sáv."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sudut atau tepi tempat bilah ⌘F menempel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'angolo o il bordo a cui si aggancia la barra ⌘F."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘F バーを固定する角または辺。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘F 막대가 붙는 모서리 또는 가장자리입니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sudut atau tepi tempat bar ⌘F berlabuh."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvilket hjørne eller hvilken kant ⌘F-feltet legger seg i."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aan welke hoek of rand de ⌘F-balk vastklikt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do którego rogu lub brzegu przylega pasek ⌘F."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Em qual canto ou borda a barra do ⌘F fica encaixada."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Em qual canto ou borda a barra do ⌘F fica encaixada."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "În ce colț sau pe ce margine se fixează bara ⌘F."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В каком углу или у какого края закрепляется панель ⌘F."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ku ktorému rohu alebo okraju sa lišta ⌘F pripne."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vilket hörn eller vilken kant ⌘F-fältet dockar till."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "มุมหรือขอบที่แถบ ⌘F จะไปเกาะอยู่"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘F çubuğunun hangi köşeye ya da kenara yerleşeceği."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "У якому куті чи біля якого краю закріплюється панель ⌘F."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Góc hoặc cạnh mà thanh ⌘F neo vào."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘F 查找栏停靠的边角或边缘。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘F 尋找列停靠的邊角或邊緣。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘F 尋找列停靠的邊角或邊緣。"
          }
        }
      }
    },
    "The find bar floats over the page, so it can cover whatever you were reading. Move it to the corner or edge that's out of your way — bottom placements suit long articles, side placements suit wide monitors." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يطفو شريط البحث فوق الصفحة، لذا قد يغطي تحديدًا ما كنت تقرأه. انقله إلى الزاوية أو الحافة التي لا تعترض طريقك؛ الأسفل يناسب المقالات الطويلة، والجانبان يناسبان الشاشات العريضة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La barra de cerca flota sobre la pàgina, així que pot tapar justament allò que estaves llegint. Mou-la al cantó o a la vora que no et faci nosa: a baix va bé amb articles llargs i als laterals amb pantalles amples."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lišta hledání se vznáší nad stránkou, takže může zakrýt právě to, co jste četli. Přesuňte ji do rohu nebo k okraji, kde vám nepřekáží: dole se hodí k dlouhým článkům, po stranách k širokým monitorům."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Søgelinjen svæver over siden og kan derfor dække netop det, du var i gang med at læse. Flyt den hen i det hjørne eller til den kant, hvor den ikke er i vejen – nederst passer til lange artikler, siderne passer til brede skærme."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Suchleiste schwebt über der Seite und kann daher genau das verdecken, was du gerade liest. Verschiebe sie an die Ecke oder Kante, die dir nicht im Weg ist – unten passt gut zu langen Artikeln, seitlich zu breiten Bildschirmen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η γραμμή εύρεσης αιωρείται πάνω από τη σελίδα, οπότε μπορεί να καλύψει ακριβώς αυτό που διάβαζες. Μετακίνησέ την στη γωνία ή στην άκρη που δεν σε ενοχλεί: κάτω ταιριάζει σε μεγάλα άρθρα, στα πλάγια σε πλατιές οθόνες."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La barra de búsqueda flota sobre la página, así que puede tapar justo lo que estabas leyendo. Muévela a la esquina o al borde que no te estorbe: abajo va bien con artículos largos y los laterales con pantallas anchas."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La barra de búsqueda flota sobre la página, así que puede tapar justo lo que estabas leyendo. Muévela a la esquina o al borde que no te estorbe: abajo va bien con artículos largos y los laterales con pantallas anchas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hakupalkki kelluu sivun päällä, joten se voi peittää juuri sen, mitä olit lukemassa. Siirrä se kulmaan tai reunaan, jossa se ei ole tiellä – alareuna sopii pitkiin artikkeleihin, sivureunat leveisiin näyttöihin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La barre de recherche flotte au-dessus de la page et peut donc masquer précisément ce que vous étiez en train de lire. Déplacez-la vers le coin ou le bord qui ne vous gêne pas : en bas pour les longs articles, sur le côté pour les écrans larges."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La barre de recherche flotte au-dessus de la page et peut donc masquer précisément ce que vous étiez en train de lire. Déplacez-la vers le coin ou le bord qui ne vous gêne pas : en bas pour les longs articles, sur le côté pour les écrans larges."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "סרגל החיפוש מרחף מעל הדף, ולכן עלול להסתיר בדיוק את מה שקראת. העבר אותו לפינה או לקצה שלא מפריעים לך – למטה מתאים לכתבות ארוכות, והצדדים למסכים רחבים."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "खोज बार पृष्ठ के ऊपर तैरता है, इसलिए वह ठीक वही हिस्सा ढक सकता है जिसे आप पढ़ रहे थे। इसे उस कोने या किनारे पर ले जाएँ जहाँ यह रास्ते में न आए — नीचे की जगह लंबे लेखों के लिए अच्छी है, किनारे चौड़ी स्क्रीन के लिए।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Traka za pretraživanje lebdi iznad stranice pa može prekriti upravo ono što ste čitali. Premjestite je u kut ili uz rub gdje vam ne smeta: dolje odgovara dugim člancima, bočno širokim monitorima."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A keresősáv az oldal fölött lebeg, így pont azt takarhatja el, amit olvastál. Tedd abba a sarokba vagy ahhoz a szélhez, ahol nincs útban: alul a hosszú cikkekhez, oldalt a széles monitorokhoz való."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bilah pencarian melayang di atas halaman, jadi bisa menutupi persis bagian yang sedang Anda baca. Pindahkan ke sudut atau tepi yang tidak mengganggu: di bawah cocok untuk artikel panjang, di sisi cocok untuk monitor lebar."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La barra di ricerca fluttua sopra la pagina, quindi può coprire proprio ciò che stavi leggendo. Spostala nell'angolo o sul bordo che non ti intralcia: in basso è comodo per gli articoli lunghi, ai lati per i monitor larghi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "検索バーはページの上に浮かぶため、ちょうど読んでいた箇所を隠してしまうことがあります。邪魔にならない角や辺に移動してください。下寄せは長い記事に、左右寄せは横長のディスプレイに向いています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "찾기 막대는 페이지 위에 떠 있어서 읽고 있던 부분을 가릴 수 있습니다. 방해되지 않는 모서리나 가장자리로 옮기세요. 아래쪽은 긴 글에, 좌우는 넓은 모니터에 어울립니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bar carian terapung di atas halaman, jadi ia boleh menutup bahagian yang sedang anda baca. Alihkannya ke sudut atau tepi yang tidak menghalang: di bawah sesuai untuk artikel panjang, di tepi sesuai untuk monitor lebar."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Søkefeltet svever over siden og kan derfor dekke akkurat det du leste. Flytt det til hjørnet eller kanten som ikke er i veien – nederst passer til lange artikler, sidene passer til brede skjermer."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De zoekbalk zweeft boven de pagina en kan dus net bedekken wat je aan het lezen was. Verplaats hem naar de hoek of rand die je niet in de weg zit – onderaan werkt goed bij lange artikelen, aan de zijkant bij brede schermen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pasek wyszukiwania unosi się nad stroną, więc może zasłonić dokładnie to, co czytasz. Przenieś go w róg lub do krawędzi, gdzie nie przeszkadza: dół sprawdza się przy długich artykułach, boki przy szerokich monitorach."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A barra de busca flutua sobre a página, então pode cobrir justamente o que você estava lendo. Mova-a para o canto ou a borda que não atrapalha: embaixo combina com artigos longos, nas laterais com monitores largos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A barra de busca flutua sobre a página, então pode cobrir justamente o que você estava lendo. Mova-a para o canto ou a borda que não atrapalha: embaixo combina com artigos longos, nas laterais com monitores largos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bara de căutare plutește peste pagină, așa că poate acoperi exact ce citeai. Mut-o în colțul sau pe marginea care nu îți stă în cale: jos merge bine la articolele lungi, lateralele la monitoarele late."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Панель поиска парит над страницей и потому может закрыть именно то, что вы читали. Переместите её в угол или к краю, где она не мешает: снизу удобно для длинных статей, по бокам — для широких мониторов."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lišta hľadania sa vznáša nad stránkou, takže môže zakryť práve to, čo ste čítali. Presuňte ju do rohu alebo k okraju, kde vám neprekáža: dole sa hodí k dlhým článkom, po stranách k širokým monitorom."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sökfältet svävar över sidan och kan därför täcka just det du läste. Flytta det till hörnet eller kanten som inte är i vägen – längst ner passar långa artiklar, sidorna passar breda skärmar."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "แถบค้นหาลอยอยู่เหนือหน้าเว็บ จึงอาจบังสิ่งที่คุณกำลังอ่านอยู่พอดี ย้ายไปยังมุมหรือขอบที่ไม่เกะกะ ด้านล่างเหมาะกับบทความยาว ส่วนด้านข้างเหมาะกับจอกว้าง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bulma çubuğu sayfanın üzerinde yüzer, dolayısıyla tam da okuduğunuz yeri kapatabilir. Yolunuza çıkmayan köşeye veya kenara taşıyın: alt taraf uzun yazılara, yanlar geniş ekranlara yakışır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Панель пошуку ширяє над сторінкою, тож може затулити саме те, що ви читали. Перемістіть її в куток або до краю, де вона не заважає: знизу зручно для довгих статей, з боків — для широких моніторів."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thanh tìm kiếm nổi trên trang nên có thể che đúng phần bạn đang đọc. Hãy chuyển nó tới góc hoặc cạnh không vướng víu: đặt ở dưới hợp với bài viết dài, đặt hai bên hợp với màn hình rộng."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "查找栏浮在页面上方，可能正好挡住你在读的内容。把它移到不碍事的边角或边缘：底部适合长文章，两侧适合宽屏显示器。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "尋找列浮在頁面上方，可能正好擋住你正在讀的內容。把它移到不礙事的邊角或邊緣：底部適合長文章，兩側適合寬螢幕。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "尋找列浮在頁面上方，可能正好擋住你正在讀的內容。把它移到不礙事的邊角或邊緣：底部適合長文章，兩側適合寬螢幕。"
          }
        }
      }
    },
