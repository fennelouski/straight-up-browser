    "Adopt another browser's keyboard shortcut scheme on this device. See ⇧⌘H for the full list." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اعتمِد نظام اختصارات لوحة المفاتيح لمتصفح آخر على هذا الجهاز. اضغط ⇧⌘H للقائمة الكاملة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adopta l’esquema de dreceres de teclat d’un altre navegador en aquest dispositiu. Prem ⇧⌘H per veure la llista completa."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Převezměte na tomto zařízení schéma klávesových zkratek jiného prohlížeče. Úplný seznam zobrazíte pomocí ⇧⌘H."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Overtag et andet browsers tastaturgenveje på denne enhed. Tryk på ⇧⌘H for hele listen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übernimm auf diesem Gerät das Kurzbefehlschema eines anderen Browsers. Die vollständige Liste zeigt ⇧⌘H."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Υιοθετήστε το σχήμα συντομεύσεων άλλου προγράμματος περιήγησης σε αυτήν τη συσκευή. Δείτε ⇧⌘H για την πλήρη λίστα."
