    "Opens the omnibar from any app, even when Browser isn't focused.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يفتح شريط العناوين من أي تطبيق، حتى عندما لا يكون المتصفح في وضع التركيز."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Obre l'omnibar des de qualsevol app, fins i tot quan el navegador no té el focus."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Otevře omnibar z libovolné aplikace, i když prohlížeč není v popředí."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Åbner omnibaren fra enhver app, selv når browseren ikke er i fokus."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Öffnet die Omnibar aus jeder App, auch wenn der Browser nicht im Fokus ist."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ανοίγει το omnibar από οποιαδήποτε εφαρμογή, ακόμη κι όταν το πρόγραμμα περιήγησης δεν είναι εστιασμένο."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre la omnibar desde cualquier app, incluso cuando el navegador no está enfocado."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre la omnibar desde cualquier app, incluso cuando el navegador no está enfocado."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Avaa omnipalkin mistä tahansa sovelluksesta, vaikka selain ei olisi kohdistettuna."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvre l'omnibar depuis n'importe quelle app, même lorsque le navigateur n'est pas actif."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvre l'omnibar depuis n'importe quelle app, même lorsque le navigateur n'est pas actif."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "פותח את שורת הכתובת מכל יישום, גם כשהדפדפן אינו במיקוד."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी भी ऐप से ओमनीबार खोलता है, भले ही ब्राउज़र फ़ोकस में न हो।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Otvara omnibar iz bilo koje aplikacije, čak i kad preglednik nije u fokusu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Megnyitja az omnibart bármely alkalmazásból, még akkor is, ha a böngésző nincs fókuszban."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Membuka omnibar dari aplikasi mana pun, bahkan saat browser tidak difokuskan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apre l'omnibar da qualsiasi app, anche quando il browser non è a fuoco."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブラウザがフォーカスされていなくても、任意のアプリからオムニバーを開きます。"
          }
        },
        "ko": {
          "stringUnit": {
