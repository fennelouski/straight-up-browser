          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Système suit l'apparence de votre Mac — et change avec elle."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "המערכת עוקבת אחר המראה של ה-Mac שלך — ומתחלפת איתו."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सिस्टम आपके Mac के स्वरूप का अनुसरण करता है — और उसके साथ बदलता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
