    "Release idle background tabs from RAM when your Mac runs low.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حرِّر علامات تبويب الخلفية الخاملة من ذاكرة الوصول العشوائي عندما تنخفض ذاكرة الـ Mac لديك."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Allibera les pestanyes inactives en segon pla de la RAM quan el teu Mac es queda sense memòria."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Uvolni nečinné karty na pozadí z RAM, když tvému Macu dochází paměť."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Frigiv inaktive baggrundsfaneblade fra RAM, når din Mac er ved at løbe tør."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Inaktive Hintergrund-Tabs aus dem RAM freigeben, wenn dein Mac knapp wird."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Απελευθέρωσε αδρανείς καρτέλες παρασκηνίου από τη RAM όταν το Mac σου μένει από μνήμη."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Liberar de la RAM las pestañas inactivas en segundo plano cuando tu Mac se quede sin memoria."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Liberar de la RAM las pestañas inactivas en segundo plano cuando tu Mac se quede sin memoria."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vapauta joutilaat taustavälilehdet RAM-muistista, kun Macisi muisti käy vähiin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Libérer les onglets inactifs en arrière-plan de la RAM lorsque votre Mac manque de mémoire."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Libérer les onglets inactifs en arrière-plan de la RAM lorsque votre Mac manque de mémoire."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שחרר כרטיסיות רקע לא פעילות מ-RAM כאשר ה-Mac שלך אוזל מזיכרון."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आपके Mac की मेमोरी कम हो जाए तो निष्क्रिय बैकग्राउंड टैब को RAM से जारी करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Oslobodi neaktivne pozadinske kartice iz RAM-a kada tvom Macu ponestaje memorije."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Inaktív háttérlapok felszabadítása a RAM-ból, amikor a Mac memóriája kevés."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lepaskan tab latar menganggur dari RAM saat Mac-mu kehabisan memori."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rilascia dalla RAM le schede inattive in background quando il tuo Mac ha poca memoria."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Macのメモリが少なくなったら、アイドル状態のバックグラウンドタブをRAMから解放します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac의 메모리가 부족할 때 유휴 백그라운드 탭을 RAM에서 해제합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Lepaskan tab latar melahu daripada RAM apabila Mac anda kehabisan memori."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Frigi inaktive bakgrunnsfaner fra RAM når Macen din begynner å gå tom."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Inactieve achtergrondtabbladen uit RAM vrijgeven wanneer je Mac weinig geheugen heeft."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zwalniaj nieaktywne karty w tle z RAM, gdy w Twoim Macu kończy się pamięć."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
