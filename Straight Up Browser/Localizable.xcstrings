    "A full-page capture stays vector — the text is still selectable. Other captures become a one-page PDF of the image." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لقطة الصفحة الكاملة تبقى متجهية — ولا يزال بالإمكان تحديد النص. أما اللقطات الأخرى فتصير ملف PDF من صفحة واحدة يحتوي الصورة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una captura de pàgina sencera es manté vectorial: el text encara es pot seleccionar. Les altres captures esdevenen un PDF d'una pàgina amb la imatge."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snímek celé stránky zůstane vektorový – text jde stále vybrat. Ostatní snímky se stanou jednostránkovým PDF s obrázkem."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Et billede af hele siden forbliver vektorbaseret – teksten kan stadig markeres. Andre billeder bliver til en PDF på én side med billedet."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Ganzseitenaufnahme bleibt vektorbasiert – der Text ist weiterhin auswählbar. Andere Aufnahmen werden zu einem einseitigen PDF des Bildes."
          }
        },
        "el" : {
          "stringUnit" : {
