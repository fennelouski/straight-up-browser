        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ओमनीबार में URL के बजाय शब्द टाइप करें और वे इस इंजन को सौंप दिए जाते हैं। जो कुछ भी पते जैसा दिखता है वह अब भी सीधे लोड होता है।"
