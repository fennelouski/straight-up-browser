    "The page as it sits on screen — no window chrome, no tab bar." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الصفحة كما هي على الشاشة — دون إطار النافذة ودون شريط علامات التبويب."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La pàgina tal com és a la pantalla, sense marc de finestra ni barra de pestanyes."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stránka tak, jak leží na obrazovce – bez rámu okna, bez lišty karet."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siden, som den ligger på skærmen – ingen vinduesramme, ingen fanebladslinje."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Seite, wie sie auf dem Bildschirm steht – ohne Fensterrahmen, ohne Tableiste."
