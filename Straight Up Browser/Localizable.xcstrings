    "Clearing browsing data removes history, cookies, caches, and local storage for the types you choose. The cookie manager lets you inspect and delete individual cookies." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يؤدي مسح بيانات التصفح إلى إزالة السجل وملفات تعريف الارتباط والذواكر المؤقتة والتخزين المحلي للأنواع التي تختارها. يتيح لك مدير ملفات تعريف الارتباط فحص ملفات تعريف الارتباط الفردية وحذفها."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esborrar les dades de navegació elimina l'historial, les galetes, les memòries cau i l'emmagatzematge local dels tipus que triïs. El gestor de galetes et permet inspeccionar i suprimir galetes individuals."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vymazání dat prohlížení odstraní historii, soubory cookie, mezipaměti a místní úložiště pro typy, které vybereš. Správce souborů cookie ti umožňuje prohlížet a mazat jednotlivé soubory cookie."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rydning af browserdata fjerner historik, cookies, caches og lokalt lager for de typer, du vælger. Cookie-administratoren lader dig inspicere og slette enkelte cookies."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Löschen der Browserdaten entfernt Verlauf, Cookies, Caches und lokalen Speicher für die von dir gewählten Typen. Mit dem Cookie-Manager kannst du einzelne Cookies prüfen und löschen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η εκκαθάριση δεδομένων περιήγησης αφαιρεί ιστορικό, cookie, προσωρινές μνήμες και τοπική αποθήκευση για τους τύπους που επιλέγεις. Ο διαχειριστής cookie σου επιτρέπει να επιθεωρείς και να διαγράφεις μεμονωμένα cookie."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Borrar los datos de navegación elimina el historial, las cookies, las cachés y el almacenamiento local de los tipos que elijas. El gestor de cookies te permite inspeccionar y eliminar cookies individuales."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Borrar los datos de navegación elimina el historial, las cookies, las cachés y el almacenamiento local de los tipos que elijas. El gestor de cookies te permite inspeccionar y eliminar cookies individuales."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selaustietojen tyhjentäminen poistaa historian, evästeet, välimuistit ja paikallisen tallennustilan valitsemiltasi tyypeiltä. Evästeiden hallinta antaa sinun tarkastella ja poistaa yksittäisiä evästeitä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Effacer les données de navigation supprime l'historique, les cookies, les caches et le stockage local pour les types que vous choisissez. Le gestionnaire de cookies vous permet d'inspecter et de supprimer des cookies individuels."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Effacer les données de navigation supprime l'historique, les cookies, les caches et le stockage local pour les types que vous choisissez. Le gestionnaire de cookies vous permet d'inspecter et de supprimer des cookies individuels."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ניקוי נתוני גלישה מסיר היסטוריה, עוגיות, מטמונים ואחסון מקומי עבור הסוגים שתבחר. מנהל העוגיות מאפשר לך לבדוק ולמחוק עוגיות בודדות."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ब्राउज़िंग डेटा साफ़ करने से आपके चुने गए प्रकारों के लिए इतिहास, कुकीज़, कैश और स्थानीय संग्रहण हट जाता है। कुकी प्रबंधक आपको अलग-अलग कुकीज़ का निरीक्षण और हटाने देता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Čišćenje podataka pregledavanja uklanja povijest, kolačiće, predmemorije i lokalnu pohranu za vrste koje odabereš. Upravitelj kolačića omogućuje ti pregledavanje i brisanje pojedinačnih kolačića."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A böngészési adatok törlése eltávolítja az előzményeket, a sütiket, a gyorsítótárakat és a helyi tárolót a kiválasztott típusokhoz. A sütikezelő lehetővé teszi az egyes sütik megtekintését és törlését."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menghapus data penjelajahan menghilangkan riwayat, cookie, cache, dan penyimpanan lokal untuk jenis yang kamu pilih. Pengelola cookie memungkinkanmu memeriksa dan menghapus cookie satu per satu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La cancellazione dei dati di navigazione rimuove cronologia, cookie, cache e archiviazione locale per i tipi che scegli. Il gestore dei cookie ti permette di ispezionare ed eliminare singoli cookie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "閲覧データを消去すると、選択した種類の履歴、Cookie、キャッシュ、ローカルストレージが削除されます。Cookieマネージャで個々のCookieを確認・削除できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "인터넷 사용 기록을 지우면 선택한 유형의 기록, 쿠키, 캐시, 로컬 저장소가 제거됩니다. 쿠키 관리자를 사용하면 개별 쿠키를 검사하고 삭제할 수 있습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mengosongkan data pelayaran mengeluarkan sejarah, kuki, cache dan storan tempatan bagi jenis yang anda pilih. Pengurus kuki membolehkan anda memeriksa dan memadam kuki satu persatu."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tømming av nettleserdata fjerner logg, informasjonskapsler, buffere og lokal lagring for typene du velger. Behandleren for informasjonskapsler lar deg inspisere og slette enkelte informasjonskapsler."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Het wissen van browsegegevens verwijdert geschiedenis, cookies, caches en lokale opslag voor de typen die je kiest. Met de cookiebeheerder kun je afzonderlijke cookies inspecteren en verwijderen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyczyszczenie danych przeglądania usuwa historię, pliki cookie, pamięci podręczne i pamięć lokalną dla wybranych typów. Menedżer plików cookie pozwala sprawdzać i usuwać poszczególne pliki cookie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limpar os dados de navegação remove histórico, cookies, caches e armazenamento local dos tipos que você escolher. O gerenciador de cookies permite inspecionar e excluir cookies individuais."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Limpar os dados de navegação remove histórico, cookies, caches e armazenamento local dos tipos que você escolher. O gerenciador de cookies permite inspecionar e excluir cookies individuais."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ștergerea datelor de navigare elimină istoricul, cookie-urile, cache-urile și stocarea locală pentru tipurile pe care le alegi. Managerul de cookie-uri îți permite să inspectezi și să ștergi cookie-uri individuale."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Очистка данных просмотра удаляет историю, cookie, кэши и локальное хранилище для выбранных типов. Менеджер cookie позволяет просматривать и удалять отдельные cookie."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vymazanie údajov prehliadania odstráni históriu, súbory cookie, vyrovnávacie pamäte a lokálne úložisko pre typy, ktoré vyberieš. Správca súborov cookie ti umožňuje prezerať a mazať jednotlivé súbory cookie."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rensning av webbdata tar bort historik, cookies, cacher och lokal lagring för de typer du väljer. Cookiehanteraren låter dig granska och radera enskilda cookies."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การล้างข้อมูลการเรียกดูจะลบประวัติ คุกกี้ แคช และที่จัดเก็บในเครื่องสำหรับประเภทที่คุณเลือก ตัวจัดการคุกกี้ให้คุณตรวจสอบและลบคุกกี้แต่ละรายการได้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gezinme verilerini temizlemek, seçtiğin türler için geçmişi, çerezleri, önbellekleri ve yerel depolamayı kaldırır. Çerez yöneticisi, tek tek çerezleri incelemene ve silmene olanak tanır."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Очищення даних перегляду видаляє історію, cookie, кеші й локальне сховище для вибраних типів. Менеджер cookie дозволяє переглядати й видаляти окремі cookie."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Xóa dữ liệu duyệt sẽ loại bỏ lịch sử, cookie, bộ nhớ đệm và bộ nhớ cục bộ cho các loại bạn chọn. Trình quản lý cookie cho phép bạn kiểm tra và xóa từng cookie."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清除浏览数据会移除你所选类型的历史记录、Cookie、缓存和本地存储。Cookie 管理器可让你检查和删除单个 Cookie。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清除瀏覽資料會移除你所選類型的紀錄、Cookie、快取與本機儲存空間。Cookie 管理程式可讓你檢查並刪除個別 Cookie。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "清除瀏覽資料會移除你所選類型的紀錄、Cookie、快取與本機儲存空間。Cookie 管理程式可讓你檢查並刪除個別 Cookie。"
          }
        }
      }
    },
