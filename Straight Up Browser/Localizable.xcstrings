    "Off makes pages static. Applies to newly loaded pages." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الإيقاف يجعل الصفحات ثابتة. ينطبق على الصفحات المحمَّلة حديثًا."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desactivat fa que les pàgines siguin estàtiques. S'aplica a les pàgines acabades de carregar."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vypnuto činí stránky statickými. Platí pro nově načtené stránky."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fra gør sider statiske. Gælder for nyligt indlæste sider."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aus macht Seiten statisch. Gilt für neu geladene Seiten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το Ανενεργό κάνει τις σελίδες στατικές. Ισχύει για νεοφορτωμένες σελίδες."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desactivado hace las páginas estáticas. Se aplica a las páginas recién cargadas."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
