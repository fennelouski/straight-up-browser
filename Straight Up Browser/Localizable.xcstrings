    "Type words rather than a URL into the omnibar and they're handed to this engine. Anything that looks like an address still loads directly.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اكتب كلمات بدلًا من عنوان URL في شريط العناوين وتُسلَّم إلى هذا المحرك. أي شيء يبدو كعنوان لا يزال يُحمَّل مباشرة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Escriu paraules en lloc d'un URL a l'omnibar i es lliuren a aquest cercador. Qualsevol cosa que sembli una adreça encara es carrega directament."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Napiš do omnibaru slova místo adresy URL a budou předána tomuto vyhledávači. Cokoli, co vypadá jako adresa, se stále načte přímo."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriv ord i stedet for en URL i omnibaren, og de sendes til denne søgemaskine. Alt, der ligner en adresse, indlæses stadig direkte."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gib Wörter statt einer URL in die Omnibar ein, und sie werden an diese Suchmaschine übergeben. Alles, was wie eine Adresse aussieht, wird trotzdem direkt geladen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πληκτρολόγησε λέξεις αντί για URL στο omnibar και παραδίδονται σε αυτή τη μηχανή. Οτιδήποτε μοιάζει με διεύθυνση εξακολουθεί να φορτώνεται απευθείας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribe palabras en lugar de una URL en la omnibar y se entregan a este motor. Todo lo que parezca una dirección sigue cargándose directamente."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribe palabras en lugar de una URL en la omnibar y se entregan a este motor. Todo lo que parezca una dirección sigue cargándose directamente."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirjoita omnipalkkiin sanoja URL-osoitteen sijaan, niin ne välitetään tälle hakukoneelle. Kaikki osoitteelta näyttävä latautuu silti suoraan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisissez des mots plutôt qu'une URL dans l'omnibar et ils sont transmis à ce moteur. Tout ce qui ressemble à une adresse se charge quand même directement."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisissez des mots plutôt qu'une URL dans l'omnibar et ils sont transmis à ce moteur. Tout ce qui ressemble à une adresse se charge quand même directement."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הקלד מילים במקום כתובת URL בשורת הכתובת והן נמסרות למנוע זה. כל דבר שנראה כמו כתובת עדיין נטען ישירות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ओमनीबार में URL के बजाय शब्द टाइप करें और वे इस इंजन को सौंप दिए जाते हैं। जो कुछ भी पते जैसा दिखता है वह अब भी सीधे लोड होता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Upiši riječi umjesto URL-a u omnibar i one se predaju ovoj tražilici. Sve što izgleda kao adresa i dalje se učitava izravno."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Írj szavakat URL helyett az omnibarba, és azok ehhez a keresőhöz kerülnek. Bármi, ami címnek tűnik, továbbra is közvetlenül betöltődik."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Ketik kata alih-alih URL ke omnibar dan kata itu diserahkan ke mesin ini. Apa pun yang tampak seperti alamat tetap dimuat langsung."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Digita parole invece di un URL nell'omnibar e vengono passate a questo motore. Tutto ciò che sembra un indirizzo si carica comunque direttamente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オムニバーにURLではなく単語を入力すると、このエンジンに渡されます。アドレスのように見えるものは引き続き直接読み込まれます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "옴니바에 URL 대신 단어를 입력하면 이 엔진으로 전달됩니다. 주소처럼 보이는 것은 여전히 직접 로드됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Taip perkataan dan bukan URL ke omnibar dan ia diserahkan kepada enjin ini. Apa sahaja yang kelihatan seperti alamat masih dimuatkan terus."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriv ord i stedet for en URL i omnibaren, så sendes de til denne søkemotoren. Alt som ser ut som en adresse, lastes fortsatt direkte."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Typ woorden in plaats van een URL in de omnibalk en ze worden aan deze zoekmachine doorgegeven. Alles wat op een adres lijkt, laadt nog steeds direct."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wpisz w omnibarze słowa zamiast adresu URL, a zostaną przekazane do tej wyszukiwarki. Wszystko, co wygląda na adres, nadal ładuje się bezpośrednio."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Digite palavras em vez de um URL na omnibar e elas são entregues a este mecanismo. Qualquer coisa que pareça um endereço ainda carrega diretamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Digite palavras em vez de um URL na omnibar e elas são entregues a este mecanismo. Qualquer coisa que pareça um endereço ainda carrega diretamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Tastează cuvinte în loc de un URL în omnibar și sunt predate acestui motor. Orice arată ca o adresă se încarcă totuși direct."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вводите в омнибар слова, а не URL, и они передаются этой поисковой системе. Всё, что выглядит как адрес, по-прежнему загружается напрямую."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Napíš do omnibaru slová namiesto adresy URL a budú odovzdané tomuto vyhľadávaču. Čokoľvek, čo vyzerá ako adresa, sa stále načíta priamo."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriv ord i stället för en URL i omnibaren så skickas de till den här sökmotorn. Allt som ser ut som en adress laddas fortfarande direkt."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "พิมพ์คำแทน URL ลงในออมนิบาร์แล้วคำเหล่านั้นจะถูกส่งไปยังเครื่องมือนี้ สิ่งใดก็ตามที่ดูเหมือนที่อยู่ยังคงโหลดโดยตรง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibar'a URL yerine kelimeler yaz, bunlar bu motora aktarılır. Adres gibi görünen her şey yine de doğrudan yüklenir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вводьте в омнібар слова, а не URL, і вони передаються цій пошуковій системі. Усе, що виглядає як адреса, все одно завантажується напряму."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gõ các từ thay vì một URL vào omnibar và chúng được chuyển cho công cụ này. Bất cứ thứ gì trông giống một địa chỉ vẫn được tải trực tiếp."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "在網址列中輸入詞語而非 URL，它們會被交給此引擎。任何看起來像位址的內容仍會直接載入。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在地址栏中输入词语而非 URL，它们会被交给此引擎。任何看起来像地址的内容仍会直接加载。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在網址列中輸入詞語而非 URL，它們會被交給此引擎。任何看起來像位址的內容仍會直接載入。"
          }
        }
      }
    },
