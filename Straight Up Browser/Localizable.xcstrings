    "Where downloaded files are saved. Empty uses your system Downloads folder." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أين تُحفظ الملفات المنزَّلة. الفارغ يستخدم مجلد التنزيلات في نظامك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On es desen els fitxers baixats. Buit utilitza la carpeta Baixades del teu sistema."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kam se ukládají stažené soubory. Prázdné použije systémovou složku Stažené."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
