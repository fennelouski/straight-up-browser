    "Light, Dark, or follow your Mac.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فاتح أو داكن أو اتباع الـ Mac."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Clar, Fosc o segueix el teu Mac."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Světlý, Tmavý nebo podle tvého Macu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Lys, Mørk eller følg din Mac."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hell, Dunkel oder deinem Mac folgen."
