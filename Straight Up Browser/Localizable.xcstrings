    "You return → it reloads instantly, scroll and history kept": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعود ← تُعاد فورًا، مع الاحتفاظ بالتمرير والسجل"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Tornes → es recarrega a l'instant, desplaçament i historial conservats"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vrátíš se → okamžitě se znovu načte, posunutí a historie zachovány"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du vender tilbage → det genindlæses øjeblikkeligt, rulning og historik bevaret"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kehrst zurück → er lädt sofort neu, Scroll und Verlauf bleiben erhalten"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιστρέφεις → επαναφορτώνεται ακαριαία, κύλιση και ιστορικό διατηρούνται"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelves → se recarga al instante, conservando desplazamiento e historial"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Vuelves → se recarga al instante, conservando desplazamiento e historial"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Palaat → se latautuu heti uudelleen, vieritys ja historia säilytetään"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous revenez → il se recharge instantanément, défilement et historique conservés"
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous revenez → il se recharge instantanément, défilement et historique conservés"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "אתה חוזר ← היא נטענת מחדש באופן מיידי, גלילה והיסטוריה נשמרים"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आप वापस आते हैं → यह तुरंत फिर से लोड होता है, स्क्रॉल और इतिहास बनाए रखे जाते हैं"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vratiš se → trenutno se ponovno učitava, pomicanje i povijest zadržani"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Visszatérsz → azonnal újratöltődik, görgetés és előzmények megmaradnak"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamu kembali → dimuat ulang secara instan, gulir dan riwayat dipertahankan"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Torni → si ricarica all'istante, scorrimento e cronologia mantenuti"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "戻ると → 即座に再読み込みされ、スクロールと履歴は保持されます"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "돌아오면 → 즉시 다시 로드되고 스크롤과 기록이 유지됩니다"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda kembali → ia dimuatkan semula serta-merta, tatal dan sejarah dikekalkan"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kommer tilbake → den lastes inn på nytt umiddelbart, rulling og logg beholdt"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je keert terug → hij laadt direct opnieuw, scrollen en geschiedenis behouden"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wracasz → przeładowuje się natychmiast, przewijanie i historia zachowane"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você volta → recarrega instantaneamente, rolagem e histórico mantidos"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Você volta → recarrega instantaneamente, rolagem e histórico mantidos"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Te întorci → se reîncarcă instantaneu, derulare și istoric păstrate"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы возвращаетесь → она мгновенно перезагружается, прокрутка и история сохранены"
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vrátiš sa → okamžite sa znova načíta, posunutie a história zachované"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du återvänder → den läses om direkt, rullning och historik behålls"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณกลับมา → มันโหลดใหม่ทันที การเลื่อนและประวัติถูกเก็บไว้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Geri dönersin → anında yeniden yüklenir, kaydırma ve geçmiş korunur"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви повертаєтеся → вона миттєво перезавантажується, прокрутка й історія збережені"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn quay lại → nó tải lại ngay lập tức, cuộn và lịch sử được giữ"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "你返回時 → 它立即重新載入，捲動與紀錄都保留"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你返回时 → 它立即重新加载，滚动和历史记录都保留"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你返回時 → 它立即重新載入，捲動與紀錄都保留"
          }
        }
      }
    },
