            "state": "translated",
            "value": "Cetak masih hanya satu tombol saja: ⇧⌘P."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La stampa è comunque a un tasto di distanza: ⇧⌘P."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "印刷はまだキー1つで可能です：⇧⌘P。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인쇄는 여전히 키 하나로 가능합니다: ⇧⌘P."
          }
        },
        "ms": {
          "stringUnit": {
