            "value": "Tipărirea este încă la o tastă distanță: ⇧⌘P."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Печать по-прежнему в одном нажатии клавиши: ⇧⌘P."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
