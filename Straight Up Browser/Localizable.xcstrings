        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Semmi sem szabadul fel, így semmit sem kell újratölteni"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tidak ada yang dilepaskan, jadi tidak ada yang perlu dimuat ulang"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non viene rilasciato nulla, quindi non c'è nulla da ricaricare"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "何も解放されないため、再読み込みは不要です"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "해제되는 것이 없으므로 다시 로드할 필요도 없습니다"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiada apa yang dilepaskan, jadi tiada apa yang perlu dimuat semula"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingenting frigis, så ingenting trenger ny innlasting"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er wordt niets vrijgegeven, dus er hoeft niets opnieuw te worden geladen"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nic nie jest zwalniane, więc nic nie wymaga przeładowania"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nada é liberado, então nada precisa ser recarregado"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nada é liberado, então nada precisa ser recarregado"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nimic nu se eliberează, așa că nimic nu trebuie reîncărcat"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ничего не выгружается, поэтому ничего не нужно перезагружать"
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nič sa neuvoľňuje, takže nie je potrebné nič znova načítať"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inget frigörs, så inget behöver läsas om"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ไม่มีอะไรถูกปล่อย ดังนั้นไม่มีอะไรต้องโหลดใหม่"
