    "An isolated, persistent session with its own cookies and logins — stay signed in under a different account, side by side." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جلسة معزولة ودائمة بملفات تعريف ارتباط وعمليات دخول خاصة بها — ابقَ مسجّلًا بحسابات مختلفة جنبًا إلى جنب."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Una sessió aïllada i persistent, amb galetes i sessions iniciades pròpies: mantén-te identificat amb comptes diferents, un al costat de l'altre."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Izolovaná trvalá relace s vlastními cookies a přihlášeními – zůstaň přihlášený pod různými účty vedle sebe."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En isoleret, vedvarende session med sine egne cookies og logins – vær logget ind på forskellige konti side om side."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine isolierte, dauerhafte Sitzung mit eigenen Cookies und Anmeldungen – bleib nebeneinander unter verschiedenen Accounts angemeldet."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μια απομονωμένη, μόνιμη συνεδρία με δικά της cookies και συνδέσεις — μείνε συνδεδεμένος σε διαφορετικούς λογαριασμούς, δίπλα δίπλα."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
