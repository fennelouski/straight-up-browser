    "System follows your Mac's appearance — and switches with it." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتبع النظام مظهر الـ Mac لديك — ويتبدّل معه."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sistema segueix l'aspecte del teu Mac — i canvia amb ell."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Systém se řídí vzhledem tvého Macu — a přepíná se s ním."
          }
        },
        "da" : {
          "stringUnit" : {
