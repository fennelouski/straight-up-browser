        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "यदि आप सेटिंग्स → सामान्य में «⌘P PDF निर्यात करता है» बंद करते हैं तो ⌘P PDF निर्यात करने के बजाय प्रिंट करता है।"
          }
        },
        "hr": {
          "stringUnit": {
