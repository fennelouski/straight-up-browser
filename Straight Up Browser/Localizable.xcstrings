          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désactivé rend les pages statiques. S'applique aux pages nouvellement chargées."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "כבוי הופך דפים לסטטיים. חל על דפים שנטענו לאחרונה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बंद पृष्ठों को स्थिर बनाता है। हाल ही में लोड किए गए पृष्ठों पर लागू होता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
