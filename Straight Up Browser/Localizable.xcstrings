    "Bookmark the current page with ⌘D and browse your bookmarks with ⇧⌘B. You can import bookmarks from another browser via Bookmarks → Import Bookmarks." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف الصفحة الحالية إلى الإشارات المرجعية بـ ⌘D وتصفّح إشاراتك المرجعية بـ ⇧⌘B. يمكنك استيراد الإشارات المرجعية من متصفح آخر عبر الإشارات المرجعية ← استيراد الإشارات المرجعية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Afegeix la pàgina actual a les adreces d'interès amb ⌘D i navega per les teves adreces d'interès amb ⇧⌘B. Pots importar adreces d'interès d'un altre navegador a través d'Adreces d'interès → Importa adreces d'interès."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přidej aktuální stránku do záložek pomocí ⌘D a procházej své záložky pomocí ⇧⌘B. Záložky z jiného prohlížeče můžeš importovat přes Záložky → Importovat záložky."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sæt bogmærke for den aktuelle side med ⌘D, og gennemse dine bogmærker med ⇧⌘B. Du kan importere bogmærker fra en anden browser via Bogmærker → Importér bogmærker."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setze mit ⌘D ein Lesezeichen für die aktuelle Seite und durchsuche deine Lesezeichen mit ⇧⌘B. Du kannst Lesezeichen aus einem anderen Browser über Lesezeichen → Lesezeichen importieren übernehmen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πρόσθεσε την τρέχουσα σελίδα στους σελιδοδείκτες με ⌘D και περιηγήσου στους σελιδοδείκτες σου με ⇧⌘B. Μπορείς να εισαγάγεις σελιδοδείκτες από άλλο πρόγραμμα περιήγησης μέσω Σελιδοδείκτες → Εισαγωγή σελιδοδεικτών."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Marca la página actual con ⌘D y explora tus marcadores con ⇧⌘B. Puedes importar marcadores de otro navegador desde Marcadores → Importar marcadores."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Marca la página actual con ⌘D y explora tus marcadores con ⇧⌘B. Puedes importar marcadores de otro navegador desde Marcadores → Importar marcadores."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lisää nykyinen sivu kirjanmerkkeihin painamalla ⌘D ja selaa kirjanmerkkejäsi painamalla ⇧⌘B. Voit tuoda kirjanmerkkejä toisesta selaimesta valitsemalla Kirjanmerkit → Tuo kirjanmerkkejä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez la page actuelle aux favoris avec ⌘D et parcourez vos favoris avec ⇧⌘B. Vous pouvez importer des favoris depuis un autre navigateur via Favoris → Importer des favoris."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez la page actuelle aux favoris avec ⌘D et parcourez vos favoris avec ⇧⌘B. Vous pouvez importer des favoris depuis un autre navigateur via Favoris → Importer des favoris."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "סמן את הדף הנוכחי כסימנייה עם ⌘D ועיין בסימניות שלך עם ⇧⌘B. אפשר לייבא סימניות מדפדפן אחר דרך סימניות ← ייבוא סימניות."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘D से वर्तमान पृष्ठ को बुकमार्क करें और ⇧⌘B से अपने बुकमार्क ब्राउज़ करें। आप बुकमार्क → बुकमार्क आयात करें के माध्यम से किसी अन्य ब्राउज़र से बुकमार्क आयात कर सकते हैं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dodaj trenutnu stranicu u knjižne oznake pomoću ⌘D i pregledaj svoje knjižne oznake pomoću ⇧⌘B. Knjižne oznake iz drugog preglednika možeš uvesti putem Knjižne oznake → Uvezi knjižne oznake."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vedd fel az aktuális oldalt a könyvjelzők közé ⌘D-vel, és böngészd a könyvjelzőidet ⇧⌘B-vel. Egy másik böngészőből könyvjelzőket importálhatsz a Könyvjelzők → Könyvjelzők importálása menüponton keresztül."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Markahi halaman saat ini dengan ⌘D dan telusuri markahmu dengan ⇧⌘B. Kamu dapat mengimpor markah dari browser lain melalui Markah → Impor Markah."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiungi ai segnalibri la pagina attuale con ⌘D e sfoglia i tuoi segnalibri con ⇧⌘B. Puoi importare segnalibri da un altro browser tramite Segnalibri → Importa segnalibri."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘Dで現在のページをブックマークし、⇧⌘Bでブックマークを閲覧します。ブックマーク →ブックマークを読み込む から別のブラウザのブックマークを読み込めます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⌘D로 현재 페이지를 북마크하고 ⇧⌘B로 북마크를 탐색하세요. 북마크 → 북마크 가져오기를 통해 다른 브라우저에서 북마크를 가져올 수 있습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tanda buku halaman semasa dengan ⌘D dan layari penanda buku anda dengan ⇧⌘B. Anda boleh mengimport penanda buku daripada pelayar lain melalui Penanda Buku → Import Penanda Buku."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bokmerk gjeldende side med ⌘D og bla gjennom bokmerkene dine med ⇧⌘B. Du kan importere bokmerker fra en annen nettleser via Bokmerker → Importer bokmerker."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zet een bladwijzer voor de huidige pagina met ⌘D en blader door je bladwijzers met ⇧⌘B. Je kunt bladwijzers uit een andere browser importeren via Bladwijzers → Bladwijzers importeren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dodaj bieżącą stronę do zakładek za pomocą ⌘D i przeglądaj zakładki za pomocą ⇧⌘B. Możesz zaimportować zakładki z innej przeglądarki przez Zakładki → Importuj zakładki."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adicione a página atual aos favoritos com ⌘D e navegue pelos seus favoritos com ⇧⌘B. Você pode importar favoritos de outro navegador em Favoritos → Importar favoritos."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adicione a página atual aos favoritos com ⌘D e navegue pelos seus favoritos com ⇧⌘B. Você pode importar favoritos de outro navegador em Favoritos → Importar favoritos."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Marchează pagina curentă cu ⌘D și răsfoiește-ți marcajele cu ⇧⌘B. Poți importa marcaje dintr-un alt browser prin Marcaje → Importă marcaje."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавьте текущую страницу в закладки с помощью ⌘D и просматривайте закладки с помощью ⇧⌘B. Вы можете импортировать закладки из другого браузера через Закладки → Импортировать закладки."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pridaj aktuálnu stránku do záložiek pomocou ⌘D a prechádzaj svoje záložky pomocou ⇧⌘B. Záložky z iného prehliadača môžeš importovať cez Záložky → Importovať záložky."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bokmärk den aktuella sidan med ⌘D och bläddra bland dina bokmärken med ⇧⌘B. Du kan importera bokmärken från en annan webbläsare via Bokmärken → Importera bokmärken."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "บุ๊กมาร์กหน้าปัจจุบันด้วย ⌘D และเรียกดูบุ๊กมาร์กของคุณด้วย ⇧⌘B คุณสามารถนำเข้าบุ๊กมาร์กจากเบราว์เซอร์อื่นผ่าน บุ๊กมาร์ก → นำเข้าบุ๊กมาร์ก"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geçerli sayfayı ⌘D ile yer işaretine ekle ve yer işaretlerine ⇧⌘B ile göz at. Yer işaretlerini başka bir tarayıcıdan Yer İşaretleri → Yer İşaretlerini İçe Aktar yoluyla içe aktarabilirsin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Додайте поточну сторінку в закладки за допомогою ⌘D і переглядайте закладки за допомогою ⇧⌘B. Ви можете імпортувати закладки з іншого браузера через Закладки → Імпортувати закладки."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Đánh dấu trang hiện tại bằng ⌘D và duyệt các dấu trang của bạn bằng ⇧⌘B. Bạn có thể nhập dấu trang từ trình duyệt khác qua Dấu trang → Nhập dấu trang."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用 ⌘D 为当前页面添加书签，用 ⇧⌘B 浏览你的书签。你可以通过 书签 → 导入书签 从其他浏览器导入书签。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用 ⌘D 將目前頁面加入書籤，用 ⇧⌘B 瀏覽你的書籤。你可以透過 書籤 → 匯入書籤 從其他瀏覽器匯入書籤。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用 ⌘D 將目前頁面加入書籤，用 ⇧⌘B 瀏覽你的書籤。你可以透過 書籤 → 匯入書籤 從其他瀏覽器匯入書籤。"
          }
        }
      }
    },
