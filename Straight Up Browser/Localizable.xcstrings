    "Nothing is released, so nothing needs reloading" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا شيء يُحرَّر، لذا لا شيء يحتاج إلى إعادة تحميل"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No s'allibera res, així que no cal recarregar res"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nic se neuvolňuje, takže není třeba nic znovu načítat"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Intet frigives, så intet skal genindlæses"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es wird nichts freigegeben, also muss nichts neu geladen werden"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Τίποτα δεν απελευθερώνεται, οπότε τίποτα δεν χρειάζεται επαναφόρτωση"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se libera nada, así que no hay nada que recargar"
