    "No white flash between tabs — the page appears only once it has pixels." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا وميض أبيض بين علامات التبويب — تظهر الصفحة فقط حين تصبح لديها بكسلات."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cap llampec blanc entre pestanyes: la pàgina apareix només quan ja té píxels."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Žádné bílé bliknutí mezi kartami – stránka se objeví, až když má pixely."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Intet hvidt glimt mellem faneblade – siden dukker først op, når den har pixels."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kein weißes Aufblitzen zwischen Tabs – die Seite erscheint erst, wenn sie Pixel hat."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Καμία λευκή αναλαμπή ανάμεσα στις καρτέλες — η σελίδα εμφανίζεται μόνο όταν έχει εικονοστοιχεία."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sin destello blanco entre pestañas: la página aparece solo cuando ya tiene píxeles."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sin destello blanco entre pestañas: la página aparece solo cuando ya tiene píxeles."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ei valkoista välähdystä välilehtien välillä – sivu ilmestyy vasta, kun sillä on pikseleitä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucun flash blanc entre les onglets — la page n'apparaît qu'une fois qu'elle a des pixels."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucun flash blanc entre les onglets — la page n'apparaît qu'une fois qu'elle a des pixels."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "בלי הבזק לבן בין כרטיסיות — הדף מופיע רק כשיש לו פיקסלים."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "टैब बदलते समय सफ़ेद झिलमिलाहट नहीं — पृष्ठ तभी दिखता है जब उसमें पिक्सेल आ जाते हैं।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bez bijelog bljeska među karticama – stranica se pojavljuje tek kad ima piksele."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nincs fehér villanás a lapok között – az oldal csak akkor jelenik meg, ha már vannak képpontjai."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tanpa kilatan putih antartab — halaman muncul hanya setelah punya piksel."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nessun lampo bianco tra le schede: la pagina compare solo quando ha dei pixel."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タブを切り替えても白い点滅なし。ページはピクセルが揃ってから現れます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "탭 사이에 흰 번쩍임 없음 — 페이지는 픽셀이 준비된 뒤에만 나타납니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiada kilatan putih antara tab — halaman muncul hanya apabila ia sudah ada piksel."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingen hvit blink mellom faner – siden dukker først opp når den har piksler."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geen witte flits tussen tabbladen – de pagina verschijnt pas als hij pixels heeft."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Żadnego białego błysku między kartami — strona pojawia się dopiero, gdy ma piksele."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sem flash branco entre abas — a página aparece só quando já tem pixels."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sem flash branco entre abas — a página aparece só quando já tem pixels."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fără licărire albă între file — pagina apare abia când are pixeli."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Никаких белых вспышек между вкладками — страница появляется, только когда у неё есть пиксели."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Žiadne biele bliknutie medzi kartami – stránka sa objaví, až keď má pixely."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingen vit blixt mellan flikar – sidan visas först när den har bildpunkter."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ไม่มีแสงขาวแวบระหว่างแท็บ — หน้าเว็บจะโผล่ก็ต่อเมื่อมีพิกเซลแล้ว"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sekmeler arasında beyaz parlama yok — sayfa ancak pikselleri olduğunda görünür."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Жодних білих спалахів між вкладками — сторінка з'являється лише тоді, коли має пікселі."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Không còn chớp trắng giữa các thẻ — trang chỉ hiện khi đã có điểm ảnh."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "切换标签页时不再白闪——页面有了像素才会出现。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "切換分頁時不再白閃——頁面有了像素才會出現。"
          }
