    "Pick any combination — edges, the favicon ring, or both.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر أي مجموعة — الحواف أو حلقة الأيقونة المفضّلة أو كليهما."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Tria qualsevol combinació — les vores, l'anell del favicon o totes dues."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyber libovolnou kombinaci — okraje, prstenec faviconu nebo oboje."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg en hvilken som helst kombination — kanterne, favicon-ringen eller begge."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle eine beliebige Kombination – Kanten, den Favicon-Ring oder beides."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επίλεξε οποιονδήποτε συνδυασμό — τις άκρες, τον δακτύλιο του favicon ή και τα δύο."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige cualquier combinación: los bordes, el anillo del favicon o ambos."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige cualquier combinación: los bordes, el anillo del favicon o ambos."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse mikä tahansa yhdistelmä — reunat, favicon-rengas tai molemmat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez n'importe quelle combinaison — les bords, l'anneau du favicon, ou les deux."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez n'importe quelle combinaison — les bords, l'anneau du favicon, ou les deux."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בחר כל שילוב — הקצוות, הטבעת סביב סמל האתר, או שניהם."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई भी संयोजन चुनें — किनारे, फ़ेविकॉन रिंग, या दोनों।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odaberi bilo koju kombinaciju — rubove, prsten favicona ili oboje."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válaszd bármely kombinációt — a szélek, a favicon gyűrű vagy mindkettő."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih kombinasi apa pun — tepi, cincin favicon, atau keduanya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli qualsiasi combinazione: i bordi, l'anello del favicon o entrambi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "任意の組み合わせを選択：端、ファビコンのリング、またはその両方。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "가장자리, 파비콘 링 또는 둘 다 등 원하는 조합을 선택하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih sebarang gabungan — tepi, cincin favicon, atau kedua-duanya."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg hvilken som helst kombinasjon — kantene, favikon-ringen eller begge."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies een willekeurige combinatie — de randen, de favicon-ring of beide."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz dowolną kombinację — krawędzie, pierścień faviconu lub oba."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha qualquer combinação — as bordas, o anel do favicon ou ambos."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha qualquer combinação — as bordas, o anel do favicon ou ambos."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alege orice combinație — marginile, inelul faviconului sau ambele."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите любое сочетание — края, кольцо вокруг фавикона или оба."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyber ľubovoľnú kombináciu — okraje, prstenec faviconu alebo oboje."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj valfri kombination — kanterna, favikon-ringen eller båda."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกชุดใดก็ได้ — ขอบ วงแหวนรอบฟาวิคอน หรือทั้งสอง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Herhangi bir kombinasyon seç — kenarlar, favicon halkası ya da her ikisi."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть будь-яке поєднання — краї, кільце навколо фавікона або обидва."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn bất kỳ kết hợp nào — các cạnh, vòng favicon, hoặc cả hai."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇任意組合——邊緣、圖示環，或兩者。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择任意组合——边缘、图标环，或两者。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇任意組合——邊緣、圖示環，或兩者。"
          }
        }
      }
    },
