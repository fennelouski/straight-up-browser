    "Follows your live rules in order: never-domains, the per-kind toggles, always-domains, then file types." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتبع قواعدك المباشرة بالترتيب: النطاقات أبدًا، مفاتيح التبديل حسب النوع، النطاقات دائمًا، ثم أنواع الملفات."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segueix les teves regles actives en ordre: dominis mai, els interruptors per tipus, dominis sempre, després tipus de fitxer."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Řídí se tvými aktivními pravidly v pořadí: domény nikdy, přepínače podle typu, domény vždy, poté typy souborů."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Følger dine aktive regler i rækkefølge: aldrig-domæner, kontakterne pr. type, altid-domæner, derefter filtyper."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Folgt deinen aktiven Regeln der Reihe nach: Nie-Domains, die Umschalter je Art, Immer-Domains, dann Dateitypen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ακολουθεί τους ζωντανούς κανόνες σου με τη σειρά: τομείς ποτέ, οι διακόπτες ανά τύπο, τομείς πάντα, μετά τύποι αρχείων."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sigue tus reglas en vivo en orden: dominios nunca, los interruptores por tipo, dominios siempre y luego tipos de archivo."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sigue tus reglas en vivo en orden: dominios nunca, los interruptores por tipo, dominios siempre y luego tipos de archivo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Noudattaa aktiivisia sääntöjäsi järjestyksessä: ei koskaan -verkkotunnukset, tyyppikohtaiset kytkimet, aina-verkkotunnukset, sitten tiedostotyypit."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suit vos règles en direct dans l'ordre : domaines jamais, les bascules par type, domaines toujours, puis types de fichiers."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Suit vos règles en direct dans l'ordre : domaines jamais, les bascules par type, domaines toujours, puis types de fichiers."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "עוקב אחר הכללים החיים שלך לפי הסדר: דומיינים אף פעם, המתגים לפי סוג, דומיינים תמיד, ואז סוגי קבצים."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपके सक्रिय नियमों का क्रम में पालन करता है: कभी-नहीं डोमेन, प्रति-प्रकार टॉगल, हमेशा डोमेन, फिर फ़ाइल प्रकार।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slijedi tvoja aktivna pravila redom: domene nikad, preklopnici po vrsti, domene uvijek, zatim vrste datoteka."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az aktív szabályaidat követi sorrendben: soha-tartományok, a típusonkénti kapcsolók, mindig-tartományok, majd fájltípusok."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mengikuti aturan langsungmu secara berurutan: domain tidak pernah, sakelar per jenis, domain selalu, lalu jenis berkas."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segue le tue regole attive in ordine: domini mai, gli interruttori per tipo, domini sempre, poi tipi di file."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "有効なルールを順番に適用します：「なし」ドメイン、種類別のスイッチ、「常に」ドメイン、次にファイルの種類。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "라이브 규칙을 순서대로 따릅니다: 절대 도메인, 유형별 스위치, 항상 도메인, 그다음 파일 유형."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mengikut peraturan langsung anda mengikut urutan: domain tidak pernah, togol setiap jenis, domain sentiasa, kemudian jenis fail."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Følger dine aktive regler i rekkefølge: aldri-domener, bryterne per type, alltid-domener, deretter filtyper."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Volgt je actieve regels op volgorde: nooit-domeinen, de schakelaars per type, altijd-domeinen, dan bestandstypen."
