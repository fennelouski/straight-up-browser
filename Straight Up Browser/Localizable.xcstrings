    "Whatever the mouse is over — an image, a field, or a block of text." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أيًّا كان ما تحت مؤشر الفأرة — صورة أو حقل أو كتلة نصية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allò que hi hagi sota el ratolí: una imatge, un camp o un bloc de text."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cokoli je pod myší – obrázek, pole nebo blok textu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvad musen end er over – et billede, et felt eller en tekstblok."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Worüber die Maus gerade steht – ein Bild, ein Feld oder ein Textblock."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ό,τι κι αν βρίσκεται κάτω από το ποντίκι — μια εικόνα, ένα πεδίο ή ένα μπλοκ κειμένου."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo que haya bajo el ratón: una imagen, un campo o un bloque de texto."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo que haya bajo el ratón: una imagen, un campo o un bloque de texto."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mikä tahansa on hiiren alla – kuva, kenttä tai tekstilohko."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce que survole la souris — une image, un champ ou un bloc de texte."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce que survole la souris — une image, un champ ou un bloc de texte."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "כל מה שהעכבר נמצא מעליו — תמונה, שדה או גוש טקסט."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "माउस जिस पर भी हो — एक छवि, एक फ़ील्ड या पाठ का एक खंड।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Što god je pod mišem – slika, polje ili blok teksta."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bármi, ami az egér alatt van – egy kép, egy mező vagy egy szövegblokk."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apa pun yang ditunjuk tetikus — sebuah gambar, kolom isian, atau blok teks."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qualunque cosa ci sia sotto il mouse: un'immagine, un campo o un blocco di testo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "マウスが重なっているもの。画像、入力欄、テキストのかたまりなど。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "마우스가 올라간 것이면 무엇이든 — 이미지, 입력 필드 또는 텍스트 블록."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apa sahaja yang tetikus berada di atasnya — sekeping imej, medan, atau blok teks."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hva enn musen står over – et bilde, et felt eller en tekstblokk."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Waar de muis ook boven staat – een afbeelding, een veld of een blok tekst."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cokolwiek jest pod myszą — obraz, pole albo blok tekstu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O que estiver sob o mouse — uma imagem, um campo ou um bloco de texto."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O que estiver sob o mouse — uma imagem, um campo ou um bloco de texto."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Orice se află sub mouse — o imagine, un câmp sau un bloc de text."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Всё, над чем стоит указатель: изображение, поле или блок текста."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Čokoľvek je pod myšou – obrázok, pole alebo blok textu."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vad musen än ligger över – en bild, ett fält eller ett textblock."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "อะไรก็ตามที่เมาส์อยู่เหนือ — รูปภาพ ช่องกรอก หรือบล็อกข้อความ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Farenin üzerinde durduğu her ne varsa — bir görüntü, bir alan ya da bir metin bloğu."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Усе, над чим стоїть вказівник: зображення, поле або блок тексту."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bất cứ thứ gì con chuột đang trỏ vào — một hình ảnh, một ô nhập hoặc một khối văn bản."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "鼠标停在哪儿就拍哪儿——图片、输入框或一段文字。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "滑鼠停在哪裡就拍哪裡——圖片、輸入欄位或一段文字。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "滑鼠停在哪裡就拍哪裡——圖片、輸入欄位或一段文字。"
          }
        }
      }
    },
    "When Browser isn't your default, a small card appears in the corner of a new tab offering to make it one. It goes away for good once you answer it either way — turn this off to skip it entirely, or back on to see it again." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حين لا يكون Browser متصفحك الافتراضي، تظهر بطاقة صغيرة في زاوية علامة تبويب جديدة تعرض جعله كذلك. وتختفي نهائيًا بمجرد أن تجيب، بأي من الاتجاهين — أوقف هذا الخيار لتخطّيها تمامًا، أو أعِد تشغيله لتراها من جديد."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quan el Browser no és el teu navegador per omissió, apareix una targeta petita al cantó d'una pestanya nova que s'ofereix a ser-ho. Desapareix per sempre tan bon punt hi respons, sigui com sigui: desactiva això per saltar-te-la del tot, o torna-ho a activar per tornar-la a veure."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Když Browser není tvůj výchozí prohlížeč, objeví se v rohu nové karty malá kartička s nabídkou to změnit. Zmizí navždy, jakmile odpovíš – tak či onak. Vypni tohle, ať ji přeskočíš úplně, nebo zapni znovu, ať ji uvidíš zas."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Når Browser ikke er din standard, dukker et lille kort op i hjørnet af et nyt faneblad og tilbyder at gøre den til det. Det forsvinder for altid, så snart du svarer – uanset hvordan. Slå dette fra for at springe det helt over, eller til igen for at se det på ny."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Browser nicht dein Standard ist, erscheint in der Ecke eines neuen Tabs eine kleine Karte, die anbietet, ihn dazu zu machen. Sobald du so oder so antwortest, ist sie endgültig weg – schalte dies aus, um sie ganz zu überspringen, oder wieder ein, um sie erneut zu sehen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Όταν το Browser δεν είναι η προεπιλογή σου, στη γωνία μιας νέας καρτέλας εμφανίζεται μια μικρή κάρτα που προτείνει να γίνει. Εξαφανίζεται οριστικά μόλις απαντήσεις, με τον έναν ή τον άλλο τρόπο — απενεργοποίησέ το για να την παρακάμψεις εντελώς, ή ενεργοποίησέ το ξανά για να τη δεις πάλι."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando Browser no es tu navegador por omisión, aparece una tarjetita en la esquina de una pestaña nueva ofreciéndose a serlo. Desaparece para siempre en cuanto respondes, sea cual sea la respuesta: desactiva esto para saltártela por completo, o vuelve a activarlo para verla otra vez."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando Browser no es tu navegador por omisión, aparece una tarjetita en la esquina de una pestaña nueva ofreciéndose a serlo. Desaparece para siempre en cuanto respondes, sea cual sea la respuesta: desactiva esto para saltártela por completo, o vuelve a activarlo para verla otra vez."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun Browser ei ole oletuksesi, uuden välilehden kulmaan ilmestyy pieni kortti, joka tarjoutuu tekemään siitä oletuksen. Se katoaa lopullisesti heti kun vastaat, tavalla tai toisella – ota tämä pois käytöstä ohittaaksesi sen kokonaan, tai takaisin käyttöön nähdäksesi sen uudelleen."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quand Browser n'est pas votre navigateur par défaut, une petite carte apparaît dans le coin d'un nouvel onglet et propose de le devenir. Elle disparaît définitivement dès que vous répondez, dans un sens ou dans l'autre — désactivez ceci pour l'éviter complètement, ou réactivez-le pour la revoir."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quand Browser n'est pas votre navigateur par défaut, une petite carte apparaît dans le coin d'un nouvel onglet et propose de le devenir. Elle disparaît définitivement dès que vous répondez, dans un sens ou dans l'autre — désactivez ceci pour l'éviter complètement, ou réactivez-le pour la revoir."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "כאשר Browser אינו ברירת המחדל שלך, מופיע כרטיס קטן בפינת כרטיסייה חדשה ומציע להפוך אותו לכזה. הוא נעלם לתמיד ברגע שתשיב, כך או אחרת — כבה את האפשרות כדי לדלג עליו לגמרי, או הפעל מחדש כדי לראותו שוב."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "जब Browser आपका डिफ़ॉल्ट नहीं होता, नए टैब के कोने में एक छोटा कार्ड आता है जो उसे डिफ़ॉल्ट बनाने का प्रस्ताव देता है। आप जो भी जवाब दें, जवाब देते ही वह हमेशा के लिए चला जाता है — इसे पूरी तरह टालने के लिए यह बंद करें, या दोबारा देखने के लिए फिर चालू करें।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kad Browser nije tvoj zadani preglednik, u kutu nove kartice pojavljuje se mala kartica koja se nudi to postati. Nestaje zauvijek čim odgovoriš, ovako ili onako – isključi ovo da je preskočiš posve, ili uključi ponovno da je vidiš opet."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha a Browser nem az alapértelmezett böngésződ, egy új lap sarkában megjelenik egy kis kártya, amely felajánlja, hogy azzá váljon. Amint válaszolsz rá – így vagy úgy –, végleg eltűnik. Kapcsold ki, ha teljesen ki akarod hagyni, vagy vissza, ha újra látni szeretnéd."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ketika Browser bukan bawaan Anda, sebuah kartu kecil muncul di sudut tab baru menawarkan diri jadi bawaan. Kartu itu hilang selamanya begitu Anda menjawab, apa pun jawabannya — matikan opsi ini untuk melewatinya sama sekali, atau nyalakan lagi untuk melihatnya kembali."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando Browser non è il tuo predefinito, nell'angolo di una nuova scheda compare una piccola scheda che si offre di diventarlo. Sparisce per sempre non appena rispondi, in un senso o nell'altro: disattiva questa opzione per saltarla del tutto, o riattivala per rivederla."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Browser がデフォルトでないとき、新しいタブの隅に小さなカードが現れ、デフォルトにするか尋ねます。どちらを選んでも、答えた時点で二度と表示されません。完全に省くにはこれをオフに、もう一度見るにはオンに戻してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Browser가 기본 브라우저가 아닐 때, 새로운 탭 모서리에 작은 카드가 나타나 기본으로 설정할지 묻습니다. 어느 쪽이든 답하면 완전히 사라집니다. 아예 건너뛰려면 이 옵션을 끄고, 다시 보려면 켜세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apabila Browser bukan lalai anda, sekeping kad kecil muncul di sudut tab baharu menawarkan untuk menjadikannya lalai. Ia hilang selama-lamanya sebaik anda menjawab, apa pun jawapannya — matikan ini untuk melangkaunya terus, atau hidupkan semula untuk melihatnya lagi."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Når Browser ikke er standarden din, dukker et lite kort opp i hjørnet av en ny fane og tilbyr å gjøre den til det. Det forsvinner for godt så snart du svarer, uansett hvordan – slå dette av for å hoppe over det helt, eller på igjen for å se det på nytt."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Als Browser niet je standaard is, verschijnt er in de hoek van een nieuw tabblad een kaartje dat aanbiedt hem dat te maken. Zodra je het hoe dan ook beantwoordt is het definitief weg – zet dit uit om het helemaal over te slaan, of weer aan om het opnieuw te zien."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gdy Browser nie jest twoją domyślną przeglądarką, w rogu nowej karty pojawia się mała karteczka z propozycją, by nią została. Znika na dobre, gdy tylko odpowiesz — tak czy inaczej. Wyłącz tę opcję, aby pominąć ją całkowicie, albo włącz ponownie, aby zobaczyć ją znowu."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando o Browser não é seu padrão, um cartãozinho aparece no canto de uma aba nova oferecendo torná-lo padrão. Ele some de vez assim que você responde, de um jeito ou de outro — desative isto para pulá-lo por completo, ou reative para vê-lo de novo."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quando o Browser não é seu padrão, um cartãozinho aparece no canto de uma aba nova oferecendo torná-lo padrão. Ele some de vez assim que você responde, de um jeito ou de outro — desative isto para pulá-lo por completo, ou reative para vê-lo de novo."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Când Browser nu e implicit, în colțul unei file noi apare un cartonaș care se oferă să îl facă implicit. Dispare definitiv de îndată ce răspunzi, într-un fel sau altul — dezactivează asta ca să îl sari complet, sau reactivează ca să-l vezi din nou."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Когда Browser не выбран по умолчанию, в углу новой вкладки появляется небольшая карточка с предложением это исправить. Она исчезает навсегда, как только вы ответите — неважно как. Выключите этот параметр, чтобы пропустить её вовсе, или включите снова, чтобы увидеть её опять."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keď Browser nie je tvoj predvolený prehliadač, v rohu novej karty sa objaví malá kartička s ponukou to zmeniť. Zmizne navždy, len čo odpovieš – tak či onak. Vypni toto, ak ju chceš preskočiť úplne, alebo zapni znova, ak ju chceš vidieť zas."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "När Browser inte är din standard dyker ett litet kort upp i hörnet av en ny flik och erbjuder att göra den till det. Det försvinner för gott så snart du svarar, hur du än svarar – stäng av det här för att hoppa över det helt, eller slå på det igen för att se det på nytt."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เมื่อ Browser ไม่ใช่ค่าเริ่มต้นของคุณ การ์ดใบเล็กจะโผล่ที่มุมของแท็บใหม่เพื่อเสนอให้ตั้งเป็นค่าเริ่มต้น เมื่อคุณตอบไม่ว่าทางใด มันจะหายไปถาวร — ปิดตัวเลือกนี้เพื่อข้ามไปเลย หรือเปิดใหม่เพื่อให้เห็นอีกครั้ง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Browser varsayılanınız değilken yeni bir sekmenin köşesinde küçük bir kart belirir ve varsayılan olmayı önerir. Nasıl yanıtlarsanız yanıtlayın, yanıtladığınız anda temelli gider — tümüyle atlamak için bunu kapatın, yeniden görmek için açın."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Коли Browser не вибрано за замовчуванням, у куті нової вкладки з'являється невелика картка з пропозицією це виправити. Вона зникає назавжди, щойно ви відповісте — байдуже як. Вимкніть цей параметр, щоб пропустити її зовсім, або увімкніть знову, щоб побачити її ще раз."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khi Browser chưa là mặc định của bạn, một thẻ nhỏ hiện ở góc thẻ mới, đề nghị đặt nó làm mặc định. Nó biến mất vĩnh viễn ngay khi bạn trả lời, dù theo hướng nào — tắt tùy chọn này để bỏ qua hẳn, hoặc bật lại để thấy nó lần nữa."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当 Browser 不是你的默认浏览器时，新标签页的角落会出现一张小卡片，提议把它设为默认。无论你怎么回答，答过之后它就永远不再出现——关掉此项可完全跳过，重新打开则可再看到它。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當 Browser 不是你的預設瀏覽器時，新分頁的角落會出現一張小卡片，建議把它設為預設。無論你怎麼回答，答過之後它就永遠不再出現——關掉此項可完全略過，重新開啟則可再看到它。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當 Browser 不是你的預設瀏覽器時，新分頁的角落會出現一張小卡片，建議把它設為預設。無論你怎麼回答，答過之後它就永遠不再出現——關掉此項可完全略過，重新開啟則可再看到它。"
          }
        }
      }
    },
    "Where any shortcut set to “save to the shared folder” writes." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "المكان الذي يكتب فيه كل اختصار مضبوط على «الحفظ في المجلد المشترك»."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "On escriu qualsevol drecera configurada per «desar a la carpeta compartida»."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kam zapisuje každá zkratka nastavená na „uložit do sdílené složky“."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvor enhver genvej, der er sat til “arkivér i den delte mappe”, skriver."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wohin jeder Kurzbefehl schreibt, der auf „in den gemeinsamen Ordner sichern“ gesetzt ist."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Πού γράφει κάθε συντόμευση ρυθμισμένη σε «αποθήκευση στον κοινό φάκελο»."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Donde escribe cualquier atajo configurado como «guardar en la carpeta compartida»."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Donde escribe cualquier atajo configurado como «guardar en la carpeta compartida»."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minne jokainen ”tallenna jaettuun kansioon” -asetuksella varustettu pikanäppäin kirjoittaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'endroit où écrit tout raccourci réglé sur « enregistrer dans le dossier partagé »."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'endroit où écrit tout raccourci réglé sur « enregistrer dans le dossier partagé »."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לאן כותב כל קיצור שמוגדר ל״שמור בתיקייה המשותפת״."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“साझा फ़ोल्डर में सहेजें” पर सेट हर शॉर्टकट यहीं लिखता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kamo piše svaka prečica postavljena na „spremi u zajedničku mapu”."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ide ír minden „mentés a közös mappába” beállítású gyorsbillentyű."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tempat setiap pintasan yang disetel ke “simpan ke folder bersama” menulis."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dove scrive ogni scorciatoia impostata su «salva nella cartella condivisa»."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「共有フォルダに保存」に設定したショートカットの書き込み先です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "‘공유 폴더에 저장’으로 설정된 단축키가 기록하는 위치입니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tempat setiap pintasan yang ditetapkan kepada “simpan ke folder kongsi” menulis."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvor alle hurtigtaster satt til «lagre i den delte mappen» skriver."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Waar elke toetscombinatie schrijft die op ‘bewaar in de gedeelde map’ staat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dokąd zapisuje każdy skrót ustawiony na „zapisuj we wspólnym folderze”."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Onde escreve qualquer atalho definido como “salvar na pasta compartilhada”."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Onde escreve qualquer atalho definido como “salvar na pasta compartilhada”."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unde scrie orice scurtătură setată pe „salvează în dosarul comun”."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Куда пишет любое сочетание, настроенное на «сохранять в общую папку»."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kam zapisuje každá skratka nastavená na „uložiť do zdieľaného priečinka“."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dit varje kortkommando som är inställt på ”spara till den delade mappen” skriver."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ที่ที่ปุ่มลัดซึ่งตั้งเป็น “บันทึกลงโฟลเดอร์ที่ใช้ร่วมกัน” จะเขียนลงไป"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“Paylaşılan klasöre kaydet” olarak ayarlanmış her kısayolun yazdığı yer."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Куди пише будь-яке сполучення, налаштоване на «зберігати у спільну папку»."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nơi mọi phím tắt đặt ở chế độ “lưu vào thư mục dùng chung” sẽ ghi tới."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有设为“存到共享文件夹”的快捷键都写到这里。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有設為「存到共用檔案夾」的快速鍵都寫到這裡。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "所有設為「存到共用檔案夾」的快速鍵都寫到這裡。"
          }
        }
      }
    },
