    "To avoid losing your tabs to a mistyped shortcut, quitting requires holding ⌘Q for two seconds.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لتجنّب فقدان علامات تبويبك بسبب اختصار مكتوب خطأً، يتطلب الإنهاء الضغط مع الاستمرار على ⌘Q لمدة ثانيتين."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Per evitar perdre les pestanyes per una drecera mal escrita, sortir requereix mantenir ⌘Q durant dos segons."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby ses vyhnul ztrátě karet kvůli chybně napsané zkratce, ukončení vyžaduje podržení ⌘Q po dobu dvou sekund."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "For at undgå at miste dine faneblade ved en fejlskrevet genvej kræver det at slutte, at du holder ⌘Q nede i to sekunder."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Um zu vermeiden, dass du deine Tabs durch einen falsch getippten Kurzbefehl verlierst, erfordert das Beenden das Halten von ⌘Q für zwei Sekunden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Για να μη χάσεις τις καρτέλες σου από μια λανθασμένη συντόμευση, η έξοδος απαιτεί το κράτημα του ⌘Q για δύο δευτερόλεπτα."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para evitar perder tus pestañas por un atajo mal escrito, salir requiere mantener ⌘Q durante dos segundos."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Para evitar perder tus pestañas por un atajo mal escrito, salir requiere mantener ⌘Q durante dos segundos."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jotta et menettäisi välilehtiäsi väärin kirjoitetun pikanäppäimen vuoksi, lopettaminen vaatii ⌘Q:n pitämistä pohjassa kaksi sekuntia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour éviter de perdre vos onglets à cause d'un raccourci mal tapé, quitter nécessite de maintenir ⌘Q pendant deux secondes."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour éviter de perdre vos onglets à cause d'un raccourci mal tapé, quitter nécessite de maintenir ⌘Q pendant deux secondes."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "כדי להימנע מאובדן הכרטיסיות שלך עקב קיצור שהוקלד בטעות, יציאה דורשת החזקת ⌘Q למשך שתי שניות."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "गलत टाइप किए गए शॉर्टकट के कारण अपने टैब खोने से बचने के लिए, छोड़ने हेतु ⌘Q को दो सेकंड तक दबाए रखना आवश्यक है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kako ne bi izgubio kartice zbog pogrešno upisanog prečaca, izlaz zahtijeva držanje ⌘Q dvije sekunde."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Hogy egy elgépelt gyorsbillentyű miatt ne veszítsd el a lapjaidat, a kilépéshez két másodpercig kell nyomva tartanod a ⌘Q-t."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Untuk menghindari kehilangan tab karena pintasan yang salah ketik, keluar memerlukan menahan ⌘Q selama dua detik."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per evitare di perdere le schede a causa di una scorciatoia digitata male, per uscire è necessario tenere premuto ⌘Q per due secondi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "打ち間違えたショートカットでタブを失わないよう、終了するには⌘Qを2秒間押し続ける必要があります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "잘못 입력한 단축키로 탭을 잃지 않도록, 종료하려면 ⌘Q를 2초 동안 눌러야 합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Untuk mengelakkan kehilangan tab akibat pintasan yang tersalah taip, keluar memerlukan menahan ⌘Q selama dua saat."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "For å unngå å miste fanene dine på grunn av en feilskrevet snarvei krever avslutning at du holder ⌘Q i to sekunder."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Om te voorkomen dat je je tabbladen verliest door een verkeerd getypte sneltoets, vereist stoppen dat je ⌘Q twee seconden ingedrukt houdt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby uniknąć utraty kart z powodu błędnie wpisanego skrótu, zakończenie wymaga przytrzymania ⌘Q przez dwie sekundy."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para evitar perder suas abas por um atalho digitado errado, sair exige segurar ⌘Q por dois segundos."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Para evitar perder suas abas por um atalho digitado errado, sair exige segurar ⌘Q por dois segundos."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pentru a evita să-ți pierzi filele din cauza unei scurtături tastate greșit, ieșirea necesită să ții ⌘Q timp de două secunde."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чтобы не потерять вкладки из-за ошибочно нажатого сочетания, для выхода нужно удерживать ⌘Q две секунды."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Aby si sa vyhol strate kariet kvôli chybne napísanej skratke, ukončenie vyžaduje podržanie ⌘Q na dve sekundy."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "För att undvika att förlora dina flikar på grund av ett felskrivet kortkommando kräver avslut att du håller ned ⌘Q i två sekunder."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เพื่อหลีกเลี่ยงการสูญเสียแท็บของคุณจากแป้นลัดที่พิมพ์ผิด การออกต้องกด ⌘Q ค้างไว้สองวินาที"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yanlış yazılan bir kısayol yüzünden sekmelerini kaybetmemek için çıkış, ⌘Q'yu iki saniye basılı tutmayı gerektirir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Щоб не втратити вкладки через помилково натиснуте сполучення, для виходу потрібно утримувати ⌘Q дві секунди."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Để tránh mất các thẻ do một phím tắt gõ nhầm, việc thoát yêu cầu giữ ⌘Q trong hai giây."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "為避免因誤按快速鍵而遺失分頁，結束需要按住 ⌘Q 兩秒。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为避免因误按快捷键而丢失标签页，退出需要按住 ⌘Q 两秒。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為避免因誤按快速鍵而遺失分頁，結束需要按住 ⌘Q 兩秒。"
          }
        }
      }
    },
