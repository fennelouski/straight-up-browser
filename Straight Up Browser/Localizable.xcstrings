    "Just the thing under the pointer: an image, a field, or a block of text." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "فقط ما تحت المؤشر: صورة أو حقل أو كتلة نصية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Només allò que hi ha sota el punter: una imatge, un camp o un bloc de text."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jen to pod kurzorem: obrázek, pole nebo blok textu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun det, der er under markøren: et billede, et felt eller en tekstblok."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nur das unter dem Zeiger: ein Bild, ein Feld oder ein Textblock."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Μόνο ό,τι βρίσκεται κάτω από τον δείκτη: μια εικόνα, ένα πεδίο ή ένα μπλοκ κειμένου."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo lo que hay bajo el puntero: una imagen, un campo o un bloque de texto."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solo lo que hay bajo el puntero: una imagen, un campo o un bloque de texto."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vain se, mikä on osoittimen alla: kuva, kenttä tai tekstilohko."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uniquement l'élément sous le pointeur : une image, un champ ou un bloc de texte."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uniquement l'élément sous le pointeur : une image, un champ ou un bloc de texte."
