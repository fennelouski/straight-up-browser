          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Få den daglige snarveien til å lagre en PDF i stedet for å skrive ut."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De alledaagse sneltoets een pdf laten opslaan in plaats van afdrukken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spraw, aby codzienny skrót zapisywał PDF zamiast drukować."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fazer com que o atalho do dia a dia salve um PDF em vez de imprimir."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
