    "Release idle background tabs from RAM when your Mac runs low." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حرِّر علامات تبويب الخلفية الخاملة من ذاكرة الوصول العشوائي عندما تنخفض ذاكرة الـ Mac لديك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allibera les pestanyes inactives en segon pla de la RAM quan el teu Mac es queda sense memòria."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uvolni nečinné karty na pozadí z RAM, když tvému Macu dochází paměť."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Frigiv inaktive baggrundsfaneblade fra RAM, når din Mac er ved at løbe tør."
          }
        },
        "de" : {
          "stringUnit" : {
