    "Screen Recording isn't granted yet, so this falls back to the limited capture." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لم يُمنح إذن تسجيل الشاشة بعد، لذا يُلجأ إلى اللقطة المحدودة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Encara no s'ha concedit l'enregistrament de pantalla, així que es recorre a la captura limitada."
          }
