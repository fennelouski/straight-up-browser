    "Hold ⌥ and click to save instead of open. Type each entry, or paste a list.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط مع الاستمرار على ⌥ وانقر للحفظ بدلًا من الفتح. اكتب كل إدخال، أو الصق قائمة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén ⌥ i fes clic per desar en lloc d'obrir. Escriu cada entrada, o enganxa una llista."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Podrž ⌥ a klikni pro uložení místo otevření. Napiš každou položku, nebo vlož seznam."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold ⌥ nede, og klik for at gemme i stedet for at åbne. Skriv hver post, eller indsæt en liste."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte ⌥ und klicke, um zu speichern statt zu öffnen. Gib jeden Eintrag ein oder füge eine Liste ein."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κράτα πατημένο το ⌥ και κάνε κλικ για αποθήκευση αντί για άνοιγμα. Πληκτρολόγησε κάθε καταχώριση, ή επικόλλησε μια λίστα."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén ⌥ y haz clic para guardar en lugar de abrir. Escribe cada entrada o pega una lista."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén ⌥ y haz clic para guardar en lugar de abrir. Escribe cada entrada o pega una lista."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pidä ⌥ pohjassa ja napsauta tallentaaksesi avaamisen sijaan. Kirjoita jokainen merkintä tai liitä luettelo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenez ⌥ et cliquez pour enregistrer au lieu d'ouvrir. Saisissez chaque entrée, ou collez une liste."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Maintenez ⌥ et cliquez pour enregistrer au lieu d'ouvrir. Saisissez chaque entrée, ou collez une liste."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "החזק ⌥ ולחץ כדי לשמור במקום לפתוח. הקלד כל ערך, או הדבק רשימה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "खोलने के बजाय सहेजने के लिए ⌥ दबाए रखें और क्लिक करें। प्रत्येक प्रविष्टि टाइप करें, या एक सूची पेस्ट करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Drži ⌥ i klikni za spremanje umjesto otvaranja. Upiši svaki unos ili zalijepi popis."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Tartsd lenyomva a ⌥ billentyűt, és kattints a megnyitás helyett a mentéshez. Írd be mindegyik bejegyzést, vagy illessz be egy listát."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tahan ⌥ dan klik untuk menyimpan alih-alih membuka. Ketik setiap entri, atau tempel daftar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tieni premuto ⌥ e fai clic per salvare invece di aprire. Digita ogni voce o incolla un elenco."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "⌥を押しながらクリックすると、開く代わりに保存します。各項目を入力するか、リストを貼り付けます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "열기 대신 저장하려면 ⌥를 누른 채 클릭하세요. 각 항목을 입력하거나 목록을 붙여넣으세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tahan ⌥ dan klik untuk simpan dan bukan buka. Taip setiap entri, atau tampal senarai."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold ⌥ og klikk for å lagre i stedet for å åpne. Skriv inn hver oppføring, eller lim inn en liste."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd ⌥ ingedrukt en klik om op te slaan in plaats van te openen. Typ elke invoer of plak een lijst."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przytrzymaj ⌥ i kliknij, aby zapisać zamiast otwierać. Wpisz każdy wpis lub wklej listę."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Segure ⌥ e clique para salvar em vez de abrir. Digite cada entrada ou cole uma lista."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Segure ⌥ e clique para salvar em vez de abrir. Digite cada entrada ou cole uma lista."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ține apăsat ⌥ și fă clic pentru a salva în loc de a deschide. Tastează fiecare intrare, sau lipește o listă."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удерживайте ⌥ и щёлкните, чтобы сохранить вместо открытия. Вводите каждую запись или вставьте список."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Podrž ⌥ a klikni na uloženie namiesto otvorenia. Napíš každú položku, alebo vlož zoznam."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Håll ned ⌥ och klicka för att spara i stället för att öppna. Skriv varje post, eller klistra in en lista."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กด ⌥ ค้างไว้แล้วคลิกเพื่อบันทึกแทนการเปิด พิมพ์แต่ละรายการ หรือวางเป็นรายการ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Açmak yerine kaydetmek için ⌥ tuşunu basılı tutup tıkla. Her girişi yaz ya da bir liste yapıştır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Утримуйте ⌥ і клікніть, щоб зберегти замість відкриття. Уведіть кожен запис або вставте список."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Giữ ⌥ và nhấp để lưu thay vì mở. Gõ từng mục, hoặc dán một danh sách."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "按住 ⌥ 並點按以儲存而非打開。逐項輸入，或貼上一份清單。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住 ⌥ 并点击以保存而非打开。逐条输入，或粘贴一个列表。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按住 ⌥ 並點按以儲存而非打開。逐項輸入，或貼上一份清單。"
          }
        }
      }
    },
    "How high the omnibar sits when you summon it.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مدى ارتفاع شريط العناوين عندما تستدعيه."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "A quina alçada se situa l'omnibar quan el crides."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak vysoko omnibar sedí, když ho vyvoláš."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvor højt omnibaren sidder, når du henter den frem."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie hoch die Omnibar sitzt, wenn du sie aufrufst."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πόσο ψηλά βρίσκεται το omnibar όταν το καλείς."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La altura a la que aparece la omnibar cuando la invocas."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "La altura a la que aparece la omnibar cuando la invocas."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuinka korkealla omnipalkki on, kun kutsut sen esiin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La hauteur à laquelle l'omnibar apparaît lorsque vous l'invoquez."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "La hauteur à laquelle l'omnibar apparaît lorsque vous l'invoquez."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "באיזה גובה יושבת שורת הכתובת כשאתה מזמן אותה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आप इसे बुलाते हैं तो ओमनीबार कितना ऊँचा बैठता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Koliko visoko omnibar stoji kada ga pozoveš."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Milyen magasan helyezkedik el az omnibar, amikor előhívod."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Seberapa tinggi omnibar berada saat kamu memanggilnya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'altezza a cui si posiziona l'omnibar quando lo richiami."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "呼び出したときにオムニバーがどの高さに表示されるか。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "불러올 때 옴니바가 표시되는 높이입니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Seberapa tinggi omnibar berada apabila anda memanggilnya."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvor høyt omnibaren sitter når du henter den frem."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoe hoog de omnibalk zit wanneer je hem oproept."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak wysoko znajduje się omnibar, gdy go przywołujesz."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A que altura a omnibar fica quando você a invoca."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A que altura a omnibar fica quando você a invoca."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Cât de sus stă omnibarul când îl invoci."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На какой высоте находится омнибар, когда вы его вызываете."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ako vysoko omnibar sedí, keď ho vyvoláš."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hur högt omnibaren sitter när du tar fram den."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ออมนิบาร์อยู่สูงแค่ไหนเมื่อคุณเรียกมันขึ้นมา"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Çağırdığında omnibar'ın ne kadar yüksekte durduğu."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "На якій висоті розташований омнібар, коли ви його викликаєте."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibar nằm cao đến đâu khi bạn gọi nó."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "當你叫出網址列時它所處的高度。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当你调出地址栏时它所处的高度。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當你叫出網址列時它所處的高度。"
          }
        }
      }
    },
    "How much of the page one press of Space jumps. Applies to newly loaded pages.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مقدار ما تقفزه ضغطة واحدة على المسافة من الصفحة. ينطبق على الصفحات المحمَّلة حديثًا."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanta pàgina salta una pulsació d'Espai. S'aplica a les pàgines acabades de carregar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak velkou část stránky přeskočí jedno stisknutí Mezerníku. Platí pro nově načtené stránky."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvor meget af siden ét tryk på Mellemrum springer. Gælder for nyligt indlæste sider."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wie viel der Seite ein Druck auf die Leertaste springt. Gilt für neu geladene Seiten."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πόσο μεγάλο μέρος της σελίδας μετακινεί ένα πάτημα Διαστήματος. Ισχύει για νεοφορτωμένες σελίδες."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuánta página avanza una pulsación de Espacio. Se aplica a las páginas recién cargadas."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuánta página avanza una pulsación de Espacio. Se aplica a las páginas recién cargadas."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuinka paljon sivua yksi Välilyönnin painallus hyppää. Koskee juuri ladattuja sivuja."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelle portion de la page un appui sur Espace fait défiler. S'applique aux pages nouvellement chargées."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Quelle portion de la page un appui sur Espace fait défiler. S'applique aux pages nouvellement chargées."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "כמה מהדף קופצת לחיצה אחת על רווח. חל על דפים שנטענו לאחרונה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Space का एक दबाव पृष्ठ का कितना हिस्सा कूदता है। हाल ही में लोड किए गए पृष्ठों पर लागू होता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Koliko stranice preskače jedan pritisak Razmaknice. Primjenjuje se na novoučitane stranice."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Mennyit ugrik az oldalon a Szóköz egy lenyomása. Az újonnan betöltött oldalakra vonatkozik."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Seberapa banyak halaman yang dilompati satu tekanan Spasi. Berlaku untuk halaman yang baru dimuat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanta pagina scorre una pressione di Spazio. Si applica alle pagine appena caricate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "スペースを1回押すとページがどれだけ移動するか。新しく読み込まれたページに適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "스페이스를 한 번 누르면 페이지가 얼마나 이동하는지. 새로 로드된 페이지에 적용됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Berapa banyak halaman yang dilompat oleh satu tekanan Space. Terpakai pada halaman yang baru dimuatkan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hvor mye av siden ett trykk på Mellomrom hopper. Gjelder nylig innlastede sider."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoeveel van de pagina één druk op Spatie springt. Geldt voor nieuw geladen pagina's."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jak dużą część strony przeskakuje jedno naciśnięcie Spacji. Dotyczy nowo załadowanych stron."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanto da página um toque de Espaço avança. Aplica-se a páginas recém-carregadas."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanto da página um toque de Espaço avança. Aplica-se a páginas recém-carregadas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Cât din pagină sare o apăsare de Spațiu. Se aplică paginilor nou încărcate."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Насколько прокручивается страница за одно нажатие «Пробел». Применяется к недавно загруженным страницам."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Akú veľkú časť stránky preskočí jedno stlačenie Medzerníka. Platí pre novo načítané stránky."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hur mycket av sidan en tryckning på Blanksteg hoppar. Gäller nyligen inlästa sidor."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การกด Space หนึ่งครั้งเลื่อนหน้าไปมากแค่ไหน ใช้กับหน้าที่โหลดใหม่"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Boşluk tuşuna bir basışın sayfanın ne kadarını atladığı. Yeni yüklenen sayfalara uygulanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Наскільки прокручується сторінка за одне натискання «Пробіл». Застосовується до нещодавно завантажених сторінок."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Một lần nhấn Dấu cách nhảy được bao nhiêu trang. Áp dụng cho các trang mới tải."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "按一次空白鍵捲動頁面的幅度。適用於新載入的頁面。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按一次空格滚动页面的幅度。适用于新加载的页面。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按一次空白鍵捲動頁面的幅度。適用於新載入的頁面。"
          }
        }
      }
    },
