    "The omnibar drops in over the page when you start typing an address. Top pins it to the toolbar; Upper floats it a third of the way down; Center puts it at eye level.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ينزل شريط العناوين فوق الصفحة عندما تبدأ بكتابة عنوان. أعلى يثبّته على شريط الأدوات؛ أعلى قليلًا يجعله يطفو عند ثلث الصفحة؛ الوسط يضعه عند مستوى العين."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "L'omnibar apareix sobre la pàgina quan comences a escriure una adreça. Dalt la fixa a la barra d'eines; Superior la fa flotar a un terç de la pàgina; Centre la col·loca a l'altura dels ulls."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibar sjede přes stránku, když začneš psát adresu. Nahoře ho připne k panelu nástrojů; Výše ho nechá vznášet v jedné třetině stránky; Uprostřed ho umístí do výše očí."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibaren falder ned over siden, når du begynder at skrive en adresse. Øverst fastgør den til værktøjslinjen; Højere lader den svæve en tredjedel nede; Midt placerer den i øjenhøjde."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Omnibar erscheint über der Seite, wenn du eine Adresse einzugeben beginnst. Oben heftet sie an die Symbolleiste; Höher lässt sie ein Drittel der Seite herabschweben; Mitte platziert sie auf Augenhöhe."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το omnibar κατεβαίνει πάνω από τη σελίδα όταν αρχίζεις να πληκτρολογείς μια διεύθυνση. Το Επάνω το καρφιτσώνει στη γραμμή εργαλείων· το Ψηλότερα το κάνει να αιωρείται στο ένα τρίτο της σελίδας· το Κέντρο το τοποθετεί στο ύψος των ματιών."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La omnibar aparece sobre la página cuando empiezas a escribir una dirección. Arriba la fija a la barra de herramientas; Superior la hace flotar a un tercio de la página; Centro la coloca a la altura de los ojos."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "La omnibar aparece sobre la página cuando empiezas a escribir una dirección. Arriba la fija a la barra de herramientas; Superior la hace flotar a un tercio de la página; Centro la coloca a la altura de los ojos."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnipalkki putoaa sivun päälle, kun alat kirjoittaa osoitetta. Ylhäällä kiinnittää sen työkalupalkkiin; Ylempänä antaa sen leijua kolmanneksen alaspäin; Keskellä asettaa sen silmien tasolle."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'omnibar apparaît par-dessus la page lorsque vous commencez à saisir une adresse. Haut l'épingle à la barre d'outils ; Supérieur la fait flotter au tiers de la page ; Centre la place au niveau des yeux."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "L'omnibar apparaît par-dessus la page lorsque vous commencez à saisir une adresse. Haut l'épingle à la barre d'outils ; Supérieur la fait flotter au tiers de la page ; Centre la place au niveau des yeux."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "שורת הכתובת יורדת מעל הדף כשאתה מתחיל להקליד כתובת. למעלה מצמידה אותה לסרגל הכלים; גבוה יותר גורם לה לרחף בשליש מהדף; מרכז ממקם אותה בגובה העיניים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जब आप कोई पता टाइप करना शुरू करते हैं तो ओमनीबार पृष्ठ के ऊपर आ जाता है। शीर्ष इसे टूलबार पर पिन करता है; ऊपर इसे पृष्ठ के एक-तिहाई नीचे तैराता है; केंद्र इसे आँख के स्तर पर रखता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibar se spušta preko stranice kada počneš tipkati adresu. Vrh ga pričvršćuje na alatnu traku; Gore ga pušta da lebdi na trećini stranice; Sredina ga stavlja u visinu očiju."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az omnibar leereszkedik az oldal fölé, amikor cím beírásába kezdesz. A Fent az eszköztárhoz rögzíti; a Feljebb az oldal harmadánál lebegteti; a Középen szemmagasságba helyezi."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibar turun di atas halaman saat kamu mulai mengetik alamat. Atas menyematkannya ke bilah alat; Lebih Atas membuatnya mengambang sepertiga ke bawah; Tengah menempatkannya setinggi mata."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'omnibar compare sopra la pagina quando inizi a digitare un indirizzo. In alto la fissa alla barra degli strumenti; Più in alto la fa fluttuare a un terzo della pagina; Centro la mette all'altezza degli occhi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アドレスの入力を始めると、オムニバーがページの上に降りてきます。「上」はツールバーに固定し、「やや上」はページの3分の1の位置に浮かせ、「中央」は目の高さに配置します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "주소를 입력하기 시작하면 옴니바가 페이지 위로 내려옵니다. 위는 도구 막대에 고정하고, 조금 위는 페이지의 3분의 1 지점에 띄우며, 가운데는 눈높이에 배치합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibar turun di atas halaman apabila anda mula menaip alamat. Atas menyematkannya pada bar alat; Lebih Atas membuatnya terapung satu pertiga ke bawah; Tengah meletakkannya setinggi mata."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibaren faller ned over siden når du begynner å skrive en adresse. Øverst fester den til verktøylinjen; Høyere lar den sveve en tredjedel ned; Midten plasserer den i øyehøyde."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De omnibalk verschijnt over de pagina wanneer je een adres begint te typen. Boven zet hem vast aan de werkbalk; Hoger laat hem een derde van de pagina zweven; Midden plaatst hem op ooghoogte."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibar zsuwa się na stronę, gdy zaczynasz wpisywać adres. Góra przypina go do paska narzędzi; Wyżej sprawia, że unosi się na jednej trzeciej wysokości; Środek umieszcza go na wysokości oczu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A omnibar surge sobre a página quando você começa a digitar um endereço. Topo a fixa na barra de ferramentas; Acima a faz flutuar a um terço da página; Centro a coloca na altura dos olhos."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A omnibar surge sobre a página quando você começa a digitar um endereço. Topo a fixa na barra de ferramentas; Acima a faz flutuar a um terço da página; Centro a coloca na altura dos olhos."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibarul coboară peste pagină când începi să tastezi o adresă. Sus îl fixează la bara de instrumente; Superior îl face să plutească la o treime în jos; Centru îl pune la nivelul ochilor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Омнибар опускается поверх страницы, когда вы начинаете вводить адрес. «Сверху» закрепляет его на панели инструментов; «Выше» заставляет его парить на трети страницы; «По центру» помещает на уровне глаз."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibar zíde cez stránku, keď začneš písať adresu. Hore ho pripne k panelu nástrojov; Vyššie ho nechá vznášať v jednej tretine stránky; V strede ho umiestni do výšky očí."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibaren faller ner över sidan när du börjar skriva en adress. Överst fäster den vid verktygsfältet; Högre låter den sväva en tredjedel ner; Mitten placerar den i ögonhöjd."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ออมนิบาร์จะลงมาทับหน้าเมื่อคุณเริ่มพิมพ์ที่อยู่ บนสุดจะปักหมุดไว้ที่แถบเครื่องมือ ด้านบนจะทำให้ลอยอยู่ที่หนึ่งในสามลงมา ตรงกลางจะวางไว้ที่ระดับสายตา"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir adres yazmaya başladığında omnibar sayfanın üzerine iner. Üst onu araç çubuğuna sabitler; Yukarısı sayfanın üçte biri kadar aşağıda yüzdürür; Orta onu göz hizasına yerleştirir."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Омнібар опускається поверх сторінки, коли ви починаєте вводити адресу. «Угорі» закріплює його на панелі інструментів; «Вище» змушує його ширяти на третині сторінки; «По центру» розміщує на рівні очей."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Omnibar thả xuống trên trang khi bạn bắt đầu gõ một địa chỉ. Trên cùng ghim nó vào thanh công cụ; Cao hơn để nó lơ lửng ở một phần ba trang; Giữa đặt nó ở tầm mắt."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "當你開始輸入位址時，網址列會落到頁面上方。「頂部」將其固定在工具列；「上方」讓它懸浮在頁面三分之一處；「置中」將其置於視線高度。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当你开始输入地址时，地址栏会落到页面上方。“顶部”将其固定在工具栏；“上方”让它悬浮在页面三分之一处；“居中”将其置于视线高度。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當你開始輸入位址時，網址列會落到頁面上方。「頂部」將其固定在工具列；「上方」讓它懸浮在頁面三分之一處；「置中」將其置於視線高度。"
          }
        }
      }
    },
    "The simplest way to use the internet — here's everything you need to get browsing.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أبسط طريقة لاستخدام الإنترنت — إليك كل ما تحتاجه لبدء التصفح."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La manera més senzilla d'utilitzar internet — aquí tens tot el que necessites per començar a navegar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nejjednodušší způsob, jak používat internet — tady je vše, co potřebuješ k tomu, abys začal prohlížet."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Den enkleste måde at bruge internettet på — her er alt, hvad du behøver for at komme i gang med at browse."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der einfachste Weg, das Internet zu nutzen – hier ist alles, was du zum Losbrowsen brauchst."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ο απλούστερος τρόπος να χρησιμοποιείς το διαδίκτυο — εδώ είναι όλα όσα χρειάζεσαι για να ξεκινήσεις την περιήγηση."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La forma más sencilla de usar Internet: aquí tienes todo lo que necesitas para empezar a navegar."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "La forma más sencilla de usar Internet: aquí tienes todo lo que necesitas para empezar a navegar."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Yksinkertaisin tapa käyttää internetiä — tässä on kaikki, mitä tarvitset selaamisen aloittamiseen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La façon la plus simple d'utiliser Internet — voici tout ce dont vous avez besoin pour commencer à naviguer."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "La façon la plus simple d'utiliser Internet — voici tout ce dont vous avez besoin pour commencer à naviguer."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הדרך הפשוטה ביותר להשתמש באינטרנט — הנה כל מה שאתה צריך כדי להתחיל לגלוש."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इंटरनेट उपयोग करने का सबसे सरल तरीका — ब्राउज़िंग शुरू करने के लिए आपको जो कुछ चाहिए वह यहाँ है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Najjednostavniji način korištenja interneta — ovdje je sve što ti treba da počneš pregledavati."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A legegyszerűbb módja az internet használatának — itt van minden, amire szükséged van a böngészés megkezdéséhez."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Cara paling sederhana menggunakan internet — inilah semua yang kamu butuhkan untuk mulai menjelajah."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il modo più semplice di usare Internet: ecco tutto ciò che ti serve per iniziare a navigare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "インターネットを使う最もシンプルな方法。ブラウジングを始めるのに必要なものすべてがここにあります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인터넷을 사용하는 가장 간단한 방법 — 브라우징을 시작하는 데 필요한 모든 것이 여기 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Cara paling mudah menggunakan internet — inilah semua yang anda perlukan untuk mula melayari."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Den enkleste måten å bruke internett på — her er alt du trenger for å begynne å surfe."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De eenvoudigste manier om internet te gebruiken — hier is alles wat je nodig hebt om te gaan browsen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Najprostszy sposób korzystania z internetu — oto wszystko, czego potrzebujesz, aby zacząć przeglądać."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A maneira mais simples de usar a internet — aqui está tudo o que você precisa para começar a navegar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A maneira mais simples de usar a internet — aqui está tudo o que você precisa para começar a navegar."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Cel mai simplu mod de a folosi internetul — iată tot ce ai nevoie ca să începi să navighezi."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Самый простой способ пользоваться интернетом — здесь всё, что нужно, чтобы начать сёрфинг."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Najjednoduchší spôsob, ako používať internet — tu je všetko, čo potrebuješ na to, aby si začal prehliadať."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Det enklaste sättet att använda internet — här är allt du behöver för att börja surfa."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "วิธีที่ง่ายที่สุดในการใช้อินเทอร์เน็ต — นี่คือทุกอย่างที่คุณต้องการเพื่อเริ่มเรียกดู"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İnterneti kullanmanın en basit yolu — göz atmaya başlaman için ihtiyacın olan her şey burada."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Найпростіший спосіб користуватися інтернетом — тут усе, що потрібно, щоб почати перегляд."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cách đơn giản nhất để dùng internet — đây là tất cả những gì bạn cần để bắt đầu duyệt."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "使用網際網路最簡單的方式——你開始瀏覽所需的一切都在這裡。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用互联网最简单的方式——你开始浏览所需的一切都在这里。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用網際網路最簡單的方式——你開始瀏覽所需的一切都在這裡。"
          }
        }
      }
    },
    "The tab bar has several sizes — toggle it with ⇧⌘L or pick a style from the View menu.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لشريط علامات التبويب عدة أحجام — بدّله بـ ⇧⌘L أو اختر نمطًا من قائمة عرض."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La barra de pestanyes té diverses mides — commuta-la amb ⇧⌘L o tria un estil del menú Visualització."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Lišta karet má několik velikostí — přepni ji pomocí ⇧⌘L nebo vyber styl z nabídky Zobrazit."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Fanebladslinjen har flere størrelser — skift den med ⇧⌘L, eller vælg en stil i menuen Vis."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Tableiste hat mehrere Größen – schalte sie mit ⇧⌘L um oder wähle einen Stil im Menü Darstellung."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η γραμμή καρτελών έχει διάφορα μεγέθη — εναλλάξέ την με ⇧⌘L ή επίλεξε ένα στιλ από το μενού Προβολή."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La barra de pestañas tiene varios tamaños: cámbiala con ⇧⌘L o elige un estilo en el menú Visualización."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "La barra de pestañas tiene varios tamaños: cámbiala con ⇧⌘L o elige un estilo en el menú Visualización."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Välilehtipalkissa on useita kokoja — vaihda sitä painamalla ⇧⌘L tai valitse tyyli Näytä-valikosta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La barre d'onglets a plusieurs tailles — basculez-la avec ⇧⌘L ou choisissez un style dans le menu Présentation."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "La barre d'onglets a plusieurs tailles — basculez-la avec ⇧⌘L ou choisissez un style dans le menu Présentation."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לסרגל הכרטיסיות כמה גדלים — החלף אותו עם ⇧⌘L או בחר סגנון מתפריט תצוגה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "टैब बार के कई आकार हैं — इसे ⇧⌘L से टॉगल करें या दृश्य मेन्यू से एक शैली चुनें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Traka kartica ima nekoliko veličina — prebaci je pomoću ⇧⌘L ili odaberi stil iz izbornika Prikaz."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A lapsávnak több mérete van — kapcsold át ⇧⌘L-lel, vagy válassz stílust a Nézet menüből."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Bilah tab memiliki beberapa ukuran — alihkan dengan ⇧⌘L atau pilih gaya dari menu Tampilan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La barra delle schede ha diverse dimensioni: attivala con ⇧⌘L o scegli uno stile dal menu Vista."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タブバーには複数のサイズがあります。⇧⌘Lで切り替えるか、表示メニューからスタイルを選択します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "탭 막대에는 여러 크기가 있습니다. ⇧⌘L로 전환하거나 보기 메뉴에서 스타일을 선택하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Bar tab mempunyai beberapa saiz — togolnya dengan ⇧⌘L atau pilih gaya daripada menu Papar."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Fanelinjen har flere størrelser — veksle den med ⇧⌘L, eller velg en stil i Vis-menyen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De tabbalk heeft meerdere formaten — schakel hem met ⇧⌘L of kies een stijl in het menu Weergave."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasek kart ma kilka rozmiarów — przełącz go za pomocą ⇧⌘L lub wybierz styl w menu Widok."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A barra de abas tem vários tamanhos — alterne-a com ⇧⌘L ou escolha um estilo no menu Visualizar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A barra de abas tem vários tamanhos — alterne-a com ⇧⌘L ou escolha um estilo no menu Visualizar."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Bara de file are mai multe dimensiuni — comut-o cu ⇧⌘L sau alege un stil din meniul Vizualizare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У панели вкладок несколько размеров — переключайте её с помощью ⇧⌘L или выберите стиль в меню «Вид»."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Lišta kariet má niekoľko veľkostí — prepni ju pomocou ⇧⌘L alebo vyber štýl z ponuky Zobraziť."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Flikfältet har flera storlekar — växla det med ⇧⌘L eller välj en stil i menyn Visa."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แถบแท็บมีหลายขนาด — สลับด้วย ⇧⌘L หรือเลือกสไตล์จากเมนูมุมมอง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sekme çubuğunun birkaç boyutu vardır — ⇧⌘L ile değiştir ya da Görünüm menüsünden bir stil seç."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Панель вкладок має кілька розмірів — перемикайте її за допомогою ⇧⌘L або виберіть стиль у меню «Вигляд»."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thanh thẻ có nhiều kích thước — bật/tắt bằng ⇧⌘L hoặc chọn một kiểu từ menu Xem."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "分頁列有多種大小——用 ⇧⌘L 切換，或從「顯示方式」選單選擇一種樣式。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "标签栏有多种大小——用 ⇧⌘L 切换，或从“显示”菜单选择一种样式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "分頁列有多種大小——用 ⇧⌘L 切換，或從「顯示方式」選單選擇一種樣式。"
          }
        }
      }
    },
