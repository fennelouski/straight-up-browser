    "Off makes pages static. Applies to newly loaded pages.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الإيقاف يجعل الصفحات ثابتة. ينطبق على الصفحات المحمَّلة حديثًا."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactivat fa que les pàgines siguin estàtiques. S'aplica a les pàgines acabades de carregar."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vypnuto činí stránky statickými. Platí pro nově načtené stránky."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Fra gør sider statiske. Gælder for nyligt indlæste sider."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aus macht Seiten statisch. Gilt für neu geladene Seiten."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το Ανενεργό κάνει τις σελίδες στατικές. Ισχύει για νεοφορτωμένες σελίδες."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactivado hace las páginas estáticas. Se aplica a las páginas recién cargadas."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactivado hace las páginas estáticas. Se aplica a las páginas recién cargadas."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Pois tekee sivuista staattisia. Koskee juuri ladattuja sivuja."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactivé rend les pages statiques. S'applique aux pages nouvellement chargées."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactivé rend les pages statiques. S'applique aux pages nouvellement chargées."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "כבוי הופך דפים לסטטיים. חל על דפים שנטענו לאחרונה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "बंद पृष्ठों को स्थिर बनाता है। हाल ही में लोड किए गए पृष्ठों पर लागू होता है।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Isključeno čini stranice statičnima. Primjenjuje se na novoučitane stranice."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A Ki statikussá teszi az oldalakat. Az újonnan betöltött oldalakra vonatkozik."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Mati membuat halaman statis. Berlaku untuk halaman yang baru dimuat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disattivato rende le pagine statiche. Si applica alle pagine appena caricate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフにするとページは静的になります。新しく読み込まれたページに適用されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "끄면 페이지가 정적으로 됩니다. 새로 로드된 페이지에 적용됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Mati menjadikan halaman statik. Terpakai pada halaman yang baru dimuatkan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Av gjør sider statiske. Gjelder nylig innlastede sider."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uit maakt pagina's statisch. Geldt voor nieuw geladen pagina's."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wył. czyni strony statycznymi. Dotyczy nowo załadowanych stron."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desativado torna as páginas estáticas. Aplica-se a páginas recém-carregadas."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Desativado torna as páginas estáticas. Aplica-se a páginas recém-carregadas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Dezactivat face paginile statice. Se aplică paginilor nou încărcate."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«Выкл.» делает страницы статичными. Применяется к недавно загруженным страницам."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vypnuté robí stránky statickými. Platí pre novo načítané stránky."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Av gör sidor statiska. Gäller nyligen inlästa sidor."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปิดทำให้หน้าเป็นแบบสถิต ใช้กับหน้าที่โหลดใหม่"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kapalı, sayfaları statik yapar. Yeni yüklenen sayfalara uygulanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "«Вимк.» робить сторінки статичними. Застосовується до нещодавно завантажених сторінок."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tắt làm cho trang tĩnh. Áp dụng cho các trang mới tải."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "「關閉」會使頁面變為靜態。適用於新載入的頁面。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“关”会使页面变为静态。适用于新加载的页面。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「關閉」會使頁面變為靜態。適用於新載入的頁面。"
          }
        }
      }
    },
