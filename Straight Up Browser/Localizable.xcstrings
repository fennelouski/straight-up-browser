          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Rendszer követi a Mac megjelenését — és vele együtt vált."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sistem mengikuti tampilan Mac-mu — dan beralih dengannya."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sistema segue l'aspetto del tuo Mac e cambia con esso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
