    "The click is synthetic, and pages that require a genuine user gesture ignore it.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "النقرة اصطناعية، والصفحات التي تتطلب إيماءة مستخدم حقيقية تتجاهلها."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El clic és sintètic, i les pàgines que requereixen un gest genuí de l'usuari l'ignoren."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknutí je syntetické a stránky, které vyžadují opravdové uživatelské gesto, ho ignorují."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Klikket er syntetisk, og sider, der kræver en ægte brugerhandling, ignorerer det."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Klick ist synthetisch, und Seiten, die eine echte Nutzergeste erfordern, ignorieren ihn."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το κλικ είναι συνθετικό, και οι σελίδες που απαιτούν μια γνήσια χειρονομία χρήστη το αγνοούν."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El clic es sintético, y las páginas que requieren un gesto genuino del usuario lo ignoran."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El clic es sintético, y las páginas que requieren un gesto genuino del usuario lo ignoran."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Napsautus on synteettinen, ja sivut, jotka vaativat aidon käyttäjän eleen, jättävät sen huomiotta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le clic est synthétique, et les pages qui exigent un véritable geste utilisateur l'ignorent."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Le clic est synthétique, et les pages qui exigent un véritable geste utilisateur l'ignorent."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הלחיצה סינתטית, ודפים הדורשים מחווה אמיתית של משתמש מתעלמים ממנה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्लिक कृत्रिम है, और जो पृष्ठ वास्तविक उपयोगकर्ता इशारा माँगते हैं वे इसे अनदेखा करते हैं।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik je sintetički, a stranice koje zahtijevaju pravu korisničku gestu ga zanemaruju."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kattintás szintetikus, és az oldalak, amelyek valódi felhasználói gesztust igényelnek, figyelmen kívül hagyják."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik bersifat sintetis, dan halaman yang memerlukan gerakan pengguna asli mengabaikannya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il clic è sintetico e le pagine che richiedono un vero gesto dell'utente lo ignorano."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリックは合成的で、本物のユーザー操作を必要とするページはそれを無視します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클릭은 합성이며, 진짜 사용자 제스처를 요구하는 페이지는 이를 무시합니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik bersifat sintetik, dan halaman yang memerlukan gerak isyarat pengguna tulen mengabaikannya."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Klikket er syntetisk, og sider som krever en ekte brukerhandling, ignorerer det."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De klik is synthetisch, en pagina's die een echt gebruikersgebaar vereisen, negeren hem."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknięcie jest syntetyczne, a strony wymagające autentycznego gestu użytkownika ignorują je."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O clique é sintético, e páginas que exigem um gesto genuíno do usuário o ignoram."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O clique é sintético, e páginas que exigem um gesto genuíno do usuário o ignoram."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Clicul este sintetic, iar paginile care necesită un gest autentic al utilizatorului îl ignoră."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Щелчок синтетический, и страницы, требующие настоящего жеста пользователя, его игнорируют."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknutie je syntetické a stránky, ktoré vyžadujú skutočné používateľské gesto, ho ignorujú."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicket är syntetiskt, och sidor som kräver en äkta användargest ignorerar det."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การคลิกเป็นแบบสังเคราะห์ และหน้าที่ต้องการท่าทางผู้ใช้จริงจะเพิกเฉยต่อมัน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tıklama sentetiktir ve gerçek bir kullanıcı hareketi gerektiren sayfalar onu yok sayar."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Клік синтетичний, і сторінки, що потребують справжнього жесту користувача, його ігнорують."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cú nhấp là tổng hợp, và các trang yêu cầu một cử chỉ thật của người dùng sẽ bỏ qua nó."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "點按是合成的，需要真實使用者手勢的頁面會忽略它。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击是合成的，需要真实用户手势的页面会忽略它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點按是合成的，需要真實使用者手勢的頁面會忽略它。"
          }
        }
      }
    },
    "The click posts a real mouse event — it counts as a user gesture, so video plays and pop-ups open.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "النقرة ترسل حدث فأرة حقيقيًا — يُحتسب كإيماءة مستخدم، لذا يُشغَّل الفيديو وتُفتح النوافذ المنبثقة."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "El clic envia un esdeveniment de ratolí real — compta com a gest de l'usuari, així que el vídeo es reprodueix i les finestres emergents s'obren."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknutí odešle skutečnou událost myši — počítá se jako uživatelské gesto, takže se přehraje video a otevřou se vyskakovací okna."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Klikket sender en rigtig musehændelse — det tæller som en brugerhandling, så video afspilles, og pop op-vinduer åbnes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Klick sendet ein echtes Mausereignis – es zählt als Nutzergeste, sodass Videos abgespielt und Pop-ups geöffnet werden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το κλικ στέλνει ένα πραγματικό συμβάν ποντικιού — μετρά ως χειρονομία χρήστη, οπότε τα βίντεο αναπαράγονται και τα αναδυόμενα ανοίγουν."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El clic envía un evento de ratón real: cuenta como gesto del usuario, así que el vídeo se reproduce y las ventanas emergentes se abren."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El clic envía un evento de ratón real: cuenta como gesto del usuario, así que el vídeo se reproduce y las ventanas emergentes se abren."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Napsautus lähettää todellisen hiiritapahtuman — se lasketaan käyttäjän eleeksi, joten video toistuu ja ponnahdusikkunat avautuvat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le clic envoie un vrai événement de souris — il compte comme un geste utilisateur, donc la vidéo se lance et les fenêtres pop-up s'ouvrent."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "Le clic envoie un vrai événement de souris — il compte comme un geste utilisateur, donc la vidéo se lance et les fenêtres pop-up s'ouvrent."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הלחיצה שולחת אירוע עכבר אמיתי — הוא נחשב כמחוות משתמש, כך שווידאו מתנגן וחלונות קופצים נפתחים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्लिक एक वास्तविक माउस घटना भेजता है — यह उपयोगकर्ता इशारे के रूप में गिना जाता है, इसलिए वीडियो चलता है और पॉप-अप खुलते हैं।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik šalje pravi događaj miša — broji se kao korisnička gesta, pa se videozapis reproducira i skočni prozori otvaraju."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A kattintás valódi egéreseményt küld — felhasználói gesztusnak számít, így a videó lejátszódik, és a felugró ablakok megnyílnak."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik mengirim peristiwa mouse nyata — dihitung sebagai gerakan pengguna, jadi video diputar dan pop-up terbuka."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il clic invia un vero evento del mouse: conta come gesto dell'utente, quindi i video vengono riprodotti e i pop-up si aprono."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クリックは本物のマウスイベントを送信します。ユーザー操作として数えられるため、動画が再生され、ポップアップが開きます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클릭은 진짜 마우스 이벤트를 보냅니다. 사용자 제스처로 계산되므로 동영상이 재생되고 팝업이 열립니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik menghantar peristiwa tetikus sebenar — ia dikira sebagai gerak isyarat pengguna, jadi video dimainkan dan pop timbul dibuka."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Klikket sender en ekte musehendelse — det teller som en brukerhandling, så video spilles av og forgrunnsvinduer åpnes."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De klik stuurt een echte muisgebeurtenis — het telt als gebruikersgebaar, dus video speelt af en pop-ups openen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknięcie wysyła prawdziwe zdarzenie myszy — liczy się jako gest użytkownika, więc wideo się odtwarza, a wyskakujące okienka się otwierają."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O clique envia um evento de mouse real — conta como gesto do usuário, então o vídeo toca e os pop-ups abrem."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O clique envia um evento de mouse real — conta como gesto do usuário, então o vídeo toca e os pop-ups abrem."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Clicul trimite un eveniment de mouse real — contează drept gest al utilizatorului, așa că videoclipul rulează și ferestrele pop-up se deschid."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Щелчок отправляет реальное событие мыши — оно засчитывается как жест пользователя, поэтому видео воспроизводится и всплывающие окна открываются."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Kliknutie odošle skutočnú udalosť myši — počíta sa ako používateľské gesto, takže sa prehrá video a otvoria sa vyskakovacie okná."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Klicket skickar en riktig mushändelse — det räknas som en användargest, så video spelas upp och popup-fönster öppnas."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การคลิกส่งเหตุการณ์เมาส์จริง — นับเป็นท่าทางผู้ใช้ ดังนั้นวิดีโอจะเล่นและป๊อปอัปจะเปิด"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tıklama gerçek bir fare olayı gönderir — kullanıcı hareketi olarak sayılır, böylece video oynatılır ve açılır pencereler açılır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Клік надсилає справжню подію миші — вона зараховується як жест користувача, тож відео відтворюється і спливні вікна відкриваються."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cú nhấp gửi một sự kiện chuột thật — nó được tính là cử chỉ của người dùng, nên video phát và cửa sổ bật lên mở ra."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "點按會傳送真實的滑鼠事件——它算作使用者手勢，因此影片會播放，彈出視窗會打開。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击会发送真实的鼠标事件——它算作用户手势，因此视频会播放，弹出窗口会打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點按會傳送真實的滑鼠事件——它算作使用者手勢，因此影片會播放，彈出視窗會打開。"
          }
        }
      }
    },
