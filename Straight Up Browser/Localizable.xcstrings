        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ภาพทั้งหน้ายังคงเป็นเวกเตอร์ — ข้อความยังเลือกได้ ส่วนภาพแบบอื่นจะกลายเป็น PDF หน้าเดียวของภาพนั้น"
          }
        },
        "tr" : {
          "stringUnit" : {
