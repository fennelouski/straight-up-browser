    "Memory runs low → the tab is released from RAM": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تنخفض الذاكرة ← تُحرَّر علامة التبويب من ذاكرة الوصول العشوائي"
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La memòria s'esgota → la pestanya s'allibera de la RAM"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Dochází paměť → karta je uvolněna z RAM"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hukommelsen er ved at slippe op → fanebladet frigives fra RAM"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Speicher wird knapp → der Tab wird aus dem RAM freigegeben"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η μνήμη τελειώνει → η καρτέλα απελευθερώνεται από τη RAM"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La memoria se agota → la pestaña se libera de la RAM"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "La memoria se agota → la pestaña se libera de la RAM"
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Muisti käy vähiin → välilehti vapautetaan RAM-muistista"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La mémoire est faible → l'onglet est libéré de la RAM"
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "La mémoire est faible → l'onglet est libéré de la RAM"
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הזיכרון אוזל ← הכרטיסייה משוחררת מ-RAM"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मेमोरी कम हो रही है → टैब को RAM से जारी किया गया"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Memorija ponestaje → kartica se oslobađa iz RAM-a"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A memória fogy → a lap felszabadul a RAM-ból"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Memori menipis → tab dilepaskan dari RAM"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La memoria si sta esaurendo → la scheda viene rilasciata dalla RAM"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メモリが不足 → タブがRAMから解放される"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메모리가 부족함 → 탭이 RAM에서 해제됨"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Memori semakin kurang → tab dilepaskan daripada RAM"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Minnet begynner å bli lite → fanen frigis fra RAM"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het geheugen raakt op → het tabblad wordt uit RAM vrijgegeven"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pamięć się kończy → karta zostaje zwolniona z RAM"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A memória está acabando → a aba é liberada da RAM"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A memória está acabando → a aba é liberada da RAM"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Memoria se termină → fila este eliberată din RAM"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Память заканчивается → вкладка выгружается из ОЗУ"
