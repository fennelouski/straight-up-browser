    "Wipes all cookies, cache, and storage in the current tab’s session. This can’t be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمسح كل ملفات تعريف الارتباط والذاكرة المؤقتة والتخزين في جلسة علامة التبويب الحالية. لا يمكن التراجع عن ذلك."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esborra totes les galetes, la memòria cau i l'emmagatzematge de la sessió de la pestanya actual. Això no es pot desfer."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Smaže všechny cookies, mezipaměť a úložiště v relaci aktuální karty. Nelze vzít zpět."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sletter alle cookies, cache og lager i det aktuelle fanebladets session. Det kan ikke fortrydes."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Löscht alle Cookies, den Cache und den Speicher in der Sitzung des aktuellen Tabs. Das lässt sich nicht rückgängig machen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Σβήνει όλα τα cookies, την προσωρινή μνήμη και την αποθήκευση στη συνεδρία της τρέχουσας καρτέλας. Δεν αναιρείται."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Borra todas las cookies, la caché y el almacenamiento de la sesión de la pestaña actual. Esto no se puede deshacer."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Borra todas las cookies, la caché y el almacenamiento de la sesión de la pestaña actual. Esto no se puede deshacer."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pyyhkii kaikki evästeet, välimuistin ja tallennustilan nykyisen välilehden istunnosta. Tätä ei voi kumota."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Efface tous les cookies, le cache et le stockage de la session de l'onglet actuel. Cette action est irréversible."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Efface tous les cookies, le cache et le stockage de la session de l'onglet actuel. Cette action est irréversible."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "מוחק את כל העוגיות, המטמון והאחסון בהפעלה של הכרטיסייה הנוכחית. אי אפשר לבטל את הפעולה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "मौजूदा टैब के सत्र की सारी कुकीज़, कैश और संग्रहण मिटा देता है। इसे पहले जैसा नहीं किया जा सकता।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Briše sve kolačiće, predmemoriju i pohranu u sesiji trenutne kartice. Ovo se ne može poništiti."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Törli az összes sütit, gyorsítótárat és tárolót az aktuális lap munkamenetében. Ez nem vonható vissza."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Menghapus semua cookie, cache, dan penyimpanan pada sesi tab kini. Ini tidak bisa dibatalkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cancella tutti i cookie, la cache e l'archiviazione nella sessione della scheda attuale. L'operazione non può essere annullata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在のタブのセッションにある Cookie、キャッシュ、ストレージをすべて消去します。この操作は取り消せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 탭 세션의 쿠키, 캐시, 저장소를 모두 지웁니다. 이 작업은 되돌릴 수 없습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Memadam semua kuki, cache dan storan dalam sesi tab semasa. Ini tidak boleh dibuat asal."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sletter alle informasjonskapsler, buffere og lagring i økten til den aktive fanen. Dette kan ikke angres."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wist alle cookies, cache en opslag in de sessie van het huidige tabblad. Dit kan niet ongedaan worden gemaakt."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kasuje wszystkie ciasteczka, pamięć podręczną i magazyn w sesji bieżącej karty. Tego nie można cofnąć."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apaga todos os cookies, cache e armazenamento na sessão da aba atual. Isso não pode ser desfeito."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apaga todos os cookies, cache e armazenamento na sessão da aba atual. Isso não pode ser desfeito."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Șterge toate cookie-urile, cache-ul și stocarea din sesiunea filei curente. Această acțiune nu poate fi anulată."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Стирает все файлы cookie, кэш и хранилище в сеансе текущей вкладки. Это действие необратимо."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vymaže všetky cookies, vyrovnávaciu pamäť a úložisko v relácii aktuálnej karty. Nedá sa vrátiť späť."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Raderar alla cookies, cache och lagring i den aktuella flikens session. Det går inte att ångra."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ล้างคุกกี้ แคช และที่จัดเก็บข้อมูลทั้งหมดในเซสชั่นของแท็บปัจจุบัน การกระทำนี้ย้อนกลับไม่ได้"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geçerli sekmenin oturumundaki tüm çerezleri, önbelleği ve depolamayı siler. Bu geri alınamaz."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Стирає всі файли cookie, кеш і сховище в сеансі поточної вкладки. Цю дію не можна скасувати."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Xóa sạch mọi cookie, bộ nhớ đệm và bộ nhớ lưu trữ trong phiên của thẻ hiện tại. Không thể hoàn tác."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "抹掉当前标签页会话中的所有 Cookie、缓存和存储。此操作无法撤销。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "抹除目前分頁工作階段中的所有 Cookie、快取與儲存空間。此操作無法還原。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "抹除目前分頁工作階段中的所有 Cookie、快取與儲存空間。此操作無法還原。"
          }
        }
      }
    },
    "With a split open, ⌘S normally shoots just the pane you're working in. Switch it to every pane and you get the whole content area — all panes side by side, still without the tab bar." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مع فتح تقسيم، يصوّر ⌘S عادةً اللوح الذي تعمل فيه فقط. بدّله إلى كل لوح وستحصل على منطقة المحتوى كاملة — كل الألواح جنبًا إلى جنب، وما زال دون شريط علامات التبويب."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amb una divisió oberta, ⌘S normalment captura només la subfinestra on treballes. Canvia-ho a totes les subfinestres i obtindràs tota l'àrea de contingut: totes les subfinestres una al costat de l'altra, encara sense la barra de pestanyes."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Při otevřeném rozdělení zachytí ⌘S obvykle jen panel, ve kterém pracuješ. Přepni na všechny panely a dostaneš celou oblast obsahu – všechny panely vedle sebe, pořád bez lišty karet."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Med en opdeling åben tager ⌘S normalt kun den rude, du arbejder i. Skift den til alle ruder, og du får hele indholdsområdet – alle ruder side om side, stadig uden fanebladslinjen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bei offener Teilung nimmt ⌘S normalerweise nur den Bereich auf, in dem du arbeitest. Stell es auf alle Bereiche um, und du bekommst den ganzen Inhaltsbereich – alle Bereiche nebeneinander, weiterhin ohne Tableiste."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Με ανοιχτή διαίρεση, το ⌘S κανονικά καταγράφει μόνο το τμήμα στο οποίο δουλεύεις. Άλλαξέ το σε όλα τα τμήματα και παίρνεις ολόκληρη την περιοχή περιεχομένου — όλα τα τμήματα δίπλα δίπλα, πάλι χωρίς τη γραμμή καρτελών."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con una división abierta, ⌘S normalmente captura solo el panel en el que trabajas. Cámbialo a todos los paneles y obtendrás toda el área de contenido: todos los paneles lado a lado, aún sin la barra de pestañas."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con una división abierta, ⌘S normalmente captura solo el panel en el que trabajas. Cámbialo a todos los paneles y obtendrás toda el área de contenido: todos los paneles lado a lado, aún sin la barra de pestañas."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun jakonäkymä on auki, ⌘S kaappaa yleensä vain ruudun, jossa työskentelet. Vaihda se kaikkiin ruutuihin, niin saat koko sisältöalueen – kaikki ruudut rinnakkain, edelleen ilman välilehtipalkkia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avec une vue divisée ouverte, ⌘S ne capture normalement que le volet dans lequel vous travaillez. Passez sur tous les volets et vous obtenez toute la zone de contenu — tous les volets côte à côte, toujours sans la barre d'onglets."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avec une vue divisée ouverte, ⌘S ne capture normalement que le volet dans lequel vous travaillez. Passez sur tous les volets et vous obtenez toute la zone de contenu — tous les volets côte à côte, toujours sans la barre d'onglets."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "כשפיצול פתוח, ⌘S מצלם בדרך כלל רק את החלונית שבה אתה עובד. העבר אותו לכל החלוניות ותקבל את כל אזור התוכן — כל החלוניות זו לצד זו, ועדיין בלי סרגל הכרטיסיות."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "विभाजन खुला हो तो ⌘S आम तौर पर सिर्फ़ उसी फलक को लेता है जिसमें आप काम कर रहे हैं। इसे हर फलक पर कर दें तो पूरा सामग्री क्षेत्र मिलता है — सभी फलक साथ-साथ, फिर भी टैब बार के बिना।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dok je podjela otvorena, ⌘S obično snima samo okno u kojem radiš. Prebaci na sva okna i dobit ćeš cijelo područje sadržaja – sva okna jedno uz drugo, i dalje bez trake kartica."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nyitott osztott nézetben a ⌘S rendes esetben csak azt a panelt rögzíti, amelyikben dolgozol. Állítsd minden panelre, és megkapod a teljes tartalomterületet – az összes panelt egymás mellett, továbbra is lapsáv nélkül."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dengan pembagian terbuka, ⌘S biasanya hanya memotret panel tempat Anda bekerja. Ubah ke setiap panel dan Anda mendapat seluruh area konten — semua panel berdampingan, tetap tanpa bilah tab."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con una vista divisa aperta, ⌘S normalmente acquisisce solo il riquadro in cui stai lavorando. Passa a tutti i riquadri e ottieni l'intera area dei contenuti: tutti i riquadri affiancati, sempre senza la barra delle schede."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分割中、⌘S は通常、作業中のペインだけを撮ります。すべてのペインに切り替えると、コンテンツ領域全体（並んだすべてのペイン）が得られます。タブバーは変わらず含まれません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "분할이 열려 있으면 ⌘S는 보통 작업 중인 패널만 찍습니다. 모든 패널로 바꾸면 콘텐츠 영역 전체 — 나란히 놓인 모든 패널 — 을 얻고, 탭 막대는 여전히 빠집니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dengan pembahagian dibuka, ⌘S biasanya merakam hanya anak tetingkap tempat anda bekerja. Tukar kepada setiap anak tetingkap dan anda mendapat seluruh kawasan kandungan — semua anak tetingkap bersebelahan, masih tanpa bar tab."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Med en deling åpen tar ⌘S normalt bare ruten du jobber i. Bytt den til alle ruter, så får du hele innholdsområdet – alle ruter side om side, fortsatt uten fanelinjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Met een splitsing open legt ⌘S normaal alleen het deelvenster vast waarin je werkt. Zet het op elk deelvenster en je krijgt het hele inhoudsgebied – alle deelvensters naast elkaar, nog steeds zonder tabbladbalk."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przy otwartym podziale ⌘S rejestruje zwykle tylko panel, w którym pracujesz. Przełącz na wszystkie panele, a dostaniesz cały obszar treści — wszystkie panele obok siebie, wciąż bez paska kart."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Com uma divisão aberta, ⌘S normalmente captura só o painel em que você está trabalhando. Mude para todos os painéis e você recebe toda a área de conteúdo — todos os painéis lado a lado, ainda sem a barra de abas."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Com uma divisão aberta, ⌘S normalmente captura só o painel em que você está trabalhando. Mude para todos os painéis e você recebe toda a área de conteúdo — todos os painéis lado a lado, ainda sem a barra de abas."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cu o divizare deschisă, ⌘S capturează în mod normal doar panoul în care lucrezi. Comută pe toate panourile și obții întreaga zonă de conținut — toate panourile alăturate, tot fără bara de file."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "При открытом разделении ⌘S обычно снимает только ту панель, в которой вы работаете. Переключите на все панели — и получите всю область содержимого: все панели рядом, по-прежнему без панели вкладок."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pri otvorenom rozdelení zachytí ⌘S zvyčajne len panel, v ktorom pracuješ. Prepni na všetky panely a dostaneš celú oblasť obsahu – všetky panely vedľa seba, stále bez lišty kariet."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Med en delning öppen fångar ⌘S normalt bara rutan du arbetar i. Ställ om det till alla rutor så får du hela innehållsytan – alla rutor sida vid sida, fortfarande utan flikfältet."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เมื่อเปิดการแบ่งหน้าจออยู่ ปกติ ⌘S จะถ่ายเฉพาะบานที่คุณกำลังใช้ เปลี่ยนเป็นทุกบานแล้วคุณจะได้พื้นที่เนื้อหาทั้งหมด — ทุกบานเรียงกัน โดยยังไม่มีแถบแท็บ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir bölme açıkken ⌘S normalde yalnızca çalıştığınız paneli çeker. Her panele geçirin, tüm içerik alanını alın — bütün paneller yan yana, yine sekme çubuğu olmadan."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "За відкритого розділення ⌘S зазвичай знімає лише ту панель, у якій ви працюєте. Перемкніть на всі панелі — і отримаєте всю область вмісту: усі панелі поруч, так само без панелі вкладок."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Khi đang mở chia đôi, ⌘S thường chỉ chụp khung bạn đang làm việc. Chuyển sang mọi khung thì bạn có cả vùng nội dung — tất cả các khung cạnh nhau, vẫn không kèm thanh thẻ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分屏打开时，⌘S 通常只拍你正在使用的那个窗格。改成每个窗格，你就能得到整片内容区域——所有窗格并排，依然不含标签栏。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分割開啟時，⌘S 通常只拍你正在使用的那個窗格。改成每個窗格，你就能得到整片內容區域——所有窗格並排，依然不含分頁列。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "分割開啟時，⌘S 通常只拍你正在使用的那個窗格。改成每個窗格，你就能得到整片內容區域——所有窗格並排，依然不含分頁列。"
          }
        }
      }
    },
    "With this on, a trackpad pinch magnifies the page, and a two-finger double-tap zooms the text block under your fingers to fill the width — just like Safari. This is separate from ⌘+ / ⌘− page zoom, which reflows text instead of magnifying. Actual Size (⌘0) resets both." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مع تفعيل هذا الخيار، يكبّر القرص على لوحة التعقب الصفحة، ويقرّب النقر المزدوج بإصبعين كتلة النص تحت أصابعك لتملأ العرض — تمامًا كما في Safari. وهذا منفصل عن تكبير الصفحة بـ ⌘+ / ⌘− الذي يعيد تنسيق النص بدل تكبيره. ويعيد «الحجم الفعلي» (⌘0) ضبط الاثنين."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Amb això activat, un pessic al ratolí tàctil amplia la pàgina, i picar dos cops amb dos dits fa que el bloc de text sota els dits ompli tota l'amplada, igual que al Safari. Això és independent del zoom de pàgina ⌘+ / ⌘−, que recompon el text en comptes d'ampliar-lo. Mida real (⌘0) restableix totes dues coses."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se zapnutou volbou stažení prstů na trackpadu stránku zvětší a dvojité klepnutí dvěma prsty přiblíží blok textu pod prsty na celou šířku – přesně jako v Safari. To je něco jiného než zoom stránky ⌘+ / ⌘−, který text přeskládá místo zvětšení. Skutečná velikost (⌘0) vrátí obojí."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Med dette slået til forstørrer et knib på pegefeltet siden, og et dobbelttryk med to fingre zoomer tekstblokken under fingrene, så den fylder bredden – præcis som i Safari. Det er adskilt fra sidezoom med ⌘+ / ⌘−, som i stedet ombryder teksten. Faktisk størrelse (⌘0) nulstiller begge."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ist dies aktiv, vergrößert eine Aufziehgeste auf dem Trackpad die Seite, und ein Doppeltippen mit zwei Fingern zoomt den Textblock unter deinen Fingern auf die volle Breite – genau wie in Safari. Das ist unabhängig vom Seitenzoom mit ⌘+ / ⌘−, der den Text stattdessen neu umbricht. „Originalgröße“ (⌘0) setzt beides zurück."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Με αυτό ενεργό, ένα τσίμπημα στην επιφάνεια αφής μεγεθύνει τη σελίδα, και ένα διπλό χτύπημα με δύο δάχτυλα κάνει ζουμ στο μπλοκ κειμένου κάτω από τα δάχτυλά σου ώστε να γεμίσει το πλάτος — ακριβώς όπως στο Safari. Αυτό είναι ξεχωριστό από το ζουμ σελίδας ⌘+ / ⌘−, που αναδιατάσσει το κείμενο αντί να το μεγεθύνει. Το Πραγματικό μέγεθος (⌘0) επαναφέρει και τα δύο."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con esto activado, un pellizco en el trackpad amplía la página y un doble toque con dos dedos hace que el bloque de texto bajo tus dedos ocupe todo el ancho, igual que en Safari. Es independiente del zoom de página ⌘+ / ⌘−, que recompone el texto en lugar de ampliarlo. Tamaño real (⌘0) restablece ambos."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con esto activado, un pellizco en el trackpad amplía la página y un doble toque con dos dedos hace que el bloque de texto bajo tus dedos ocupe todo el ancho, igual que en Safari. Es independiente del zoom de página ⌘+ / ⌘−, que recompone el texto en lugar de ampliarlo. Tamaño real (⌘0) restablece ambos."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kun tämä on käytössä, ohjauslevyn nipistys suurentaa sivua ja kahden sormen kaksoisnapautus zoomaa sormiesi alla olevan tekstilohkon täyteen leveyteen – aivan kuten Safarissa. Tämä on eri asia kuin ⌘+ / ⌘− -sivuzoomaus, joka rivittää tekstin uudelleen. Todellinen koko (⌘0) palauttaa molemmat."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avec cette option, un pincement sur le trackpad agrandit la page, et un double-tap à deux doigts fait zoomer le bloc de texte sous vos doigts pour occuper toute la largeur — exactement comme dans Safari. C'est indépendant du zoom de page ⌘+ / ⌘−, qui refait la mise en page du texte au lieu de l'agrandir. Taille réelle (⌘0) réinitialise les deux."
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avec cette option, un pincement sur le trackpad agrandit la page, et un double-tap à deux doigts fait zoomer le bloc de texte sous vos doigts pour occuper toute la largeur — exactement comme dans Safari. C'est indépendant du zoom de page ⌘+ / ⌘−, qui refait la mise en page du texte au lieu de l'agrandir. Taille réelle (⌘0) réinitialise les deux."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "כשהאפשרות פעילה, צביטה על משטח המגע מגדילה את הדף, והקשה כפולה בשתי אצבעות מקרבת את גוש הטקסט שמתחת לאצבעות כך שימלא את הרוחב — בדיוק כמו ב‑Safari. זה נפרד מהגדלת הדף ב‑⌘+ / ⌘−, שמסדרת את הטקסט מחדש במקום להגדיל. ״גודל אמיתי״ (⌘0) מאפס את שניהם."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यह चालू होने पर ट्रैकपैड पर पिंच करने से पृष्ठ बड़ा होता है, और दो उँगलियों से दो बार टैप करने पर उँगलियों के नीचे का पाठ खंड पूरी चौड़ाई तक ज़ूम हो जाता है — बिलकुल Safari की तरह। यह ⌘+ / ⌘− वाले पृष्ठ ज़ूम से अलग है, जो बड़ा करने के बजाय पाठ को फिर से सजाता है। वास्तविक आकार (⌘0) दोनों को रीसेट कर देता है।"
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "S ovom opcijom stisak prstiju na trackpadu povećava stranicu, a dvostruki dodir s dva prsta zumira blok teksta pod prstima na punu širinu – baš kao u Safariju. To je odvojeno od zumiranja stranice ⌘+ / ⌘−, koje tekst prelama umjesto da ga povećava. Stvarna veličina (⌘0) vraća oboje."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ha ez be van kapcsolva, a trackpaden végzett csippentés nagyítja az oldalt, a kétujjas dupla koppintás pedig teljes szélességűre nagyítja az ujjaid alatti szövegblokkot – akárcsak a Safariban. Ez független a ⌘+ / ⌘− oldalnagyítástól, amely nagyítás helyett újratördeli a szöveget. A Valódi méret (⌘0) mindkettőt visszaállítja."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dengan opsi ini aktif, cubitan di trackpad memperbesar halaman, dan ketuk ganda dua jari memperbesar blok teks di bawah jari Anda hingga memenuhi lebar — persis seperti Safari. Ini terpisah dari perbesaran halaman ⌘+ / ⌘−, yang menata ulang teks alih-alih memperbesarnya. Ukuran Sebenarnya (⌘0) mengembalikan keduanya."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con questa opzione attiva, un pizzico sul trackpad ingrandisce la pagina e un doppio tocco con due dita porta il blocco di testo sotto le dita a riempire la larghezza, proprio come in Safari. È indipendente dallo zoom pagina ⌘+ / ⌘−, che invece riadatta il testo. Dimensioni reali (⌘0) ripristina entrambi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この設定を入れると、トラックパッドのピンチでページが拡大し、2 本指のダブルタップで指の下のテキストブロックが幅いっぱいにズームします。Safari と同じ動きです。文字を組み直す ⌘+ / ⌘− のページズームとは別物です。実際のサイズ（⌘0）で両方リセットされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 설정을 켜면 트랙패드 핀치가 페이지를 확대하고, 두 손가락 이중 탭이 손가락 아래 텍스트 블록을 너비에 맞게 확대합니다. Safari와 같습니다. 글을 다시 흘려 배치하는 ⌘+ / ⌘− 페이지 확대와는 별개이며, 실제 크기(⌘0)가 둘 다 재설정합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dengan ini dihidupkan, cubitan pada trackpad membesarkan halaman, dan ketikan dua jari dua kali menzum blok teks di bawah jari anda supaya memenuhi lebar — sama seperti Safari. Ini berasingan daripada zum halaman ⌘+ / ⌘−, yang menyusun semula teks dan bukannya membesarkannya. Saiz Sebenar (⌘0) menetapkan semula kedua-duanya."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Med dette på forstørrer et knip på styreflaten siden, og et dobbelttrykk med to fingre zoomer tekstblokken under fingrene så den fyller bredden – akkurat som i Safari. Dette er atskilt fra sidezoom med ⌘+ / ⌘−, som i stedet bryter om teksten. Faktisk størrelse (⌘0) nullstiller begge."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Met dit aan vergroot knijpen op het trackpad de pagina, en dubbeltikken met twee vingers zoomt het tekstblok onder je vingers tot de volle breedte – net als in Safari. Dit staat los van paginazoom met ⌘+ / ⌘−, die de tekst juist opnieuw laat lopen. Werkelijke grootte (⌘0) zet beide terug."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przy włączonej opcji szczypnięcie na gładziku powiększa stronę, a dwukrotne stuknięcie dwoma palcami zbliża blok tekstu pod palcami na całą szerokość — dokładnie jak w Safari. To coś innego niż powiększenie strony ⌘+ / ⌘−, które przelewa tekst zamiast go powiększać. Rzeczywisty rozmiar (⌘0) przywraca oba."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Com isto ativado, pinçar no trackpad amplia a página, e tocar duas vezes com dois dedos faz o bloco de texto sob seus dedos ocupar toda a largura — igual ao Safari. Isso é separado do zoom de página ⌘+ / ⌘−, que refaz o fluxo do texto em vez de ampliar. Tamanho real (⌘0) redefine os dois."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Com isto ativado, pinçar no trackpad amplia a página, e tocar duas vezes com dois dedos faz o bloco de texto sob seus dedos ocupar toda a largura — igual ao Safari. Isso é separado do zoom de página ⌘+ / ⌘−, que refaz o fluxo do texto em vez de ampliar. Tamanho real (⌘0) redefine os dois."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cu această opțiune activată, o ciupire pe trackpad mărește pagina, iar un dublu tap cu două degete aduce blocul de text de sub degete la lățimea întreagă — exact ca în Safari. E separat de zoomul de pagină ⌘+ / ⌘−, care rearanjează textul în loc să îl mărească. Dimensiune reală (⌘0) readuce ambele la normal."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "С этой настройкой щипок на трекпаде увеличивает страницу, а двойное касание двумя пальцами приближает блок текста под пальцами на всю ширину — как в Safari. Это не то же самое, что масштаб страницы ⌘+ / ⌘−, который переверстывает текст, а не увеличивает его. «Фактический размер» (⌘0) сбрасывает и то и другое."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "So zapnutou voľbou stiahnutie prstov na trackpade stránku zväčší a dvojité ťuknutie dvoma prstami priblíži blok textu pod prstami na celú šírku – presne ako v Safari. Je to niečo iné než zoom stránky ⌘+ / ⌘−, ktorý text preskladá namiesto zväčšenia. Skutočná veľkosť (⌘0) vráti oboje."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Med det här på förstorar ett nyp på styrplattan sidan, och ett dubbeltryck med två fingrar zoomar textblocket under fingrarna så att det fyller bredden – precis som i Safari. Det är skilt från sidzoom med ⌘+ / ⌘−, som i stället bryter om texten. Verklig storlek (⌘0) återställer båda."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เมื่อเปิดตัวเลือกนี้ การจีบนิ้วบนแทร็คแพดจะขยายหน้าเว็บ และการแตะสองนิ้วสองครั้งจะซูมบล็อกข้อความใต้นิ้วให้เต็มความกว้าง — เหมือน Safari เลย ซึ่งแยกจากการซูมหน้าด้วย ⌘+ / ⌘− ที่จัดข้อความใหม่แทนการขยาย ขนาดจริง (⌘0) รีเซ็ตทั้งสองอย่าง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu açıkken izleme dörtgeninde kıstırmak sayfayı büyütür, iki parmakla çift dokunuş ise parmaklarınızın altındaki metin bloğunu genişliği dolduracak şekilde yakınlaştırır — tıpkı Safari'deki gibi. Bu, metni büyütmek yerine yeniden akıtan ⌘+ / ⌘− sayfa yakınlaştırmasından ayrıdır. Gerçek Boyut (⌘0) ikisini de sıfırlar."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "З цим параметром щипок на трекпаді збільшує сторінку, а подвійний дотик двома пальцями наближає блок тексту під пальцями на всю ширину — як у Safari. Це не те саме, що масштаб сторінки ⌘+ / ⌘−, який перекомпоновує текст, а не збільшує його. «Фактичний розмір» (⌘0) скидає і те, і те."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bật tùy chọn này, chụm trên trackpad sẽ phóng to trang, còn chạm hai ngón hai lần sẽ thu phóng khối văn bản dưới ngón tay cho vừa chiều ngang — y như Safari. Việc này tách biệt với thu phóng trang ⌘+ / ⌘−, vốn dàn lại chữ thay vì phóng to. Kích cỡ thật (⌘0) đặt lại cả hai."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开启后，在触控板上捏合可放大页面，双指轻点两下会把手指下的文字块放大到铺满宽度——和 Safari 一样。这与 ⌘+ / ⌘− 的页面缩放不同，后者会重新排版文字。实际大小（⌘0）会同时复位两者。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "開啟後，在觸控式軌跡板上捏合可放大頁面，雙指點兩下會把手指下的文字區塊放大到填滿寬度——和 Safari 一樣。這與 ⌘+ / ⌘− 的頁面縮放不同，後者會重新排版文字。實際大小（⌘0）會同時重設兩者。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "開啟後，在觸控式軌跡板上捏合可放大頁面，雙指點兩下會把手指下的文字區塊放大到填滿寬度——和 Safari 一樣。這與 ⌘+ / ⌘− 的頁面縮放不同，後者會重新排版文字。實際大小（⌘0）會同時重設兩者。"
          }
        }
      }
    },
