        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Dochádza pamäť → karta je uvoľnená z RAM"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Minnet börjar ta slut → fliken frigörs från RAM"
          }
        },
        "th": {
