        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kết quả tìm được tự báo hiệu mạnh đến mức nào."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "找到的匹配项有多醒目。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
