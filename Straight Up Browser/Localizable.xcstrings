    "Click a shortcut and press the new keys. Esc cancels. Shortcuts need a modifier — ⌘, ⌥, ⌃, or ⇧." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "انقر على اختصار ثم اضغط المفاتيح الجديدة. Esc للإلغاء. يجب أن يتضمّن الاختصار مفتاح تعديل — ⌘ أو ⌥ أو ⌃ أو ⇧."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fes clic en una drecera i prem les tecles noves. Esc cancel·la. Les dreceres necessiten un modificador: ⌘, ⌥, ⌃ o ⇧."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klikněte na zkratku a stiskněte nové klávesy. Esc zruší akci. Zkratky potřebují modifikátor — ⌘, ⌥, ⌃ nebo ⇧."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klik på en genvej, og tryk på de nye taster. Esc annullerer. Genveje kræver en modifikatortast — ⌘, ⌥, ⌃ eller ⇧."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klicke auf einen Kurzbefehl und drücke die neuen Tasten. Esc bricht ab. Kurzbefehle brauchen eine Modifiziertaste – ⌘, ⌥, ⌃ oder ⇧."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Κάντε κλικ σε μια συντόμευση και πατήστε τα νέα πλήκτρα. Το Esc ακυρώνει. Οι συντομεύσεις χρειάζονται πλήκτρο τροποποίησης — ⌘, ⌥, ⌃ ή ⇧."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haz clic en un atajo y pulsa las teclas nuevas. Esc cancela. Los atajos necesitan un modificador: ⌘, ⌥, ⌃ o ⇧."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Napsauta pikanäppäintä ja paina uusia näppäimiä. Esc peruuttaa. Pikanäppäin tarvitsee muokkausnäppäimen — ⌘, ⌥, ⌃ tai ⇧."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cliquez sur un raccourci et appuyez sur les nouvelles touches. Esc annule. Un raccourci doit inclure une touche de modification — ⌘, ⌥, ⌃ ou ⇧."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "לחצו על קיצור והקישו על המקשים החדשים. Esc לביטול. קיצור חייב לכלול מקש עזר — ⌘, ⌥, ⌃ או ⇧."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "किसी शॉर्टकट पर क्लिक करें और नई कुंजियाँ दबाएँ. Esc रद्द करता है. शॉर्टकट में एक मॉडिफ़ायर होना चाहिए — ⌘, ⌥, ⌃, या ⇧."
          }
        },
        "hr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kliknite prečac i pritisnite nove tipke. Esc otkazuje. Prečac treba modifikator — ⌘, ⌥, ⌃ ili ⇧."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kattints egy gyorsbillentyűre, és nyomd le az új billentyűket. Az Esc megszakítja. A gyorsbillentyűhöz módosítóbillentyű kell — ⌘, ⌥, ⌃ vagy ⇧."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klik pintasan lalu tekan tombol baru. Esc membatalkan. Pintasan memerlukan pengubah — ⌘, ⌥, ⌃, atau ⇧."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fai clic su una scorciatoia e premi i nuovi tasti. Esc annulla. Le scorciatoie richiedono un modificatore — ⌘, ⌥, ⌃ o ⇧."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ショートカットをクリックして新しいキーを押します。Esc でキャンセルします。ショートカットには修飾キー（⌘、⌥、⌃、⇧）が必要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "단축키를 클릭한 다음 새 키를 누르세요. Esc로 취소합니다. 단축키에는 조합 키(⌘, ⌥, ⌃ 또는 ⇧)가 필요합니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klik pintasan dan tekan kekunci baharu. Esc membatalkan. Pintasan memerlukan pengubah suai — ⌘, ⌥, ⌃, atau ⇧."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klikk på en snarvei og trykk på de nye tastene. Esc avbryter. Snarveier trenger en modifikatortast – ⌘, ⌥, ⌃ eller ⇧."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klik op een sneltoets en druk op de nieuwe toetsen. Esc annuleert. Sneltoetsen hebben een modificatietoets nodig — ⌘, ⌥, ⌃ of ⇧."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kliknij skrót i naciśnij nowe klawisze. Esc anuluje. Skrót wymaga modyfikatora — ⌘, ⌥, ⌃ lub ⇧."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clique em um atalho e pressione as novas teclas. Esc cancela. Os atalhos precisam de um modificador — ⌘, ⌥, ⌃ ou ⇧."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fă clic pe o scurtătură și apasă tastele noi. Esc anulează. Scurtăturile au nevoie de un modificator — ⌘, ⌥, ⌃ sau ⇧."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нажмите на сочетание и введите новые клавиши. Esc отменяет. Сочетание должно содержать клавишу-модификатор — ⌘, ⌥, ⌃ или ⇧."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kliknite na skratku a stlačte nové klávesy. Esc zruší. Skratka potrebuje modifikátor — ⌘, ⌥, ⌃ alebo ⇧."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klicka på en genväg och tryck på de nya tangenterna. Esc avbryter. Genvägar behöver en modifierartangent – ⌘, ⌥, ⌃ eller ⇧."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "คลิกทางลัดแล้วกดปุ่มใหม่ Esc เพื่อยกเลิก ทางลัดต้องมีปุ่มขยาย — ⌘, ⌥, ⌃ หรือ ⇧"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bir kısayola tıklayıp yeni tuşlara basın. Esc iptal eder. Kısayollar bir değiştirici gerektirir — ⌘, ⌥, ⌃ veya ⇧."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Клацніть сполучення та натисніть нові клавіші. Esc скасовує. Сполучення потребує клавіші-модифікатора — ⌘, ⌥, ⌃ або ⇧."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nhấp vào một phím tắt rồi nhấn các phím mới. Esc để hủy. Phím tắt cần một phím bổ trợ — ⌘, ⌥, ⌃ hoặc ⇧."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "点按某个快捷键，然后按下新的按键。Esc 取消。快捷键需要包含修饰键 — ⌘、⌥、⌃ 或 ⇧。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按一下某個快捷鍵，然後按下新的按鍵。Esc 取消。快捷鍵需要包含輔助鍵 — ⌘、⌥、⌃ 或 ⇧。"
          }
        },
        "zh-HK" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按一下某個快捷鍵，然後按下新的按鍵。Esc 取消。快捷鍵需要包含輔助鍵 — ⌘、⌥、⌃ 或 ⇧。"
          }
        },
        "fr-CA" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cliquez sur un raccourci et appuyez sur les nouvelles touches. Esc annule. Un raccourci doit inclure une touche de modification — ⌘, ⌥, ⌃ ou ⇧."
          }
        },
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haz clic en un atajo y pulsa las teclas nuevas. Esc cancela. Los atajos necesitan un modificador: ⌘, ⌥, ⌃ o ⇧."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clique em um atalho e pressione as novas teclas. Esc cancela. Os atalhos precisam de um modificador — ⌘, ⌥, ⌃ ou ⇧."
          }
        }
      }
    },
