    "Lets `browser-cli click --real` post genuine mouse events." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتيح للأمر `browser-cli click --real` إرسال أحداث فأرة حقيقية."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permet que `browser-cli click --real` enviï esdeveniments de ratolí genuïns."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Umožňuje příkazu `browser-cli click --real` odesílat opravdové události myši."
          }
        },
        "da" : {
