          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रोज़मर्रा के शॉर्टकट को प्रिंट करने के बजाय PDF सहेजने पर सेट करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Neka svakodnevni prečac sprema PDF umjesto ispisa."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A mindennapi gyorsbillentyű nyomtatás helyett PDF-et mentsen."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Buat pintasan sehari-hari menyimpan PDF alih-alih mencetak."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fai in modo che la scorciatoia di tutti i giorni salvi un PDF invece di stampare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "日常のショートカットで印刷の代わりにPDFを保存させます。"
