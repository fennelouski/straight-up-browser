    "The certificate for %@ could not be verified.\n\nTrust Result: %@\n\nThis may indicate a security risk. Do you want to proceed anyway?" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تعذّر التحقق من شهادة %@.\n\nنتيجة الثقة: %@\n\nقد يشير هذا إلى خطر أمني. هل تريد المتابعة على أي حال؟"
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No s'ha pogut verificar el certificat de %@.\n\nResultat de confiança: %@\n\nAixò pot indicar un risc de seguretat. Vols continuar igualment?"
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Certifikát pro %@ nebylo možné ověřit.\n\nVýsledek důvěryhodnosti: %@\n\nToto může znamenat bezpečnostní riziko. Chceš přesto pokračovat?"
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Certifikatet for %@ kunne ikke verificeres.\n\nTillidsresultat: %@\n\nDette kan indikere en sikkerhedsrisiko. Vil du fortsætte alligevel?"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Zertifikat für %@ konnte nicht überprüft werden.\n\nVertrauensergebnis: %@\n\nDies kann auf ein Sicherheitsrisiko hinweisen. Möchtest du trotzdem fortfahren?"
          }
        },
        "el" : {
          "stringUnit" : {
