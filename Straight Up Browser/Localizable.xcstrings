        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Akce tvého prohlížeče — Otevřít URL, Hledat na webu, Nová karta — se objevují v aplikaci Zkratky, ve Spotlightu a v Siri. Zkus říct «Nová karta v Browser»."
          }
        },
        "da" : {
