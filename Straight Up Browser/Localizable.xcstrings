        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przestrzega Twoich aktywnych reguł w kolejności: domeny nigdy, przełączniki dla typów, domeny zawsze, następnie typy plików."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segue suas regras ativas em ordem: domínios nunca, os interruptores por tipo, domínios sempre, depois tipos de arquivo."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Segue suas regras ativas em ordem: domínios nunca, os interruptores por tipo, domínios sempre, depois tipos de arquivo."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Urmează regulile tale active în ordine: domenii niciodată, comutatoarele pe tip, domenii întotdeauna, apoi tipuri de fișiere."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Следует вашим активным правилам по порядку: домены «никогда», переключатели по типу, домены «всегда», затем типы файлов."
          }
        },
        "sk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Riadi sa tvojimi aktívnymi pravidlami v poradí: domény nikdy, prepínače podľa typu, domény vždy, potom typy súborov."
          }
        },
        "sv" : {
          "stringUnit" : {
