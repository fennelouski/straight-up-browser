    "Print is still one keystroke away: ⇧⌘P.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الطباعة لا تزال على بُعد مفتاح واحد: ⇧⌘P."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "Imprimir encara és a una tecla de distància: ⇧⌘P."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tisk je stále jen jednu klávesu daleko: ⇧⌘P."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Udskrivning er stadig kun ét tastetryk væk: ⇧⌘P."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Drucken ist weiterhin nur einen Tastendruck entfernt: ⇧⌘P."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η εκτύπωση είναι ακόμη ένα πάτημα μακριά: ⇧⌘P."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Imprimir sigue estando a una tecla: ⇧⌘P."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Imprimir sigue estando a una tecla: ⇧⌘P."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tulostus on yhä yhden näppäimen päässä: ⇧⌘P."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'impression reste à une touche : ⇧⌘P."
          }
        },
        "fr-CA": {
          "stringUnit": {
            "state": "translated",
            "value": "L'impression reste à une touche : ⇧⌘P."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ההדפסה עדיין במרחק מקש אחד: ⇧⌘P."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रिंट अभी भी एक कुंजी दूर है: ⇧⌘P।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ispis je i dalje udaljen samo jednu tipku: ⇧⌘P."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
