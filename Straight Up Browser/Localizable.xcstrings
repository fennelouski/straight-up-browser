            "value": "Afdrukken is nog steeds één toets ver: ⇧⌘P."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Drukowanie wciąż jest o jeden klawisz dalej: ⇧⌘P."
          }
        },
        "pt-BR": {
