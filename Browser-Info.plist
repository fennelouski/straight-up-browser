<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- System Settings → Default web browser only lists apps that claim the
	     web document types as well as the http/https schemes — the URL types
	     alone get you into "Open With" but not into the browser picker.
	     Mirrors what Safari, Chrome, and Arc declare.
	     Generated keys (version, category, copyright…) are merged in by
	     GENERATE_INFOPLIST_FILE. -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>HTML document</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.html</string>
				<string>public.xhtml</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Plain text document</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.text</string>
			</array>
		</dict>
	</array>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>Web site URL</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>http</string>
				<string>https</string>
			</array>
		</dict>
	</array>
	<!-- Sparkle auto-update. Feed is generated + signed by
	     scripts/sparkle-bin/generate_appcast (see scripts/release.sh) and hosted
	     alongside the DMG. Filename is "browser-appcast.xml", not the generic
	     "appcast.xml" — that name is already taken by Dictate's feed in the same
	     nathanfennel.com/downloads/ folder. SUPublicEDKey is the public half of
	     the EdDSA key in the release Mac's Keychain — it never changes across
	     releases; losing the private key would break updates for everyone
	     already installed. -->
	<key>SUFeedURL</key>
	<string>https://nathanfennel.com/downloads/browser-appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>EVIc3OgRfDph2xDZgmLkjrHOdI8S249jGppr8MHTMCs=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUAutomaticallyUpdate</key>
	<true/>
</dict>
</plist>
